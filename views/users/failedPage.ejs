<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Payment Failed</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <style>
    :root {
      --primary: #C586A5;
      --primary-dark: #A76C86;
      --primary-light: #f3e8ed;
      --text-dark: #1A202C;
      --text-muted: #6B7280;
      --background: #F9FAFB;
      --white: #FFFFFF;
      --border: #E2E8F0;
      --shadow: 0 1px 3px rgba(0, 0, 0, 0.05), 0 4px 12px rgba(0, 0, 0, 0.03);
      --shadow-hover: 0 4px 6px rgba(0, 0, 0, 0.08);
      --error: #EF4444;
      --error-light: #fee2e2;
      --success: #10B981;
    }
    
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      background-color: var(--background);
      color: var(--text-dark);
      line-height: 1.5;
      padding: 0;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    
    .payment-container {
      max-width: 520px;
      margin: 2rem auto;
      background: var(--white);
      border-radius: 16px;
      box-shadow: var(--shadow);
      padding: 2.5rem;
      border: 1px solid var(--border);
    }
    
    .payment-header {
      margin-bottom: 1.75rem;
      text-align: center;
    }
    
    .payment-header h1 {
      font-weight: 600;
      font-size: 1.75rem;
      color: var(--error);
      margin-bottom: 0.5rem;
    }
    
    .payment-alert {
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
      background-color: var(--error-light);
      border: none;
      color: var(--error);
      font-weight: 500;
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }
    
    .payment-alert:before {
      content: "!";
      font-weight: bold;
      display: inline-block;
      min-width: 1.5rem;
      height: 1.5rem;
      background: var(--error);
      color: white;
      border-radius: 50%;
      text-align: center;
      line-height: 1.5;
    }
    
    .payment-details {
      background: var(--primary-light);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }
    
    .payment-details p {
      margin-bottom: 0.5rem;
      font-size: 0.95rem;
    }
    
    .payment-actions {
      display: flex;
      gap: 1rem;
      margin-top: 1.5rem;
      flex-wrap: wrap;
    }
    
    .btn {
      padding: 0.75rem 1.5rem;
      border-radius: 10px;
      font-weight: 500;
      transition: all 0.2s ease;
      flex: 1;
      min-width: 180px;
      text-align: center;
    }
    
    .btn-primary {
      background: var(--primary);
      border: none;
      color: var(--white);
    }
    
    .btn-primary:hover {
      background: var(--primary-dark);
      transform: translateY(-1px);
      box-shadow: var(--shadow-hover);
    }
    
    .btn-dark {
      background: var(--text-dark);
      border: none;
    }
    
    .btn-dark:hover {
      background: var(--text-muted);
      transform: translateY(-1px);
      box-shadow: var(--shadow-hover);
    }
    
    @media (max-width: 576px) {
      body {
        padding: 1rem;
      }
      
      .payment-container {
        padding: 1.75rem;
        margin: 0;
        width: 100%;
      }
      
      .payment-actions {
        flex-direction: column;
        gap: 0.75rem;
      }
      
      .btn {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <div class="payment-container">
    <div class="payment-header">
      <h1>Payment Failed</h1>
    </div>
    
    <div class="alert alert-danger payment-alert">
      <%= message %>
    </div>

    <% if (retryAvailable) { %>
      <h3 class="h5 mb-3">Retry Payment</h3>
      
      <% if (isBuyNow && tempOrder.orderedItems[0]?.productDetails) { %>
        <div class="payment-details">
          <p><strong>Product:</strong> <%= tempOrder.orderedItems[0].productDetails.productName %></p>
          <p><strong>Size:</strong> <%= size %></p>
        </div>
      <% } %>
      
      <form id="retryCheckoutForm" action="/retry-checkout" method="POST">
        <input type="hidden" name="orderId" value="<%= tempOrder._id %>">
        <% if (isBuyNow) { %>
          <input type="hidden" name="productId" value="<%= productId %>">
          <input type="hidden" name="size" value="<%= size %>">
        <% } %>
        <input type="hidden" name="buyNow" value="<%= isBuyNow %>">
        <div class="payment-actions">
          <button type="submit" class="btn btn-primary">Go to Checkout</button>
          <a href="/" class="btn btn-dark">Go to Home</a>
        </div>
      </form>

    <% } else { %>
      <p class="mb-3">Please try placing a new order.</p>
      <div class="payment-actions">
        <a href="/" class="btn btn-primary">Go to Home</a>
      </div>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>