<%- include("../layouts/header.ejs") %>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
<style>
   body {
    font-family: 'Poppins', sans-serif;
  }
  .navbar-brand {
    font-weight: 700;
    font-size: 1.6rem;
    color: #1a1517;
    letter-spacing: 0.5px;
  }

  .brand-dot {
    width: 10px;
    height: 10px;
    background: #C586A5;
    border-radius: 50%;
    display: inline-block;
  }

  .navbar-nav {
    gap: 1.5rem;
  }

  .navbar-nav .nav-link {
    font-weight: 500;
    color: #333;
    transition: color 0.3s;
  }

  .navbar-nav .nav-link:hover,
  .navbar-nav .nav-link.active {
    color: #C586A5;
  }

  .badge-dot {
    position: absolute;
    top: -5px;
    right: -5px;
    width: 10px;
    height: 10px;
    background-color: red;
    border-radius: 50%;
    border: 1px solid white;
  }
  .form-container {
    max-width: 800px;
    margin: auto;
  }
  .form-card {
    border: none;
    border-radius: 15px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    background: #ffffff;
  }
  .btn-primary {
    background: linear-gradient(45deg, #1a1517, #1f1b1d);
    border: none;
    padding: 12px 30px;
    font-size: 1.1rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(4, 105, 99, 0.3);
  }
  .form-label {
    font-weight: 600;
    color: #333;
  }
  .form-control {
    border-radius: 8px;
    border: 1px solid #ced4da;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .form-control:focus {
    border-color: #C586A5;
    box-shadow: 0 0 0 0.25rem rgba(4, 105, 99, 0.25);
  }
  h3 {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    color: #C586A5;
  }
</style>

<nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top py-3">
