<%- include("../layouts/header.ejs") %>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

  .navbar-brand {
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: 1px;
  }
  .brand-dot {
    width: 10px;
    height: 10px;
    background: #C586A5;
    border-radius: 50%;
    display: inline-block;
  }
  .navbar-nav {
    gap: 2rem;
  }
  body {
    font-family: 'Poppins', sans-serif;
    margin: 0;
    padding: 0;
  }

  .navbar {
    margin-left: 250px;
    background: #fff;
    transition: margin-left 0.3s;
  }

  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 250px;
    height: 100%;
    background-color: #ffffff;
    border-right: 1px solid #ddd;
    padding: 20px;
    overflow-y: auto;
    transition: transform 0.3s ease-in-out;
    z-index: 1000;
  }

  .sidebar h4 {
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 30px;
  }

  .filter-section {
    margin-bottom: 30px;
  }

  .filter-title {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 12px;
    color: #333;
    border-bottom: 1px solid #ddd;
    padding-bottom: 6px;
  }

  .filter-section ul {
    list-style: none;
    padding-left: 0;
    margin: 0;
  }

  .filter-item a {
    display: block;
    color: #555;
    text-decoration: none;
    padding: 6px 0;
    transition: all 0.3s ease;
    border-radius: 4px;
  }

  .filter-item a:hover {
    background-color: #f1f1f1;
    color: #C586A5;
  }

  .price-button {
    display: block;
    width: 100%;
    background-color: #f1f1f1;
    border: none;
    padding: 10px 15px;
    text-align: left;
    font-size: 14px;
    color: #333;
    border-radius: 6px;
    margin-bottom: 10px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .price-button:hover {
    background-color: #C586A5;
    color: #fff;
  }

  .main-content {
    margin-left: 250px;
    padding: 20px;
  }

  .product-card {
    border: 1px solid #ddd;
    padding: 15px;
    border-radius: 8px;
    text-align: center;
    height: 100%;
  }

  .product-card img {
    max-width: 100%;
    height: auto;
    border-radius: 5px;
    margin-bottom: 10px;
  }

  .shop-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .search-form {
  display: flex;
  align-items: center;
  max-width: 400px;
  background: #f5f5f5;
  border-radius: 50px;
  padding: 5px;
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.search-input {
  flex: 1;
  border: none;
  background: transparent;
  padding: 12px 20px;
  font-size: 16px;
  outline: none;
  color: #333;
}

.search-input::placeholder {
  color: #aaa;
  font-weight: 500;
}

.search-button {
  background: #111;
  color: #fff;
  border: none;
  padding: 12px 24px;
  font-size: 16px;
  font-weight: 600;
  border-radius: 50px;
  margin-left: 5px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.search-button:hover {
  background: #333;
}


  /* .search-form {
    display: flex;
    align-items: center;
    background-color: #f1f1f1;
    border-radius: 25px;
    overflow: hidden;
    max-width: 300px;
    width: 100%;
  }

  .search-input {
    flex: 1;
    padding: 8px 10px;
    border: none;
    outline: none;
    background-color: transparent;
  }

  .search-button {
    padding: 8px 0px;
    background-color: #060606;
    color: #fff;
    border: none;
    cursor: pointer;
    font-size: 14px;
  } */

  @media (max-width: 992px) {
    .navbar {
      margin-left: 0;
    }

    .sidebar {
      transform: translateX(-100%);
    }

    .sidebar.show {
      transform: translateX(0);
    }

    .main-content {
      margin-left: 0;
    }
  }
</style>

<!-- Sidebar -->
<aside class="sidebar" id="sidebar">
  <h4>Filters</h4>
  <div class="filter-section">
    <div class="filter-title">Categories</div>
    <ul>
      <% for(let i=0;i<category.length;i++) {%>
        <li class="filter-item">
          <a href="/filter?category=<%=category[i]._id%>"><%=category[i].name%></a>
        </li>
      <% } %>
    </ul>
  </div>

  <div class="filter-section">
    <div class="filter-title">Brands</div>
    <ul>
      <% for(let i=0;i<brand.length;i++) {%>
        <li class="filter-item">
          <a href="/filter?brand=<%=brand[i]._id%>"><%=brand[i].brandName%></a>
        </li>
      <% } %>
    </ul>
  </div>

  <!-- <div class="filter-section mt-4">
    <div class="filter-title">Sort By</div>
    <a href="/filterPrice?sort=Low-to-High" class="btn btn-outline-secondary btn-sm">Price: Low to High</a>
    <a href="/filterPrice?sort=High-to-Low" class="btn btn-outline-secondary btn-sm">Price: High to Low</a>
    <a href="/filterPrice?sort=name-asc" class="btn btn-outline-secondary btn-sm">Name: A-Z</a>
    <a href="/filterPrice?sort=name-desc" class="btn btn-outline-secondary btn-sm">Name: Z-A</a>
  </div> -->
  <div class="filter-section mt-4">
    <div class="filter-title">Sort By</div>
    <ul>
      <li class="filter-item">
        <a href="/filterPrice?sort=Low-to-High">Price: Low to High</a>
      </li>
      <li class="filter-item">
        <a href="/filterPrice?sort=High-to-Low">Price: High to Low</a>
      </li>
      <li class="filter-item">
        <a href="/filterPrice?sort=name-asc">Name: A-Z</a>
      </li>
      <li class="filter-item">
        <a href="/filterPrice?sort=name-desc">Name: Z-A</a>
      </li>
    </ul>
  </div>
  
</aside>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top py-3">
  <div class="container d-flex align-items-center justify-content-between">
    <a href="#" class="navbar-brand d-flex align-items-center gap-2">18-CREW <span class="brand-dot"></span></a>
    <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse flex-grow-1 justify-content-center" id="navbarContent">
      <ul class="navbar-nav mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link active" href="/">HOME</a></li>
        <li class="nav-item"><a class="nav-link" href="/shop">COLLECTION</a></li>
        <li class="nav-item"><a class="nav-link" href="#">ABOUT</a></li>
        <li class="nav-item"><a class="nav-link" href="#">CONTACT</a></li>
      </ul>
    </div>

    <div class="d-flex align-items-center gap-3">
      <a href="#" class="text-dark" style="font-size: 1.5rem;"><i class="bi bi-search"></i></a>
      <a href="#" class="text-dark" style="font-size: 1.5rem;"><i class="bi bi-bag"></i></a>
      <% if (locals?.user) { %>
        <div class="dropdown">
          <a class="nav-link dropdown-toggle text-uppercase fw-bold" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <%= locals.user.name %>
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="/userProfile">Profile</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>
          </ul>
        </div>
      <% } else { %>
        <a href="/signin" class="text-dark" style="font-size: 1.5rem;">
          <i class="bi bi-person"></i>
        </a>
      <% } %>
    </div>
  </div>
</nav>

<!-- Main Content -->
<div class="main-content">
  <div class="shop-topbar mb-4">
    <form action="/search" method="POST" class="search-form">
      <input type="text" name="query" placeholder="Search items..." class="search-input" />
      <button type="submit" class="search-button">Search</button>
    </form>
  </div>

  <div class="row g-4">
    <% for(let i=0;i<products.length;i++) {%>
      <div class="col-sm-6 col-md-4">
        <div class="product-card h-100">
          <a href="/productDetails?id=<%=products[i]._id%>" class="text-black text-decoration-none">
            <img src="/uploads/re-image/<%=products[i].productImage[0]%>" alt="<%=products[i].productName%>" />
            <div class="product-details">
              <h5 class="fw-semibold mb-1"><%= products[i].productName %></h5>
              <p class="text-secondary mb-1">Brand: <span class="text-dark"><%= products[i].brand %></span></p>
              <p class="mb-0">
                <span class="fw-bold text-success">₹<%= products[i].salePrice.toLocaleString('en-IN') %></span>
                <span class="text-muted ms-2">
                  <strike>₹<%= products[i].regularPrice.toLocaleString('en-IN') %></strike>
                </span>
              </p>
            </div>
          </a>
          <button class="btn btn-dark w-100 mt-2">Add to Cart</button>
        </div>
      </div>
    <% } %>
  </div>

  <nav aria-label="Page navigation" class="mt-4 d-flex justify-content-center">
    <ul class="pagination">
      <% if (currentPage > 1) { %>
        <li class="page-item">
          <a class="page-link" href="/shop?page=<%= currentPage - 1 %>">Prev</a>
        </li>
      <% } %>

      <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
          <a class="page-link" href="/shop?page=<%= i %>"><%= i %></a>
        </li>
      <% } %>

      <% if (currentPage < totalPages) { %>
        <li class="page-item">
          <a class="page-link" href="/shop?page=<%= currentPage + 1 %>">Next</a>
        </li>
      <% } %>
    </ul>
  </nav>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const sidebarToggle = document.getElementById("sidebarToggle");
  const sidebar = document.getElementById("sidebar");

  if (sidebarToggle) {
    sidebarToggle.addEventListener("click", () => {
      sidebar.classList.toggle("show");
    });
  }
</script>
<%- include("../layouts/footer.ejs") %>

