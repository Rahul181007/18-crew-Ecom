<%- include("../layouts/header.ejs") %>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
 <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  <style>
    :root {
      --primary-color: #C586A5;
      --primary-dark: #9F6B89;
      --secondary-color: #1a1517;
      --accent-color: #e60039;
      --light-bg: #f8f9fa;
      --dark-text: #212529;
      --muted-text: #6c757d;
      --light-gray: #f5f5f5;
      --border-color: #e9ecef;
      --transition-speed: 0.3s;
      --border-radius: 10px;
      --box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
      --box-shadow-hover: 0 8px 32px rgba(0, 0, 0, 0.12);
    }
    
body {
    font-family: 'Poppins', sans-serif;
    background-color: var(--background);
    color: var(--text-dark);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
}
/* Navigation */
  .navbar {
    box-shadow: 0 2px 15px rgba(0,0,0,0.05);
    transition: all var(--transition-speed) ease;
  }
  
  .navbar.scrolled {
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  
  .navbar-brand {
    font-weight: 700;
    font-size: 1.6rem;
    color: var(--secondary-color);
    letter-spacing: 0.5px;
    position: relative;
  }
  
  .brand-dot {
    width: 10px;
    height: 10px;
    background: var(--primary-color);
    border-radius: 50%;
    display: inline-block;
    margin-left: 4px;
  }
  
  .navbar-nav {
    gap: 1.5rem;
  }
  
  .navbar-nav .nav-link {
    font-weight: 500;
    color: var(--dark-text);
    transition: color var(--transition-speed);
    position: relative;
    padding: 0.5rem 0;
  }
  
  .navbar-nav .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--primary-color);
    transition: width var(--transition-speed);
  }
  
  .navbar-nav .nav-link:hover::after,
  .navbar-nav .nav-link.active::after {
    width: 100%;
  }
  
  .navbar-nav .nav-link:hover,
  .navbar-nav .nav-link.active {
    color: var(--primary-color);
  }
  
  /* Badge */
  .badge-dot {
    position: absolute;
    top: -5px;
    right: -5px;
    width: 10px;
    height: 10px;
    background-color: var(--accent-color);
    border-radius: 50%;
    border: 1px solid white;
  }
  
    
    /* Main Content Layout */
    .shop-container {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 2rem;
      padding: 2rem 0;
    }
    
    /* Filter Sidebar */
    .filter-sidebar {
      background: white;
      border-radius: var(--border-radius);
      box-shadow: var(--box-shadow);
      padding: 1.5rem;
      height: fit-content;
      position: sticky;
      top: 1rem;
    }
    
    .filter-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
    }
    
    .filter-title {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--secondary-color);
    }
    
    .filter-group {
      margin-bottom: 1.5rem;
    }
    
    .filter-group-title {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--secondary-color);
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      cursor: pointer;
    }
    
    .filter-group-content {
      padding-left: 0.5rem;
    }
    
    .filter-option {
      display: flex;
      align-items: center;
      margin-bottom: 0.5rem;
    }
    
    .filter-option input[type="checkbox"] {
      margin-right: 0.75rem;
      accent-color: var(--primary-color);
      width: 1.1em;
      height: 1.1em;
    }
    
    .filter-option label {
      font-size: 0.95rem;
      color: var(--dark-text);
      cursor: pointer;
      transition: color var(--transition-speed);
    }
    
    .filter-option:hover label {
      color: var(--primary-color);
    }
    
    .filter-apply {
      background: var(--primary-color);
      color: white;
      border: none;
      padding: 0.75rem 1.5rem;
      border-radius: var(--border-radius);
      width: 100%;
      font-weight: 600;
      margin-top: 1rem;
      transition: all var(--transition-speed);
    }
    
    .filter-apply:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
    }
    
    /* Product Grid */
    .product-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1.5rem;
    }
    
    /* Product Card */
    .product-card {
      background: white;
      border-radius: var(--border-radius);
      padding: 1.5rem;
      box-shadow: var(--box-shadow);
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(0,0,0,0.05);
    }
    
    .product-card:hover {
      transform: translateY(-8px);
      box-shadow: var(--box-shadow-hover);
      border-color: rgba(197, 134, 165, 0.3);
    }
    
    .product-card img {
      width: 100%;
      height: 220px;
      object-fit: contain;
      border-radius: 8px;
      margin-bottom: 1.5rem;
      transition: transform 0.3s ease;
      background: #f9f9f9;
      padding: 1rem;
    }
    
    .product-card:hover img {
      transform: scale(1.03);
    }
    
    .product-details {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    
    .product-title {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--dark-text);
      margin-bottom: 0.5rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    
    .product-brand {
      font-size: 0.9rem;
      color: var(--muted-text);
      margin-bottom: 0.75rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    
    .price-container {
      margin-top: auto;
    }
    
    .current-price {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--primary-color);
    }
    
    .original-price {
      font-size: 0.9rem;
      color: var(--muted-text);
      text-decoration: line-through;
      margin-left: 0.5rem;
    }
    
    .product-actions {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 1.5rem;
    }
    
    .btn-quick-view {
      background: var(--primary-color);
      color: white;
      border: none;
      padding: 0.75rem;
      font-weight: 600;
      border-radius: var(--border-radius);
      width: calc(100% - 40px);
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      font-size: 0.9rem;
    }
    
    .btn-quick-view:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
    }
    
    .wishlist-icon {
      position: relative;
      color: var(--muted-text);
      transition: all 0.3s ease;
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: rgba(0,0,0,0.03);
    }
    
    .wishlist-icon:hover {
      color: var(--primary-color);
      background: rgba(197, 134, 165, 0.1);
    }
    
    .wishlist-icon i {
      font-size: 1.2rem;
    }
    
    .wishlist-icon.wishlist-active {
      color: var(--primary-color);
    }
    
    /* Mobile Filter Controls */
    .mobile-filter-controls {
      display: none;
      margin-bottom: 1.5rem;
    }
    
    .btn-filter-mobile {
      background: var(--primary-color);
      color: white;
      border: none;
      padding: 0.75rem 1.5rem;
      border-radius: var(--border-radius);
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    
    .filter-results-count {
      font-size: 0.9rem;
      color: var(--muted-text);
    }
    
    /* Responsive Adjustments */
    @media (max-width: 992px) {
      .shop-container {
        grid-template-columns: 1fr;
      }
      
      .filter-sidebar {
        position: fixed;
        top: 0;
        left: 0;
        width: 90%;
        max-width: 400px;
        height: 100vh;
        z-index: 1050;
        overflow-y: auto;
        transform: translateX(-100%);
        transition: transform 0.3s ease;
        border-radius: 0;
        padding: 1.5rem;
      }
      
      .filter-sidebar.active {
        transform: translateX(0);
      }
      
      .mobile-filter-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      
      .overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        z-index: 1040;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
      }
      
      .overlay.active {
        opacity: 1;
        visibility: visible;
      }
    }
    
    @media (max-width: 576px) {
      .product-grid {
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 1rem;
      }
      
      .btn-filter-mobile {
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
      }
    }
    
    /* Empty State */
    .empty-state {
      text-align: center;
      padding: 3rem 0;
      grid-column: 1 / -1;
    }
    
    .empty-state img {
      max-width: 250px;
      opacity: 0.7;
      margin-bottom: 1.5rem;
    }
    /* Search Styles */
.search-container {
  position: relative;
  width: 250px;
  transition: width 0.3s ease;
}

.search-input {
  border-radius: 20px;
  padding: 0.5rem 1rem;
  border: 1px solid var(--border-color);
  transition: all 0.3s ease;
}

.search-input:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 0.25rem rgba(197, 134, 165, 0.25);
  width: 300px;
}

.btn-search {
  position: absolute;
  right: 0;
  top: 0;
  height: 100%;
  background: transparent;
  border: none;
  color: var(--muted-text);
  z-index: 5;
}

.btn-search:hover {
  color: var(--primary-color);
}

.btn-clear-search {
  position: absolute;
  right: 40px;
  top: 50%;
  transform: translateY(-50%);
  background: transparent;
  border: none;
  color: var(--muted-text);
  padding: 0;
  z-index: 5;
}

.btn-clear-search:hover {
  color: var(--accent-color);
}

.search-suggestions {
  position: absolute;
  top: 100%;
  left: 0;
  width: 100%;
  max-height: 300px;
  overflow-y: auto;
  display: none;
  z-index: 1000;
  border-radius: var(--border-radius);
  box-shadow: var(--box-shadow);
  padding: 0.5rem 0;
  margin-top: 0.5rem;
}

.search-suggestions.show {
  display: block;
}

.search-suggestions .dropdown-item {
  padding: 0.5rem 1rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.search-suggestions .dropdown-item:hover {
  background-color: rgba(197, 134, 165, 0.1);
  color: var(--primary-color);
}

.search-suggestions .dropdown-item:active {
  background-color: var(--primary-color);
  color: white;
}

/* Responsive search */
@media (max-width: 992px) {
  .search-container {
    width: 200px;
  }
  
  .search-input:focus {
    width: 250px;
  }
}

@media (max-width: 768px) {
  .search-container {
    order: -1;
    width: 100%;
    margin-bottom: 1rem;
  }
  
  .search-input:focus {
    width: 100%;
  }
}
  </style>

  <!-- Navbar -->
 
<nav class="navbar navbar-expand-lg navbar-light bg-white py-3 sticky-top">
    <div class="container">
      <a href="/" class="navbar-brand d-flex align-items-center">
        18-CREW<span class="brand-dot"></span>
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarContent">
        <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link <%= typeof page !== 'undefined' && page === 'home' ? 'active' : '' %>" href="/">HOME</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= typeof page !== 'undefined' && page === 'shop' ? 'active' : '' %>" href="/shop">COLLECTION</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= typeof page !== 'undefined' && page === 'about' ? 'active' : '' %>" href="/about">ABOUT</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= typeof page !== 'undefined' && page === 'contact' ? 'active' : '' %>" href="/contact">CONTACT</a>
          </li>

          <% if (locals?.user || user) { %>
            <li class="nav-item dropdown d-lg-none">
              <a class="nav-link dropdown-toggle text-uppercase fw-bold" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <%= user.name %>
              </a>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/userProfile">Profile</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>
              </ul>
            </li>
          <% } else { %>
            <li class="nav-item d-lg-none">
              <a class="nav-link" href="/signin"><i class="bi bi-person me-2"></i>Sign In</a>
            </li>
          <% } %>
        </ul>

        <div class="d-none d-lg-flex align-items-center gap-3">
          <% if (locals?.user || user) { %>
            <div class="dropdown">
              <a class="nav-link dropdown-toggle text-uppercase fw-bold d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-person-circle me-2"></i>
                <%= user.name %>
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/userProfile">Profile</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>
              </ul>
            </div>
          <% } else { %>
            <a href="/signin" class="text-dark fs-5" title="Account" aria-label="Account">
              <i class="bi bi-person"></i>
            </a>
          <% } %>
          <a href="/wishlist" class="text-dark position-relative fs-5" title="Wishlist" aria-label="Wishlist<%= wishlistCount > 0 ? ` with ${wishlistCount} items` : '' %>">
            <i class="bi bi-heart"></i>
            <% if (wishlistCount > 0) { %>
              <span class="badge-dot"></span>
            <% } %>
          </a>
          <a href="/getCartPage" class="text-dark position-relative fs-5" title="Cart" aria-label="Cart<%= cartCount > 0 ? ` with ${cartCount} items` : '' %>">
            <i class="bi bi-bag"></i>
            <% if (cartCount > 0) { %>
              <span class="badge-dot"></span>
            <% } %>
          </a>
        </div>
      </div>
    </div>
  </nav>

 <form class="d-flex align-items-center me-3 position-relative" id="searchForm">
  <div class="input-group search-container">
    <input class="form-control search-input" type="search" name="query" 
           placeholder="Search products..." aria-label="Search"
           value="<%= typeof query !== 'undefined' ? query : '' %>"
           autocomplete="off"
           aria-autocomplete="list"
           aria-controls="searchSuggestions">
    <button class="btn btn-search" type="submit" aria-label="Search">
      <i class="bi bi-search"></i>
    </button>
    <% if (typeof query !== 'undefined' && query) { %>
      <a href="/shop" class="btn btn-clear-search" title="Clear search" aria-label="Clear search">
        <i class="bi bi-x-lg"></i>
      </a>
    <% } %>
  </div>
  <!-- Search suggestions dropdown -->
  <div class="search-suggestions dropdown-menu" id="searchSuggestions" role="listbox"></div>
</form>

  <!-- Main Content -->
  <div class="container py-3">
    <!-- Mobile Filter Controls -->
    <div class="mobile-filter-controls">
      <button class="btn-filter-mobile" id="mobileFilterToggle">
        <i class="bi bi-funnel"></i> Filters
      </button>
      <div class="filter-results-count">
        <%= products.length %> products
      </div>
    </div>
    
    <!-- Overlay for mobile filters -->
    <div class="overlay" id="filterOverlay"></div>
    
    <div class="shop-container">
      <!-- Filter Sidebar -->
      <aside class="filter-sidebar" id="filterSidebar">
        <div class="filter-header">
          <h3 class="filter-title">Filters</h3>
          <button class="btn-close d-lg-none" id="closeFilters"></button>
        </div>
        
        <!-- Categories Filter -->
        <div class="filter-group">
          <div class="filter-group-title" data-bs-toggle="collapse" data-bs-target="#categoriesCollapse">
            <span>Categories</span>
            <i class="bi bi-chevron-down"></i>
          </div>
          <div class="filter-group-content collapse show" id="categoriesCollapse">
            <% if (category && category.length > 0) { %>
              <% category.forEach(cat => { %>
                <div class="filter-option">
                  <input type="checkbox" id="cat-<%= cat._id %>" class="filter-checkbox" data-filter="category" value="<%= cat._id %>" 
                    <%= selectedCategories && selectedCategories.includes(cat._id.toString()) ? 'checked' : '' %>>
                  <label for="cat-<%= cat._id %>"><%= cat.name %></label>
                </div>
              <% }) %>
            <% } else { %>
              <p class="text-muted">No categories available</p>
            <% } %>
          </div>
        </div>
        
        <!-- Brands Filter -->
        <div class="filter-group">
          <div class="filter-group-title" data-bs-toggle="collapse" data-bs-target="#brandsCollapse">
            <span>Brands</span>
            <i class="bi bi-chevron-down"></i>
          </div>
          <div class="filter-group-content collapse show" id="brandsCollapse">
            <% if (brand && brand.length > 0) { %>
              <% brand.forEach(b => { %>
                <div class="filter-option">
                  <input type="checkbox" id="brand-<%= b._id %>" class="filter-checkbox" data-filter="brand" value="<%= b._id %>"
                    <%= selectedBrands && selectedBrands.includes(b._id.toString()) ? 'checked' : '' %>>
                  <label for="brand-<%= b._id %>"><%= b.brandName %></label>
                </div>
              <% }) %>
            <% } else { %>
              <p class="text-muted">No brands available</p>
            <% } %>
          </div>
        </div>
        
        <!-- Sort Options -->
        <div class="filter-group">
          <div class="filter-group-title" data-bs-toggle="collapse" data-bs-target="#sortCollapse">
            <span>Sort By</span>
            <i class="bi bi-chevron-down"></i>
          </div>
          <div class="filter-group-content collapse show" id="sortCollapse">
            <div class="filter-option">
              <input type="radio" id="sort-low-high" name="sort" class="filter-radio" data-filter="sort" value="Low-to-High"
                <%= selectedSort === 'Low-to-High' ? 'checked' : '' %>>
              <label for="sort-low-high">Price: Low to High</label>
            </div>
            <div class="filter-option">
              <input type="radio" id="sort-high-low" name="sort" class="filter-radio" data-filter="sort" value="High-to-Low"
                <%= selectedSort === 'High-to-Low' ? 'checked' : '' %>>
              <label for="sort-high-low">Price: High to Low</label>
            </div>
            <div class="filter-option">
              <input type="radio" id="sort-a-z" name="sort" class="filter-radio" data-filter="sort" value="name-asc"
                <%= selectedSort === 'name-asc' ? 'checked' : '' %>>
              <label for="sort-a-z">Name: A-Z</label>
            </div>
            <div class="filter-option">
              <input type="radio" id="sort-z-a" name="sort" class="filter-radio" data-filter="sort" value="name-desc"
                <%= selectedSort === 'name-desc' ? 'checked' : '' %>>
              <label for="sort-z-a">Name: Z-A</label>
            </div>
          </div>
        </div>
        
        <button class="filter-apply" id="applyFilters">Apply Filters</button>
      </aside>
      
      <!-- Product Grid -->
      <div class="product-grid-container">
        <% if (products.length === 0) { %>
          <div class="empty-state">
            <img src="/images/no-products.svg" alt="No products found">
            <h4 class="mb-3">No products found</h4>
            <p class="text-muted mb-4">Try adjusting your filters or search term</p>
            <a href="/shop" class="btn btn-primary">Reset Filters</a>
          </div>
        <% } else { %>
          <div class="product-grid">
            <% products.forEach(product => { %>
              <div class="product-card">
                <a href="/productDetails?id=<%= product._id %>" class="text-decoration-none text-reset">
                  <img src="/Uploads/re-image/<%= product.productImage[0] || 'default.jpg' %>" alt="<%= product.productName %>" class="img-fluid" loading="lazy" />
                  <div class="product-details">
                    <h5 class="product-title"><%= product.productName %></h5>
                    <p class="product-brand">Brand: <%= product.brand && product.brand.brandName ? product.brand.brandName : product.brand %></p>
                    <div class="price-container">
                      <div class="d-flex align-items-center">
                        <span class="current-price">₹<%= product.salePrice.toLocaleString('en-IN') %></span>
                        <% if (product.salePrice < product.regularPrice) { %>
                          <span class="original-price">₹<%= product.regularPrice.toLocaleString('en-IN') %></span>
                        <% } %>
                      </div>
                    </div>
                  </div>
                </a>
                <div class="product-actions">
                  <button class="btn btn-quick-view" onclick="showQuickView('<%= product._id %>', '<%= product.productName %>', '<%= product.brand && product.brand.brandName ? product.brand.brandName : product.brand %>', '<%= product.salePrice %>', '<%= product.regularPrice %>', '/Uploads/re-image/<%= product.productImage[0] %>')" aria-label="Quick view for <%= product.productName %>">
                    <i class="bi bi-eye"></i> Quick View
                  </button>
                  <a href="#" class="wishlist-icon" onclick="toggleWishlist('<%= product._id %>', this)" title="Add to Wishlist" aria-label="Add <%= product.productName %> to wishlist" data-product-id="<%= product._id %>">
                    <i class="bi bi-heart"></i>
                  </a>
                </div>
              </div>
            <% }) %>

          </div>
          <% } %>
          
      <% if (totalPages > 1) { %>
  <nav aria-label="Product pagination" class="mt-5">
    <ul class="pagination justify-content-center">
      <% 
        // Build query string with active filters
        let queryString = '';
        if (selectedCategories && selectedCategories.length) {
          queryString += `&category=${selectedCategories.join(',')}`;
        }
        if (selectedBrands && selectedBrands.length) {
          queryString += `&brand=${selectedBrands.join(',')}`;
        }
        if (selectedSort) {
          queryString += `&sort=${selectedSort}`;
        }
        if (typeof query !== 'undefined' && query !== '') {
          queryString += `&query=${encodeURIComponent(query)}`;
        }
      %>

      <% if (currentPage > 1) { %>
        <li class="page-item">
          <a class="page-link" href="?page=<%= currentPage - 1 %><%= queryString %>" aria-label="Previous">
            <span aria-hidden="true">&laquo;</span>
          </a>
        </li>
      <% } %>

      <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %><%= queryString %>"><%= i %></a>
        </li>
      <% } %>

      <% if (currentPage < totalPages) { %>
        <li class="page-item">
          <a class="page-link" href="?page=<%= currentPage + 1 %><%= queryString %>" aria-label="Next">
            <span aria-hidden="true">&raquo;</span>
          </a>
        </li>
      <% } %>
    </ul>
  </nav>
<% } %>


  <!-- Quick View Modal -->
  <div class="modal fade" id="quickViewModal" tabindex="-1" aria-labelledby="quickViewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="quickViewModalLabel"></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="row">
            <div class="col-md-6">
              <img id="quickViewImage" src="" alt="Product Image" class="img-fluid" loading="lazy" />
            </div>
            <div class="col-md-6">
              <h5 id="quickViewName" class="product-title mb-3"></h5>
              <p id="quickViewBrand" class="product-brand mb-4"></p>
              <div class="d-flex align-items-center mb-4">
                <span id="quickViewSalePrice" class="current-price"></span>
                <span id="quickViewRegularPrice" class="original-price"></span>
              </div>
              <div class="d-flex gap-2">
                <button class="btn btn-primary" onclick="location.href=document.getElementById('quickViewDetailsLink').href">View Details</button>
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Continue Shopping</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  <script>
    // Mobile Filter Toggle
    document.addEventListener('DOMContentLoaded', function() {
      const filterSidebar = document.getElementById('filterSidebar');
      const filterOverlay = document.getElementById('filterOverlay');
      const mobileFilterToggle = document.getElementById('mobileFilterToggle');
      const closeFilters = document.getElementById('closeFilters');
      
      // Toggle mobile filters
      mobileFilterToggle.addEventListener('click', function() {
        filterSidebar.classList.add('active');
        filterOverlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
      
      // Close filters
      closeFilters.addEventListener('click', function() {
        filterSidebar.classList.remove('active');
        filterOverlay.classList.remove('active');
        document.body.style.overflow = '';
      });
      
      filterOverlay.addEventListener('click', function() {
        filterSidebar.classList.remove('active');
        filterOverlay.classList.remove('active');
        document.body.style.overflow = '';
      });
      
      // Filter functionality
      const applyFiltersBtn = document.getElementById('applyFilters');
      applyFiltersBtn.addEventListener('click', function() {
        const selectedCategories = [];
        const selectedBrands = [];
        let selectedSort = '';
        
        // Get selected categories
        document.querySelectorAll('input[data-filter="category"]:checked').forEach(checkbox => {
          selectedCategories.push(checkbox.value);
        });
        
        // Get selected brands
        document.querySelectorAll('input[data-filter="brand"]:checked').forEach(checkbox => {
          selectedBrands.push(checkbox.value);
        });
        
        // Get selected sort
        const selectedSortRadio = document.querySelector('input[data-filter="sort"]:checked');
        if (selectedSortRadio) {
          selectedSort = selectedSortRadio.value;
        }
        
        // Build URL based on what filters are selected
        let url = '/filter';
        const params = new URLSearchParams();
        
        if (selectedCategories.length > 0) {
          params.append('category', selectedCategories.join(','));
        }
        
        if (selectedBrands.length > 0) {
          params.append('brand', selectedBrands.join(','));
        }
        
        // If only sort is selected (without categories/brands)
        if (selectedSort && selectedCategories.length === 0 && selectedBrands.length === 0) {
          url = '/filterPrice?sort=' + selectedSort;
        } 
        // If sort is selected with categories/brands
        else if (selectedSort) {
          params.append('sort', selectedSort);
        }
        
        // Add page if needed
        if (<%= currentPage %> > 1) {
          params.append('page', <%= currentPage %>);
        }
        
        // Redirect with filters
        window.location.href = url + (params.toString() ? '?' + params.toString() : '');
      });
      
      // Initialize current filters from URL
      function initFiltersFromUrl() {
        const urlParams = new URLSearchParams(window.location.search);
        
        // Check categories
        if (urlParams.has('category')) {
          const categories = urlParams.get('category').split(',');
          categories.forEach(cat => {
            const checkbox = document.querySelector(`input[data-filter="category"][value="${cat}"]`);
            if (checkbox) checkbox.checked = true;
          });
        }
        
        // Check brands
        if (urlParams.has('brand')) {
          const brands = urlParams.get('brand').split(',');
          brands.forEach(brand => {
            const checkbox = document.querySelector(`input[data-filter="brand"][value="${brand}"]`);
            if (checkbox) checkbox.checked = true;
          });
        }
        
        // Check sort - works for both /filter and /filterPrice
        if (urlParams.has('sort')) {
          const sortValue = urlParams.get('sort');
          const radio = document.querySelector(`input[data-filter="sort"][value="${sortValue}"]`);
          if (radio) radio.checked = true;
        }
      }
      
      initFiltersFromUrl();
      
      // Initialize wishlist icons
      initWishlistIcons();
    });

    // Wishlist functionality
    async function initWishlistIcons() {
      try {
        const response = await fetch('/getWishlist', {
          method: 'GET',
          headers: { 'Content-Type': 'application/json' },
        });
        
        const data = await response.json();
        
        if (response.ok && data.status) {
          const wishlist = data.wishlist || [];
          document.querySelectorAll('.wishlist-icon').forEach(icon => {
            const productId = icon.getAttribute('data-product-id');
            if (wishlist.includes(productId)) {
              icon.classList.add('wishlist-active');
              icon.innerHTML = '<i class="bi bi-heart-fill"></i>';
            }
          });
        }
      } catch (error) {
        console.error('Error fetching wishlist:', error);
      }
    }

    async function toggleWishlist(productId, element) {
      event.preventDefault();
      
      try {
        const isInWishlist = element.classList.contains('wishlist-active');
        const endpoint = isInWishlist ? '/removeFromWishlist' : '/addToWishlist';
        
        const response = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId }),
        });
        
        const data = await response.json();
        
        if (response.ok && data.status) {
          if (isInWishlist) {
            element.classList.remove('wishlist-active');
            element.innerHTML = '<i class="bi bi-heart"></i>';
            showToast({
              message: 'Product removed from wishlist',
              type: 'success',
              icon: '✓',
            });
          } else {
            element.classList.add('wishlist-active');
            element.innerHTML = '<i class="bi bi-heart-fill"></i>';
            showToast({
              message: 'Product added to wishlist',
              type: 'success',
              icon: '✓',
            });
          }
        } else {
          showToast({
            message: data.message || 'Failed to update wishlist',
            type: 'error',
            icon: '✕',
          });
        }
      } catch (error) {
        showToast({
          message: 'Network error - please try again',
          type: 'error',
          icon: '⚠',
        });
      }
    }

    // Quick View functionality
    // Quick View functionality
function showQuickView(productId, productName, brandName, salePrice, regularPrice, imageUrl) {
  const modalLabel = document.getElementById('quickViewModalLabel');
  const quickViewName = document.getElementById('quickViewName');
  const quickViewBrand = document.getElementById('quickViewBrand');
  const quickViewSalePrice = document.getElementById('quickViewSalePrice');
  const quickViewRegularPrice = document.getElementById('quickViewRegularPrice');
  const quickViewImage = document.getElementById('quickViewImage');
  
  modalLabel.textContent = productName;
  quickViewName.textContent = productName;
  quickViewBrand.textContent = `Brand: ${brandName}`;
  quickViewSalePrice.textContent = `₹${parseFloat(salePrice).toLocaleString('en-IN')}`;
  
  if (parseFloat(salePrice) < parseFloat(regularPrice)) {
    quickViewRegularPrice.textContent = `₹${parseFloat(regularPrice).toLocaleString('en-IN')}`;
    quickViewRegularPrice.style.display = 'inline-block';
  } else {
    quickViewRegularPrice.style.display = 'none';
  }
  
  quickViewImage.src = imageUrl;
  quickViewImage.alt = productName;
  
  // Create a hidden link for the "View Details" button
  const detailsLink = document.createElement('a');
  detailsLink.id = 'quickViewDetailsLink';
  detailsLink.href = `/productDetails?id=${productId}`;
  detailsLink.style.display = 'none';
  document.body.appendChild(detailsLink);
  
  const quickViewModal = new bootstrap.Modal(document.getElementById('quickViewModal'));
  quickViewModal.show();
}
    // Toast notification utility
    function showToast({ message, type, icon }) {
      const colors = {
        success: { bg: 'linear-gradient(to right, #00b09b, #96c93d)', text: '#fff' },
        error: { bg: 'linear-gradient(to right, #ff5f6d, #ffc371)', text: '#fff' },
      };

      Toastify({
        text: `${icon} ${message}`,
        duration: 3000,
        close: true,
        gravity: 'top',
        position: 'right',
        stopOnFocus: true,
        style: {
          background: colors[type].bg,
          color: colors[type].text,
          borderRadius: '8px',
          boxShadow: '0 4px 12px rgba(0,0,0,0.15)',
          padding: '12px 20px',
          fontSize: '14px',
          fontWeight: '500',
          display: 'flex',
          alignItems: 'center',
          gap: '8px',
        },
        onClick: function() {}
      }).showToast();
    }

    // Search form handling
// Enhanced Search functionality
document.addEventListener('DOMContentLoaded', function() {
  const searchForm = document.getElementById('searchForm');
  const searchInput = searchForm?.querySelector('.search-input');
  const searchSuggestions = searchForm?.querySelector('.search-suggestions');
  
  if (searchForm && searchInput) {
    // Handle form submission
    searchForm.addEventListener('submit', function(e) {
      e.preventDefault();
      const searchQuery = searchInput.value.trim();
      if (searchQuery) {
        submitSearch(searchQuery);
      }
    });
    
    // Handle keyboard navigation
    searchInput.addEventListener('keydown', function(e) {
      const activeSuggestion = document.querySelector('.search-suggestions .active');
      
      // Arrow down
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        const next = activeSuggestion ? 
          activeSuggestion.nextElementSibling : 
          searchSuggestions.firstElementChild;
        if (next) {
          if (activeSuggestion) activeSuggestion.classList.remove('active');
          next.classList.add('active');
        }
      }
      
      // Arrow up
      if (e.key === 'ArrowUp') {
        e.preventDefault();
        const prev = activeSuggestion ? 
          activeSuggestion.previousElementSibling : 
          searchSuggestions.lastElementChild;
        if (prev) {
          if (activeSuggestion) activeSuggestion.classList.remove('active');
          prev.classList.add('active');
        }
      }
      
      // Enter
      if (e.key === 'Enter' && activeSuggestion) {
        e.preventDefault();
        searchInput.value = activeSuggestion.textContent;
        submitSearch(activeSuggestion.textContent);
      }
    });
    
    // Handle input for suggestions
    searchInput.addEventListener('input', debounce(function() {
      const query = this.value.trim();
      if (query.length > 1) {
        fetchSearchSuggestions(query);
      } else {
        hideSuggestions();
      }
    }, 300));
    
    // Close suggestions when clicking outside
    document.addEventListener('click', function(e) {
      if (!searchForm.contains(e.target)) {
        hideSuggestions();
      }
    });
  }
  
  // Submit search function
  function submitSearch(query) {
    const urlParams = new URLSearchParams(window.location.search);
    const currentCategory = urlParams.get('category');
    const currentBrand = urlParams.get('brand');
    const currentSort = urlParams.get('sort');
    const currentPage = urlParams.get('page');
    
    let searchUrl = '/search?query=' + encodeURIComponent(query);
    
    if (currentCategory) searchUrl += '&category=' + currentCategory;
    if (currentBrand) searchUrl += '&brand=' + currentBrand;
    if (currentSort) searchUrl += '&sort=' + currentSort;
    if (currentPage) searchUrl += '&page=' + currentPage;
    
    window.location.href = searchUrl;
  }
  
  // Fetch search suggestions
  async function fetchSearchSuggestions(query) {
    try {
      const response = await fetch(`/search/suggestions?query=${encodeURIComponent(query)}`);
      const suggestions = await response.json();
      
      if (suggestions.length > 0) {
        showSuggestions(suggestions);
      } else {
        hideSuggestions();
      }
    } catch (error) {
      console.error('Error fetching suggestions:', error);
      hideSuggestions();
    }
  }
  
  // Show suggestions dropdown
  function showSuggestions(suggestions) {
    if (!searchSuggestions) return;
    
    searchSuggestions.innerHTML = '';
    suggestions.forEach(item => {
      const suggestionItem = document.createElement('a');
      suggestionItem.className = 'dropdown-item';
      suggestionItem.href = '#';
      suggestionItem.textContent = item;
      suggestionItem.setAttribute('role', 'option');
      suggestionItem.addEventListener('click', (e) => {
        e.preventDefault();
        searchInput.value = item;
        submitSearch(item);
      });
      suggestionItem.addEventListener('mouseenter', () => {
        document.querySelectorAll('.search-suggestions .dropdown-item').forEach(el => {
          el.classList.remove('active');
        });
        suggestionItem.classList.add('active');
      });
      searchSuggestions.appendChild(suggestionItem);
    });
    
    searchSuggestions.classList.add('show');
  }
  
  // Hide suggestions dropdown
  function hideSuggestions() {
    if (searchSuggestions) {
      searchSuggestions.classList.remove('show');
    }
  }
  
  // Debounce function for input events
  function debounce(func, wait) {
    let timeout;
    return function() {
      const context = this, args = arguments;
      clearTimeout(timeout);
      timeout = setTimeout(() => {
        func.apply(context, args);
      }, wait);
    };
  }
});
  </script>

