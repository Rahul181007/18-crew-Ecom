</nav>

<div class="profile-container">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-lg-4">
      <div class="profile-sidebar">
        <div class="profile-header">
          <% if (user.image) { %>
            <img src="/userimage/<%= user.image %>" alt="Profile picture of <%= user.name %>" class="profile-avatar">
          <% } else { %>
            <img src="https://ui-avatars.com/api/?name=<%= user.name %>&background=C586A5&color=fff" alt="Profile picture of <%= user.name %>" class="profile-avatar">
          <% } %>
          <h3 class="profile-name"><%= user.name %></h3>
          <p class="profile-email"><%= user.email %></p>
          <button class="btn-edit mb-4" data-bs-toggle="modal" data-bs-target="#editProfileModal" aria-label="Edit Profile">
            <i class="bi bi-pencil me-2"></i>Edit Profile
          </button>
        </div>

        <ul class="nav nav-pills flex-column">
          <li class="nav-item">
            <a class="nav-link active" href="#profile" data-bs-toggle="tab" aria-selected="true">
              <i class="bi bi-person"></i> Profile
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#orders" data-bs-toggle="tab" aria-selected="false">
              <i class="bi bi-bag"></i> Orders
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#address" data-bs-toggle="tab" aria-selected="false">
              <i class="bi bi-house"></i> Addresses
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#wallet" data-bs-toggle="tab" aria-selected="false">
              <i class="bi bi-wallet"></i> Wallet
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#security" data-bs-toggle="tab" aria-selected="false">
              <i class="bi bi-shield-lock"></i> Security
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#referral" data-bs-toggle="tab" aria-selected="false">
              <i class="bi bi-gift"></i> Referral
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout" aria-label="Logout">
              <i class="bi bi-box-arrow-right"></i> Logout
            </a>
          </li>
        </ul>

        <div class="row mt-4">
          <div class="col-md-6">
            <div class="stats-card">
              <div class="stats-number"><%= order ? order.length : 0 %></div>
              <div class="stats-label">Total Orders</div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="stats-card">
              <div class="stats-number">₹<%= user.wallet ? user.wallet.toFixed(2) : '0.00' %></div>
              <div class="stats-label">Wallet Balance</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="col-lg-8">
      <div class="profile-content">
        <div class="tab-content">
          <!-- Profile Tab -->
          <div class="tab-pane fade show active" id="profile">
            <h4 class="section-title">Personal Information</h4>
            <div class="row">
              <div class="col-md-6">
                <div class="info-item">
                  <div class="info-label">Full Name</div>
                  <div class="info-value"><%= user.name %></div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="info-item">
                  <div class="info-label">Email Address</div>
                  <div class="info-value"><%= user.email %></div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="info-item">
                  <div class="info-label">Phone Number</div>
                  <div class="info-value"><%= user.mobile || 'Not provided' %></div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="info-item">
                  <div class="info-label">Account Created</div>
                  <div class="info-value"><%= new Date(user.createdOn).toLocaleDateString() %></div>
                </div>
              </div>
            </div>

            <h4 class="section-title mt-5">Security</h4>
            <div class="row">
              <div class="col-md-6">
                <div class="info-item">
                  <div class="info-label">Password</div>
                  <div class="info-value">••••••••</div>
                </div>
              </div>
              <div class="col-md-6 d-flex align-items-end">
                <% if (user.googleId === null) { %>
                  <a href="/change-password" class="btn-edit text-decoration-none" aria-label="Change Password">Change Password</a>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Orders Tab -->
          <div class="tab-pane fade" id="orders">
            <h4 class="section-title">Recent Orders</h4>
            <% if (order && order.length > 0) { %>
              <% order.forEach(ord => { %>
                <div class="order-card">
                  <div class="d-flex justify-content-between mb-2">
                    <div class="fw-bold">OrderID: <%= ord.orderId || 'N/A' %></div>
                    <div class="order-status status-<%= ord.status?.toLowerCase() || 'pending' %>">
                      <%= ord.status || 'Pending' %>
                    </div>
                  </div>
                  <div class="d-flex justify-content-between text-muted small mb-2">
                    <div><%= new Date(ord.createdOn).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></div>
                    <div><%= ord.orderedItems?.length || 0 %> item<%= (ord.orderedItems?.length || 0) !== 1 ? 's' : '' %></div>
                  </div>
                  <div class="d-flex justify-content-between align-items-center">
                    <div class="fw-bold"><%= ord.finalAmount ? '₹' + ord.finalAmount.toFixed(2) : '₹0.00' %></div>
                    <a href="/orders/<%= ord.orderId %>" class="btn btn-sm btn-outline-primary" aria-label="View details of order <%= ord.orderId %>">View Details</a>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <div class="text-center py-4">
                <p>You haven't placed any orders yet</p>
                <a href="/shop" class="btn-edit" aria-label="Start Shopping">Start Shopping</a>
              </div>
            <% } %>
          </div>

          <!-- Address Tab -->
          <div class="tab-pane fade" id="address">
            <div class="d-flex justify-content-between align-items-center mb-4">
              <h4 class="section-title mb-0">Saved Addresses</h4>
              <a href="/addAddress" class="btn-edit text-decoration-none" aria-label="Add New Address">Add New Address</a>
            </div>

            <div class="row">
              <% if (userAddress && userAddress.address && Array.isArray(userAddress.address) && userAddress.address.length > 0) { %>
                <% userAddress.address.forEach((address, index) => { %>
                  <div class="col-md-6">
                    <div class="card border-0 shadow-sm mb-3">
                      <div class="card-body">
                        <h5 class="card-title"><%= address.addressType %></h5>
                        <address class="card-text">
                          <%= address.name %><br>
                          <%= address.landMark ? address.landMark + ',' : '' %> <%= address.city %><br>
                          <%= address.state %>-<%= address.pincode %><br>
                          India
                        </address>
                        Phone: <%= address.mobile %><br>
                        <% if (address.altMobile) { %>
                          Alternate Phone: <%= address.altMobile %>
                        <% } %>
                        <div class="d-flex gap-2">
                          <a href="/editAddress?id=<%= userAddress._id %>&index=<%= index %>" class="btn btn-sm btn-outline-primary" aria-label="Edit address <%= address.addressType %>">Edit</a>
                          <a href="#" class="btn btn-sm btn-outline-danger" onclick="deleteAddressWithAlert('<%=address._id %>', '<%= index %>')" aria-label="Delete address <%= address.addressType %>">Remove</a>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }) %>
              <% } else { %>
                <div class="col-md-6">
                  <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body">
                      <h5 class="card-title">No Address</h5>
                      <address class="card-text">
                        No address available. Please add a new address.
                      </address>
                    </div>
                  </div>
                </div>
              <% } %>
            </div>
          </div>

          <!-- Wallet Tab -->
          <div class="tab-pane fade" id="wallet">
            <h4 class="section-title">Wallet Transactions</h4>
            <div class="stats-card mb-4">
              <div class="stats-number">₹<%= user.wallet ? user.wallet.toFixed(2) : '0.00' %></div>
              <div class="stats-label">Current Wallet Balance</div>
            </div>
            <% if (walletTransactions && walletTransactions.length > 0) { %>
              <div class="table-responsive">
                <table class="table">
                  <thead>
                    <tr>
                      <th>Date</th>
                      <th>Type</th>
                      <th>Amount</th>
                      <th>Source</th>
                      <th>Reference/OrderId</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% walletTransactions.forEach(transaction => { %>
                      <tr>
                        <td><%= new Date(transaction.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></td>
                        <td><%= transaction.type.charAt(0).toUpperCase() + transaction.type.slice(1) %></td>
                        <td>₹<%= transaction.amount.toFixed(2) %></td>
                        <td>
                          <span class="order-status status-<%= transaction.type ? transaction.type.toLowerCase() : 'unknown' %>">
                            <%= transaction.source ? (transaction.source.charAt(0).toUpperCase() + transaction.source.slice(1)) : 'Unknown' %>
                          </span>
                        </td>
                        <td>
                          <% if (transaction.reference) { %>
                            <% if (transaction.reference.startsWith('OrderID:')) { %>
                              <strong>Order ID:</strong> <%= transaction.reference.replace('OrderID:', '') %>
                            <% } else if (transaction.reference.startsWith('Referred by')) { %>
                              <strong><%= transaction.reference %></strong>
                            <% } else if (transaction.reference.startsWith('Referral signup by')) { %>
                              <strong><%= transaction.reference %></strong>
                            <% } else { %>
                              <%= transaction.reference %>
                            <% } %>
                          <% } else { %>
                            -
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <div class="text-center py-4">
                <p>No transactions yet.</p>
              </div>
            <% } %>
          </div>

          <!-- Security Tab -->
          <div class="tab-pane fade" id="security">
            <h4 class="section-title">Account Security</h4>
            <div class="alert alert-warning">
              <i class="bi bi-exclamation-triangle me-2"></i>
              For your security, never share your password with anyone.
            </div>

            <div class="row">
              <div class="col-md-6">
                <div class="info-item d-flex justify-content-between align-items-center">
                  <div>
                    <div class="info-label">Email Address</div>
                    <div class="info-value"><%= user.email %></div>
                  </div>
                  <a href="/change-email" class="btn btn-edit ms-3" aria-label="Change Email">Change Email</a>
                </div>
              </div>

              <div class="col-md-6">
                <div class="info-item d-flex justify-content-between align-items-center">
                  <div>
                    <div class="info-label">Password</div>
                    <div class="info-value">••••••••</div>
                  </div>
                  <% if (user.googleId === null) { %>
                    <a href="/change-password" class="btn btn-edit ms-3" aria-label="Change Password">Change Password</a>
                  <% } %>
