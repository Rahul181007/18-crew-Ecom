      <!-- Desktop View Icons -->
      <div class="d-none d-lg-flex align-items-center gap-3">
        <% if (locals?.user || user) { %>
        <div class="dropdown">
          <a
            class="nav-link dropdown-toggle text-uppercase fw-bold d-flex align-items-center"
