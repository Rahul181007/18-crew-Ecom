<%- include("../layouts/header.ejs") %>

<!-- External Stylesheets -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

<style>
  :root {
    --bg-color: #f8f9fa;
    --accent: #C586A5;
    --hover-accent: #b06b90;
    --text-dark: #333;
    --card-bg: #fff;
    --shadow: 0 4px 12px rgba(0, 0, 0, 0.08);
    --border-radius: 16px;
  }

  body {
    background-color: var(--bg-color);
    font-family: 'Poppins', sans-serif;
    color: var(--text-dark);
  }
  .navbar-brand {
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: 1px;
  }
  .brand-dot {
    width: 10px;
    height: 10px;
    background: #C586A5;
    border-radius: 50%;
    display: inline-block;
  }
  .navbar-nav {
    gap: 2rem;
  }
  .main {
    padding: 60px 0;
  }

  .dashboard-menu {
    background: var(--card-bg);
    border-radius: var(--border-radius);
    padding: 25px 20px;
    box-shadow: var(--shadow);
  }

  .dashboard-menu .nav-link {
    color: var(--text-dark);
    font-weight: 500;
    padding: 14px 18px;
    border-radius: 12px;
    margin-bottom: 8px;
    transition: all 0.3s ease;
  }

  .dashboard-menu .nav-link.active,
  .dashboard-menu .nav-link:hover {
    background-color: var(--accent);
    color: #fff;
  }

  .card {
    border-radius: var(--border-radius);
    background-color: var(--card-bg);
    box-shadow: var(--shadow);
    border: none;
    margin-bottom: 25px;
  }

  .card-header {
    background-color: var(--accent);
    color: #fff;
    font-weight: 600;
    text-align: center;
    border-radius: var(--border-radius) var(--border-radius) 0 0;
    padding: 14px;
    font-size: 1.05rem;
    letter-spacing: 0.5px;
  }

  .btn, .logout-btn {
    background-color: var(--accent);
    color: #fff;
    border: none;
    border-radius: 20px;
    padding: 10px 22px;
    font-weight: 500;
    transition: background-color 0.3s ease;
  }

  .btn:hover, .logout-btn:hover {
    background-color: var(--hover-accent);
  }

  .btn-link {
    color: var(--accent);
    font-weight: 500;
    text-decoration: none;
  }

  .btn-link:hover {
    text-decoration: underline;
    color: var(--hover-accent);
  }

  .table th {
    background-color: #d1cfd0;
    color: var(--text-dark);
    vertical-align: middle;
  }

  .table td {
    background-color: #fff;
    vertical-align: middle;
  }

  .top-header {
    background-color: #fff;
    padding: 18px 0;
    box-shadow: var(--shadow);
    border-radius: 0 0 var(--border-radius) var(--border-radius);
  }

  .header-box {
    background-color: #fff;
    border-radius: var(--border-radius);
    padding: 14px 22px;
    box-shadow: var(--shadow);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .account-page {
    padding: 50px 0;
  }

  .nav-item {
    margin-bottom: 8px;
  }

  .tab-content .card-body {
    padding: 25px;
  }

  .nav-link i {
    margin-right: 8px;
  }

  .btn-sm {
    padding: 6px 14px;
    font-size: 0.9rem;
  }

  .table th, .table td {
    padding: 14px 16px;
  }

  .table {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .dashboard-menu {
      margin-bottom: 20px;
    }
  }
</style>


<!-- Navbar -->
<nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top py-3">
  <div class="container d-flex align-items-center justify-content-between">
    <a href="#" class="navbar-brand d-flex align-items-center gap-2">18-CREW</a>

    <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse flex-grow-1 justify-content-center" id="navbarContent">
      <ul class="navbar-nav mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link active" href="/">HOME</a></li>
        <li class="nav-item"><a class="nav-link" href="/shop">COLLECTION</a></li>
        <li class="nav-item"><a class="nav-link" href="#">ABOUT</a></li>
        <li class="nav-item"><a class="nav-link" href="#">CONTACT</a></li>
      </ul>
    </div>

    <div class="d-flex align-items-center gap-3">
      <a href="#" class="text-dark" style="font-size: 1.5rem;"><i class="bi bi-search"></i></a>
      <a href="#" class="text-dark" style="font-size: 1.5rem;"><i class="bi bi-bag"></i></a>

      <% if (locals.user) { %>
        <div class="dropdown">
          <a class="nav-link dropdown-toggle text-uppercase fw-bold" href="#" role="button" data-bs-toggle="dropdown">
            <%= locals.user.name %>
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="/userProfile">Profile</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>
          </ul>
        </div>
      <% } else { %>
        <a href="/signin" class="text-dark" style="font-size: 1.5rem;"><i class="bi bi-person"></i></a>
      <% } %>
    </div>
  </div>
</nav>

<!-- Account Section -->
<section class="account-page">
  <div class="container">
    <div class="row gx-4">
      <!-- Sidebar -->
      <div class="col-lg-3">
        <div class="dashboard-menu">
          <ul class="nav flex-column">
            <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#dashboard">Dashboard</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#address">My Address</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#orders">Orders</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#track-orders">Wallet Status</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#wallet-history">Wallet History</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#referal">Referrals</a></li>
            <li class="nav-item"><a class="nav-link" href="/logout">Logout</a></li>
          </ul>
        </div>
      </div>

      <!-- Tab Content -->
      <div class="col-md-8">
        <div class="tab-content">

          <!-- Dashboard -->
          <div class="tab-pane fade show active" id="dashboard">
            <div class="card">
              <div class="card-header">User Profile</div>
              <div class="card-body text-center">
                <h6><strong><%= user.name %></strong> </h6>
                <p><strong>Email:</strong> <%= user.email %></p>
                <p><strong>Phone:</strong> <%= user.mobile %></p>
                
                <a href="/change-email" class="btn btn-success btn-sm me-2">Change Email</a>
                <a href="/change-password" class="btn btn-success btn-sm">Change Password</a>
              </div>
            </div>
          </div>

          <!-- Address -->
          <div class="tab-pane fade" id="address">
            <div class="row">
              <div class="col-lg-6">
                <div class="card">
                  <div class="card-header">Address 1</div>
                  <div class="card-body">
                    <address>123 Street, City, Country</address>
                    <div class="d-flex justify-content-between">
                      <a href="#" class="btn btn-link test-dark">Edit</a>
                      <a href="#" class="btn btn-link text-dark">Delete</a>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col-lg-6">
                <div class="card">
                  <div class="card-header">Address 2</div>
                  <div class="card-body">
                    <address>No address</address>
                  </div>
                </div>
              </div>
            </div>
            <div class="text-center mt-3">
              <button class="btn btn-primary">Add Address</button>
            </div>
          </div>

          <!-- Orders -->
          <div class="tab-pane fade" id="orders">
            <div class="card">
              <div class="card-header">Your Orders</div>
              <div class="card-body">
                <div class="table-responsive">
                  <table class="table">
                    <thead>
                      <tr>
                        <th>Order</th>
                        <th>Status</th>
                        <th>Total</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td>#</td>
                        <td>Pending</td>
                        <td>₹0.00</td>
                        <td><a href="#" class="btn btn-link">View</a></td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

          <!-- Wallet Status -->
          <div class="tab-pane fade" id="track-orders">
            <div class="card">
              <div class="card-header">Wallet</div>
              <div class="card-body text-center">
                <p class="h4">Amount: ₹0.00</p>
                <button class="btn btn-success mt-3">Add Money</button>
              </div>
            </div>
          </div>

          <!-- Wallet History -->
          <div class="tab-pane fade" id="wallet-history">
            <div class="card">
              <div class="card-header">Wallet History</div>
              <div class="card-body">
                <div class="table-responsive">
                  <table class="table">
                    <thead>
                      <tr>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Amount</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td>-</td>
                        <td>-</td>
                        <td>₹0.00</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

          <!-- Referrals -->
          <div class="tab-pane fade" id="referal">
            <div class="card">
              <div class="card-header">Referrals</div>
              <div class="card-body text-center">
                <p>Share this link to earn: <strong>[link]</strong></p>
                <p>Total Earned: ₹0.00</p>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.3/dist/umd/popper.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js"></script>


<%- include("../layouts/footer.ejs") %>

