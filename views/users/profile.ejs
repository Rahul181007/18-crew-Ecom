                </div>
              </div>
              <div class="col-md-4 mb-3">
                <div class="card h-100 border-0">
                  <div class="card-body text-center">
                    <div class="bg-primary-light rounded-circle p-3 mb-3 d-inline-block">
                      <i class="bi bi-person-plus fs-4 text-primary"></i>
                    </div>
                    <h6>They Register</h6>
                    <p class="small text-muted">Friends use your code during registration.</p>
                  </div>
                </div>
              </div>
              <div class="col-md-4 mb-3">
                <div class="card h-100 border-0">
                  <div class="card-body text-center">
                    <div class="bg-primary-light rounded-circle p-3 mb-3 d-inline-block">
                      <i class="bi bi-wallet fs-4 text-primary"></i>
                    </div>
