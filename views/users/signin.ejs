<%- include("../layouts/header.ejs") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-SgOJa3DmI69IUzQ2PVdRZhwQ+dy64/BUtbMJw1MZ8t5HZApcHrRKUc4W0kG879m7" crossorigin="anonymous">

<!-- Sign In Form -->
<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
  <div class="card p-4 shadow-sm border-0 rounded-4" style="width: 100%; max-width: 400px;">
    
    <h1 class="text-center mb-4">Sign In —</h1>

    <% if (locals.message && message.length > 0) { %>
      <div id="message" class="text-danger text-center small mb-2"><%= message %></div>
      <script>
        setTimeout(() => document.getElementById('message')?.remove(), 3000);
      </script>
    <% } %>

    <form action="/signin" method="post" id="signform">

      <div class="mb-3">
        <input type="email" class="form-control rounded-3" id="email" name="email" placeholder="Email" required>
        <div id="error2" class="text-danger small"></div>
      </div>

      <div class="mb-2">
        <input type="password" class="form-control rounded-3" id="password" name="password" placeholder="Password" required>
        <div id="error3" class="text-danger small"></div>
      </div>

      <div class="text-end mb-3">
        <a href="/forgot-Password" class="text-decoration-none small text-muted">Forgot Password?</a>
      </div>

      <div class="d-grid mb-3">
        <button type="submit" class="btn btn-dark rounded-3">Sign In</button>
      </div>

      <div class="text-center text-muted my-2">— OR —</div>

      <div class="d-grid mb-3">
        <a href="/auth/google" class="btn btn-outline-dark rounded-3 d-flex align-items-center justify-content-center gap-2">
          <img src="/images/googlesignup.png" alt="Google Logo" width="24" height="24">
          <span>Sign in with Google</span>
        </a>
      </div>

      <div class="text-center small mt-3">
        Don't have an account? <a href="/register" class="fw-semibold text-dark">Sign Up</a>
      </div>

    </form>
  </div>
</div>

<script>
      const emailId = document.getElementById("email");
      const passwordId = document.getElementById("password");
      const signform = document.getElementById("signform");
      const error2 = document.getElementById("error2");
      const error3 = document.getElementById("error3");

      function emailValidateChecking() {
    const emailVal = emailId.value.trim();
    const emailPattern = /^[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$/;
  
    if (!emailPattern.test(emailVal)) {
      error2.style.display = "block";
      error2.innerHTML = "Please enter a valid email address";
    } else {
      error2.style.display = "none";
      error2.innerHTML = "";
    }
  }
  
  function passwordValidateChecking() {
    const passval = passwordId.value;
    const alpha = /[a-zA-Z]/;
    const digit = /\d/;
  
    if (passval.length < 8) {
      error3.style.display = "block";
      error3.innerHTML = "Password must be at least 8 characters long";
    } else if (!alpha.test(passval) || !digit.test(passval)) {
      error3.style.display = "block";
      error3.innerHTML = "Password should contain both alphabets and numbers";
    } else {
      error3.style.display = "none";
      error3.innerHTML = "";
    }
  }
</script>





<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js" integrity="sha384-k6d4wzSIapyDyv1kpU366/PK5hCdSbCRGRCMv+eplOQJWyd1fbcAu9OCUj5zNLiq" crossorigin="anonymous"></script>

