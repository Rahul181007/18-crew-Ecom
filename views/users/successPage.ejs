<%- include("../layouts/header.ejs") %>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
<style>
  body {
    font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
    background-color: #f8f9fa;
    color: #212529;
  }
  .order-confirmation {
    max-width: 800px;
    margin: 0 auto;
  }
  .order-header {
    border-bottom: 1px solid #e9ecef;
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
  }
  .order-details {
    border: 1px solid #e0e0e0;
    border-radius: 0.5rem;
    background-color: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  }
  .detail-item {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid #f0f0f0;
  }
  .detail-item:last-child {
    border-bottom: none;
  }
  .detail-label {
    font-weight: 500;
    color: #495057;
  }
  .detail-value {
    color: #212529;
  }
  .items-list {
    border-top: 1px solid #e9ecef;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
  }
  .btn-success {
    background-color: #28a745;
    border-color: #28a745;
    padding: 0.5rem 1.5rem;
  }
  .btn-primary {
    padding: 0.5rem 1.5rem;
  }
</style>

<body>
  <div class="container py-5">
    <div class="order-confirmation">
      <div class="order-header text-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="#28a745" class="bi bi-check-circle-fill mb-3" viewBox="0 0 16 16">
          <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
        </svg>
        <h1 class="h2 fw-bold text-success mb-2">Order Confirmed</h1>
        <p class="text-muted mb-0">Thank you for your purchase. Your order has been received and is being processed.</p>
      </div>

      <div class="order-details p-4 mb-5">
        <h2 class="h5 fw-semibold mb-4 text-uppercase text-secondary">Order Information</h2>
        
        <div class="detail-item">
          <span class="detail-label">Order Number</span>
          <span class="detail-value"><%= order.orderId %></span>
        </div>
        
        <div class="detail-item">
          <span class="detail-label">Order Date</span>
          <span class="detail-value"><%= new Date(order.createdOn).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
        </div>
        
        <div class="detail-item">
          <span class="detail-label">Total Amount</span>
          <span class="detail-value">₹<%= order.totalPrice %></span>
        </div>
        
        <% if (order.discount > 0) { %>
        <div class="detail-item">
          <span class="detail-label">Discount</span>
          <span class="detail-value text-danger">-₹<%= order.discount %></span>
        </div>
        <% } %>
        
        <div class="detail-item">
          <span class="detail-label">Final Amount</span>
          <span class="detail-value fw-bold">₹<%= order.finalAmount %></span>
        </div>
        
        <div class="detail-item">
          <span class="detail-label">Payment Method</span>
          <span class="detail-value"><%= order.paymentMethod %></span>
        </div>
        
        <div class="detail-item">
          <span class="detail-label">Payment Status</span>
          <span class="detail-value"><%= order.isPaid ? 'Paid' : 'Pending' %></span>
        </div>
        
        <div class="detail-item">
          <span class="detail-label">Order Status</span>
          <span class="detail-value"><%= order.status %></span>
        </div>
        
        <% if (order.trackingNumber) { %>
        <div class="detail-item">
          <span class="detail-label">Tracking Number</span>
          <span class="detail-value"><%= order.trackingNumber %></span>
        </div>
        <% } %>

        <div class="items-list">
          <h3 class="h5 fw-semibold mb-3 text-uppercase text-secondary">Order Items</h3>
          <div class="list-group">
            <% order.orderedItems.forEach(item => { %>
            <div class="list-group-item border-0 px-0 py-2">
              <div class="d-flex justify-content-between">
                <span><%= item.product.productName %></span>
                <span>₹<%= item.price.toFixed(2) %> × <%= item.quantity %></span>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>

      <div class="text-center">
        <div class="d-grid gap-3 d-md-block mb-4">
          <% if (order.trackingUrl) { %>
            <a href="<%= order.trackingUrl %>" target="_blank" class="btn btn-success me-md-3">Track Your Order</a>
          <% } else { %>
            <a href="/trackOrder?id=<%= order._id %>" class="btn btn-success me-md-3">Track Your Order</a>
          <% } %>
          <a href="/shop" class="btn btn-outline-primary">Continue Shopping</a>
        </div>
        <p class="text-muted small">A confirmation email has been sent to your registered email address. You'll receive another email with tracking information once your order ships.</p>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

<%- include("../layouts/footer.ejs") %>