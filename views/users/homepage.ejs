<% include("../layouts/header.ejs") %>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">


<style>
  body {
    font-family: 'Poppins', sans-serif;
  }
  .navbar-brand {
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: 1px;
  }
  .brand-dot {
    width: 10px;
    height: 10px;
    background: #C586A5;
    border-radius: 50%;
    display: inline-block;
  }
  .navbar-nav {
    gap: 2rem;
  }
  .category-card {
    transition: all 0.3s ease;
  }
  .category-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 16px rgba(0,0,0,0.1);
  }
/* Card Styling */
.card {
  border: none;
  border-radius: 12px;
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.card:hover {
  transform: translateY(-5px);
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
}

.card-img-top {
  width: 100%;
  height: 280px;
  object-fit: contain;
  object-position: center;
  transition: transform 0.4s ease;
  display: block;
}


.card:hover .card-img-top {
  transform: scale(1.05);
}

/* Quick View Overlay */
.card-overlay {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  width: 100%;
  background: rgba(0, 0, 0, 0.45);
  opacity: 0;
  transition: all 0.3s ease;
}

.card:hover .card-overlay {
  opacity: 1;
}

.card-overlay a {
  opacity: 0;
  transition: opacity 0.3s ease;
}

.card:hover .card-overlay a {
  opacity: 1;
}

/* Wishlist Button */
.wishlist-btn {
  position: absolute;
  top: 12px;
  right: 12px;
  background: transparent;
  border: none;
  cursor: pointer;
  z-index: 2;
  padding: 0;
}

.wishlist-btn i {
  color: #ebeaea;
  font-size: 22px;
  transition: transform 0.3s ease, color 0.3s ease;
}

.wishlist-btn:hover i {
  color: #e60039;
  transform: scale(1.2);
}
.category-card {
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.category-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 20px rgba(0,0,0,0.15);
}


.category-img {
  object-fit: contain;
  object-position: center;
  width: 100%;
  height: 280px; 
  border-top-left-radius: 0.375rem; 
  border-top-right-radius: 0.375rem;
  transition: transform 0.4s ease;
  display: block;
}


.card-title {
  font-size: 1.2rem;
  color: #212529;
}
.banner-section {
  background: url('/images/hero_img.png') no-repeat center center;
  background-size: cover;
  position: relative;
  min-height: 70vh; /* Creates a large, impactful banner */
  z-index: 1;
  overflow: hidden;
}

.banner-section::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5); /* Semi-transparent overlay */
  z-index: -1;
}

.banner-section h1,
.banner-section h5,
.banner-section a {
  z-index: 2;
}

@media (max-width: 768px) {
  .banner-section h1 {
    font-size: 2.5rem;
  }
  .banner-section h5 {
    font-size: 1rem;
  }
}


</style>

<nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top py-3">
  <div class="container d-flex align-items-center justify-content-between">
    <a href="#" class="navbar-brand d-flex align-items-center gap-2">18-CREW <span class="brand-dot"></span></a>
    <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse flex-grow-1 justify-content-center" id="navbarContent">
      <ul class="navbar-nav mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link active" href="/">HOME</a></li>
        <li class="nav-item"><a class="nav-link" href="/shop">COLLECTION</a></li>
        <li class="nav-item"><a class="nav-link" href="#">ABOUT</a></li>
        <li class="nav-item"><a class="nav-link" href="#">CONTACT</a></li>
      </ul>
    </div>
    <div class="d-flex align-items-center gap-3">
      <a href="#" class="text-dark" style="font-size: 1.5rem;"><i class="bi bi-search"></i></a>
      <a href="#" class="text-dark" style="font-size: 1.5rem;"><i class="bi bi-bag"></i></a>
      <% if (locals?.user|| user ) { %>
        <div class="dropdown">
          <a class="nav-link dropdown-toggle text-uppercase fw-bold" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <%= locals.user.name %>
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="/userProfile">Profile</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>
          </ul>
        </div>
      <% } else { %>
        <a href="/signin" class="text-dark" style="font-size: 1.5rem;">
          <i class="bi bi-person"></i>
        </a>
      <% } %>
      
      <!-- <a href="/register" class="btn btn-dark btn-sm px-3">Sign Up</a> -->
    </div>
  </div>
</nav>

<!-- HERO SECTION -->
<section class="banner-section d-flex align-items-center text-white text-center">
  <div class="container py-5">
    <h5 class="text-uppercase text-light mb-2">Our Bestseller</h5>
    <h1 class="display-3 fw-bold mb-4">Latest Arrivals</h1>
    <a href="/shop" class="btn btn-outline-light btn-lg px-4">Shop Now</a>
  </div>
</section>


<!-- CATEGORY SECTION -->
<section class="py-5 bg-light">
  <div class="container">
    <h2 class="text-center mb-5 fw-bold text-dark">Shop by Category</h2>
    <div class="row g-4 justify-content-center">
      <% for (let i = 0; i < category.length; i++) { %>
        <div class="col-6 col-sm-6 col-md-4 col-lg-3">
          <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden category-card">
            <div class="ratio ratio-1x1 bg-light">
              <img 
                src="/uploads/re-image/<%=category[i].image%>" 
                class="img-fluid object-fit-cover" 
                alt="<%= category[i].name %>" 
                style="width: 100%; height: 100%; object-fit: cover;">
            </div>
            <div class="card-body d-flex flex-column justify-content-center align-items-center">
              <a href="/filter?category=<%= category[i]._id %>" class="stretched-link text-decoration-none text-dark fw-semibold fs-5 text-center">
                <%= category[i].name %>
              </a>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>





<!-- LATEST COLLECTIONS -->
<section class="py-5">
  <div class="container">
    <h2 class="text-center mb-3">Latest Collections</h2>
    <p class="text-center text-muted mb-5">Discover new trends and styles curated just for you.</p>
    <div class="row g-4">
      <% for(let i=0; i<products.length; i++) { %>
        <div class="col-6 col-md-4 col-lg-3">
          <div class="card h-100 text-center position-relative overflow-hidden">
            
            <!-- Wishlist Button -->
            <button class="wishlist-btn" ><a href="/addToWishlist?id=<%=products[i]._id  %>">
              <i class="fa-regular fa-heart"></i></a>
            </button>
            
            
              <img src="/uploads/re-image/<%= products[i].productImage[0] %>" class="card-img-top" alt="<%= products[i].productName %>">
          
        
            <!-- Quick View Overlay -->
            <div class="card-overlay d-flex justify-content-center align-items-center">
              <a href="/productDetails?id=<%= products[i]._id %>" class="btn btn-dark btn-sm">Quick View</a>
            </div>
        
            <div class="card-body">
              <h5 class="card-title fs-6"><%= products[i].productName %></h5>
              <p class="text-muted">₹ <%= products[i].salePrice %></p>
            </div>
        
          </div>
        </div>
        
      <% } %>
    </div>
  </div>
</section>


<!-- INFO ICONS -->
<section class="py-5 bg-light">
  <div class="container">
    <div class="row text-center g-4">
      <div class="col-12 col-md-4">
        <i class="bi bi-truck fs-2"></i>
        <p class="mt-2">Free Nationwide Shipping</p>
      </div>
      <div class="col-12 col-md-4">
        <i class="bi bi-arrow-counterclockwise fs-2"></i>
        <p class="mt-2">7 Days Return Policy</p>
      </div>
      <div class="col-12 col-md-4">
        <i class="bi bi-headset fs-2"></i>
        <p class="mt-2">Best Customer Support</p>
      </div>
    </div>
  </div>
</section>

<!-- SUBSCRIBE -->
<section class="py-5">
  <div class="container text-center">
    <h3>Subscribe Now & Get 20% Off</h3>
    <form action="/subscribe" method="POST" class="row justify-content-center mt-4 g-2">
      <div class="col-12 col-md-4">
        <input type="email" class="form-control" name="email" placeholder="Enter your email" required>
      </div>
      <div class="col-12 col-md-2">
        <button type="submit" class="btn btn-dark w-100">Subscribe</button>
      </div>
    </form>
  </div>
</section>

