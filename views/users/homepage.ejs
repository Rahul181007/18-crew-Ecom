<%-include("../layouts/header.ejs") %>
<link
  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css"
  rel="stylesheet"
/>
<link
  href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
  rel="stylesheet"
/>
<link
  href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
  rel="stylesheet"
/>
<link
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  rel="stylesheet"
/>
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css"
/>

<style>
  :root {
    --primary-color: #c586a5;
    --secondary-color: #1a1517;
    --accent-color: #e60039;
    --light-bg: #f8f9fa;
    --dark-text: #212529;
    --muted-text: #6c757d;
    --transition-speed: 0.3s;
  }

  body {
    font-family: "Poppins", sans-serif;
    overflow-x: hidden;
  }

  /* Navigation */
  .navbar {
    box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
    transition: all var(--transition-speed) ease;
  }

  .navbar.scrolled {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .navbar-brand {
    font-weight: 700;
    font-size: 1.6rem;
    color: var(--secondary-color);
    letter-spacing: 0.5px;
    position: relative;
  }

  .brand-dot {
    width: 10px;
    height: 10px;
    background: var(--primary-color);
    border-radius: 50%;
    display: inline-block;
    margin-left: 4px;
  }

  .navbar-nav {
    gap: 1.5rem;
  }

  .navbar-nav .nav-link {
    font-weight: 500;
    color: var(--dark-text);
    transition: color var(--transition-speed);
    position: relative;
    padding: 0.5rem 0;
  }

  .navbar-nav .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--primary-color);
    transition: width var(--transition-speed);
  }

  .navbar-nav .nav-link:hover::after,
  .navbar-nav .nav-link.active::after {
    width: 100%;
  }

  .navbar-nav .nav-link:hover,
  .navbar-nav .nav-link.active {
    color: var(--primary-color);
  }

  /* Badge */
  .badge-dot {
    position: absolute;
    top: -5px;
    right: -5px;
    width: 10px;
    height: 10px;
    background-color: var(--accent-color);
    border-radius: 50%;
    border: 1px solid white;
  }

  /* Hero Section */
.hero-section {
  background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6));
  background-size: cover;
  min-height: 80vh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  /* Add these properties to prevent repeating */
  background-repeat: no-repeat;
  background-position: center center;
  
}

@media (max-width: 768px) {
    .hero-section {
    min-height: 60vh;
    background-attachment: scroll; /* Better for mobile performance */
  }
}

.hero-content {
  position: relative;
  z-index: 2;
  animation: fadeInUp 1s ease;
  /* Add padding for better mobile spacing */
  padding: 2rem 1rem;
}

.hero-title {
  font-size: 3.5rem;
  font-weight: 700;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  /* Add responsive font sizes */
  line-height: 1.2;
}

.hero-subtitle {
  font-weight: 400;
  letter-spacing: 1px;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
  margin-bottom: 1.5rem;
}

/* Responsive font sizes */
@media (max-width: 992px) {
  .hero-title {
    font-size: 2.8rem;
  }
}

@media (max-width: 768px) {
  .hero-title {
    font-size: 2.2rem;
  }
  .hero-subtitle {
    font-size: 1rem;
  }
}

@media (max-width: 576px) {
  .hero-title {
    font-size: 1.8rem;
  }
}
  /* Category Section */
  .section-title {
    position: relative;
    display: inline-block;
    margin-bottom: 2.5rem;
  }

  .section-title::after {
    content: "";
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 3px;
    background: var(--primary-color);
  }

  .category-card {
    transition: all var(--transition-speed) ease;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
  }

  .category-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
  }

  .category-img-container {
    height: 280px;
    overflow: hidden;
  }

  .category-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .category-card:hover .category-img {
    transform: scale(1.05);
  }

  .category-body {
    background: white;
    padding: 1.5rem;
    text-align: center;
  }

  .category-link {
    font-weight: 600;
    color: var(--dark-text);
    transition: color var(--transition-speed);
  }

  .category-link:hover {
    color: var(--primary-color);
    text-decoration: none;
  }

  /* Product Cards */
  .product-card {
    border: none;
    border-radius: 12px;
    overflow: hidden;
    transition: all var(--transition-speed) ease;
    position: relative;
  }

  .product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
  }

  .product-img-container {
    height: 280px;
    overflow: hidden;
    background: #f8f9fa;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.5s ease;
  }

  .product-card:hover .product-img {
    transform: scale(1.05);
  }

  .product-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    opacity: 0;
    transition: opacity var(--transition-speed);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-card:hover .product-overlay {
    opacity: 1;
  }

  .quick-view-btn {
    opacity: 0;
    transform: translateY(20px);
    transition: all var(--transition-speed) ease;
  }

  .product-card:hover .quick-view-btn {
    opacity: 1;
    transform: translateY(0);
  }

  .wishlist-btn {
    position: absolute;
    top: 15px;
    right: 15px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
    z-index: 10;
    transition: all var(--transition-speed);
    opacity: 0;
  }

  .product-card:hover .wishlist-btn {
    opacity: 1;
  }

  .wishlist-btn:hover {
    background: white;
  }

  .wishlist-btn i {
    color: var(--muted-text);
    transition: color var(--transition-speed);
  }

  .wishlist-btn:hover i {
    color: var(--accent-color);
  }

  .product-info {
    padding: 1.5rem;
    text-align: center;
  }

  .product-title {
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--dark-text);
  }

  .product-price {
    font-weight: 700;
    color: var(--primary-color);
  }

  /* Features Section */
  .features-section {
    background: var(--light-bg);
  }

  .feature-icon {
    width: 60px;
    height: 60px;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
    transition: all var(--transition-speed);
  }

  .feature-icon i {
    font-size: 1.5rem;
    color: var(--primary-color);
  }

  .feature-item:hover .feature-icon {
    transform: translateY(-5px);
    background: var(--primary-color);
  }

  .feature-item:hover .feature-icon i {
    color: white;
  }

  .feature-title {
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  /* Newsletter */
  .newsletter-section {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  }

  .newsletter-title {
    font-weight: 700;
    position: relative;
    display: inline-block;
  }

  .newsletter-title::after {
    content: "";
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 3px;
    background: var(--primary-color);
  }

  .newsletter-input {
    border: 2px solid #dee2e6;
    border-radius: 50px;
    padding: 0.75rem 1.5rem;
    transition: all var(--transition-speed);
  }

  .newsletter-input:focus {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 0.25rem rgba(197, 134, 165, 0.25);
  }

  .newsletter-btn {
    border-radius: 50px;
    padding: 0.75rem 2rem;
    background: var(--secondary-color);
    border: none;
    transition: all var(--transition-speed);
  }

  .newsletter-btn:hover {
    background: var(--primary-color);
    transform: translateY(-2px);
  }

  /* Footer */
  .footer {
    background: var(--secondary-color);
    color: white;
  }

  .footer-logo {
    font-weight: 700;
    font-size: 1.8rem;
    margin-bottom: 1rem;
    display: inline-block;
  }

  .footer-logo-dot {
    color: var(--primary-color);
  }

  .footer-about {
    color: rgba(255, 255, 255, 0.7);
  }

  .footer-title {
    font-weight: 600;
    margin-bottom: 1.5rem;
    position: relative;
    display: inline-block;
  }

  .footer-title::after {
    content: "";
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 40px;
    height: 2px;
    background: var(--primary-color);
  }

  .footer-links li {
    margin-bottom: 0.75rem;
  }

  .footer-link {
    color: rgba(255, 255, 255, 0.7);
    transition: all var(--transition-speed);
    text-decoration: none;
  }

  .footer-link:hover {
    color: white;
    padding-left: 5px;
  }

  .footer-contact-item {
    margin-bottom: 1rem;
    display: flex;
    align-items: flex-start;
  }

  .footer-contact-icon {
    margin-right: 1rem;
    color: var(--primary-color);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 1.5rem;
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  
</style>

<!-- Navigation -->
<nav class="navbar navbar-expand-lg navbar-light bg-white py-3 sticky-top">
  <div class="container">
    <a href="/" class="navbar-brand d-flex align-items-center">
      18-CREW<span class="brand-dot"></span>
    </a>

    <!-- Cart & Wishlist Icons - Always Visible on Mobile -->
    <div class="d-flex d-lg-none align-items-center gap-3 ms-auto me-3">
      <a
        href="/wishlist"
        class="text-dark position-relative fs-5"
        title="Wishlist"
        aria-label="Wishlist<%= wishlistCount > 0 ? ` with ${wishlistCount} items` : '' %>"
      >
        <i class="bi bi-heart"></i>
        <% if (wishlistCount > 0) { %>
        <span class="badge-dot"></span>
        <% } %>
      </a>
      <a
        href="/getCartPage"
        class="text-dark position-relative fs-5"
        title="Cart"
        aria-label="Cart<%= cartCount > 0 ? ` with ${cartCount} items` : '' %>"
      >
        <i class="bi bi-bag"></i>
        <% if (cartCount > 0) { %>
        <span class="badge-dot"></span>
        <% } %>
      </a>
    </div>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarContent"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarContent">
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a
            class="nav-link <%= typeof page !== 'undefined' && page === 'home' ? 'active' : '' %>"
            href="/"
            >HOME</a
          >
        </li>
        <li class="nav-item">
          <a
            class="nav-link <%= typeof page !== 'undefined' && page === 'shop' ? 'active' : '' %>"
            href="/shop"
            >COLLECTION</a
          >
        </li>
        <li class="nav-item">
          <a
            class="nav-link <%= typeof page !== 'undefined' && page === 'about' ? 'active' : '' %>"
            href="/about"
            >ABOUT</a
          >
        </li>
        <li class="nav-item">
          <a
            class="nav-link <%= typeof page !== 'undefined' && page === 'contact' ? 'active' : '' %>"
            href="/contact"
            >CONTACT</a
          >
        </li>

        <!-- User Dropdown for Mobile -->
        <% if (locals?.user || user) { %>
        <li class="nav-item dropdown d-lg-none">
          <a
            class="nav-link dropdown-toggle text-uppercase fw-bold"
            href="#"
            role="button"
            data-bs-toggle="dropdown"
            aria-expanded="false"
          >
            <i class="bi bi-person-circle me-2"></i><%= user.name %>
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/userProfile">Profile</a></li>
            <li><hr class="dropdown-divider" /></li>
            <li>
              <a class="dropdown-item text-danger" href="/logout">Logout</a>
            </li>
          </ul>
        </li>
        <% } else { %>
        <li class="nav-item d-lg-none">
          <a class="nav-link" href="/signin"
            ><i class="bi bi-person me-2"></i>Sign In</a
          >
        </li>
        <% } %>
      </ul>

      <!-- Desktop View Icons -->
      <div class="d-none d-lg-flex align-items-center gap-3">
        <% if (locals?.user || user) { %>
        <div class="dropdown">
          <a
            class="nav-link dropdown-toggle text-uppercase fw-bold d-flex align-items-center"
            href="#"
            role="button"
            data-bs-toggle="dropdown"
            aria-expanded="false"
          >
            <i class="bi bi-person-circle me-2"></i>
            <%= user.name %>
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="/userProfile">Profile</a></li>
            <li><hr class="dropdown-divider" /></li>
            <li>
              <a class="dropdown-item text-danger" href="/logout">Logout</a>
            </li>
          </ul>
        </div>
        <% } else { %>
        <a
          href="/signin"
          class="text-dark fs-5"
          title="Account"
          aria-label="Account"
        >
          <i class="bi bi-person"></i>
        </a>
        <% } %>
        <a
          href="/wishlist"
          class="text-dark position-relative fs-5"
          title="Wishlist"
          aria-label="Wishlist<%= wishlistCount > 0 ? ` with ${wishlistCount} items` : '' %>"
        >
          <i class="bi bi-heart"></i>
          <% if (wishlistCount > 0) { %>
          <span class="badge-dot"></span>
          <% } %>
        </a>
        <a
          href="/getCartPage"
          class="text-dark position-relative fs-5"
          title="Cart"
          aria-label="Cart<%= cartCount > 0 ? ` with ${cartCount} items` : '' %>"
        >
          <i class="bi bi-bag"></i>
          <% if (cartCount > 0) { %>
          <span class="badge-dot"></span>
          <% } %>
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- Hero Section -->
<!-- Hero Section -->
<section
  class="hero-section"
  style="background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('/uploads/banner/<%= banner ? banner.image : 'default.png' %>');"
>
  <div class="container">
    <div class="hero-content text-center text-white">
      <% if (banner) { %>
      <h5 class="hero-subtitle text-uppercase mb-3"><%= banner.title %></h5>
      <h1 class="hero-title mb-4"><%= banner.description %></h1>
      <a href="/shop" class="btn btn-outline-light btn-lg px-4 py-2">Shop Now</a>
      <% } else { %>
      <h5 class="hero-subtitle text-uppercase mb-3">Our Bestseller</h5>
      <h1 class="hero-title mb-4">Latest Arrivals</h1>
      <a href="/shop" class="btn btn-outline-light btn-lg px-4 py-2">Shop Now</a>
      <% } %>
    </div>
  </div>
</section>

<!-- Category Section -->
<section class="py-5 bg-light">
  <div class="container">
    <h2 class="text-center section-title">Shop by Category</h2>
    <div class="row g-4 justify-content-center">
      <% for (let i = 0; i < category.length; i++) { %>
      <div class="col-6 col-sm-6 col-md-4 col-lg-3">
        <div class="category-card">
          <div class="category-img-container">
            <img
              src="/uploads/re-image/<%=category[i].image%>"
              class="category-img"
              alt="<%= category[i].name %>"
            />
          </div>
          <div class="category-body">
            <a
              href="/filter?category=<%= category[i]._id %>"
              class="category-link"
            >
              <%= category[i].name %>
            </a>
          </div>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</section>

<!-- Products Section -->
<section class="py-5">
  <div class="container">
    <h2 class="text-center section-title">Latest Collections</h2>
    <p class="text-center text-muted mb-5">
      Discover new trends and styles curated just for you.
    </p>
    <% if (products && products.length > 0) { %>
    <div class="row g-4">
      <% for(let i = 0; i < Math.min(products.length, 4); i++) { %>
      <div class="col-6 col-md-4 col-lg-3">
        <div class="product-card">
          <button
            class="wishlist-btn"
            onclick="addToWishlist('<%= products[i]._id %>')"
          >
            <i class="bi bi-heart"></i>
          </button>
          <div class="product-img-container">
            <img
              src="/uploads/re-image/<%= products[i].productImage[0] || 'default.jpg' %>"
              class="product-img"
              alt="<%= products[i].productName %>"
            />
            <div class="product-overlay">
              <a
                href="/productDetails?id=<%= products[i]._id %>"
                class="quick-view-btn btn btn-light btn-sm"
                >Quick View</a
              >
            </div>
          </div>
          <div class="product-info">
            <h5 class="product-title"><%= products[i].productName %></h5>
            <p class="product-price">₹ <%= products[i].salePrice %></p>
          </div>
        </div>
      </div>
      <% } %>
    </div>
    <div class="text-center mt-5">
      <a href="/shop" class="btn btn-dark px-4 py-2">View All Products</a>
    </div>
    <% } else { %>
    <div class="row">
      <div class="col-12 text-center">
        <p class="text-muted">No products available at the moment.</p>
      </div>
    </div>
    <% } %>
  </div>
</section>

<!-- Features Section -->
<section class="py-5 features-section">
  <div class="container">
    <div class="row g-4 text-center">
      <div class="col-md-4">
        <div class="feature-item p-4">
          <div class="feature-icon">
            <i class="bi bi-truck"></i>
          </div>
          <h5 class="feature-title">Free Nationwide Shipping</h5>
          <p class="text-muted mb-0">On all orders over ₹5000</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-item p-4">
          <div class="feature-icon">
            <i class="bi bi-arrow-counterclockwise"></i>
          </div>
          <h5 class="feature-title">7 Days Return Policy</h5>
          <p class="text-muted mb-0">Hassle-free returns</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-item p-4">
          <div class="feature-icon">
            <i class="bi bi-headset"></i>
          </div>
          <h5 class="feature-title">24/7 Customer Support</h5>
          <p class="text-muted mb-0">Dedicated support</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Newsletter Section -->
<section class="py-5 newsletter-section">
  <div class="container text-center">
    <h3 class="newsletter-title mb-4">Subscribe Now & Get 20% Off</h3>
    <p class="text-muted mb-4">
      Be the first to know about our latest products and exclusive offers.
    </p>
    <form
      action="/subscribe"
      method="POST"
      class="row justify-content-center mt-4 g-2"
    >
      <div class="col-12 col-md-6">
        <input
          type="email"
          class="form-control newsletter-input"
          name="email"
          placeholder="Enter your email"
          required
        />
      </div>
      <div class="col-12 col-md-3">
        <button type="submit" class="btn btn-dark newsletter-btn w-100">
          Subscribe
        </button>
      </div>
    </form>
  </div>
</section>

<!-- Footer -->
<footer class="footer py-5">
  <div class="container">
    <div class="row gy-4">
      <div class="col-lg-5">
        <a href="/" class="footer-logo text-white"
          >18-CREW<span class="footer-logo-dot">.</span></a
        >
        <p class="footer-about">
          We're dedicated to providing you with the very best fashion
          experience, with an emphasis on quality, style, and exceptional
          service.
        </p>
      </div>
      <div class="col-lg-2 col-md-4">
        <h6 class="footer-title">COMPANY</h6>
        <ul class="footer-links list-unstyled">
          <li><a href="/" class="footer-link">Home</a></li>
          <li><a href="/about" class="footer-link">About us</a></li>
          <li><a href="/shop" class="footer-link">Shop</a></li>
          <li><a href="/contact" class="footer-link">Contact</a></li>
        </ul>
      </div>
      <div class="col-lg-2 col-md-4">
        <h6 class="footer-title">HELP</h6>
        <ul class="footer-links list-unstyled">
          <li><a href="/faq" class="footer-link">FAQs</a></li>
