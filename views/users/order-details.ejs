            </div>
          </div>
        `;
        trackingTimeline.appendChild(newTimelineItem);

        // If order is fully cancelled, remove the cancel order button
        if (result.orderStatus === 'Cancelled') {
          const cancelOrderButton = document.querySelector('.btn-cancel-order');
          if (cancelOrderButton) cancelOrderButton.remove();
        }
      } else {
        Toast.fire({
          icon: 'error',
          title: result.message || 'Failed to cancel item.'
        });
        this.disabled = false;
      }
    } catch (error) {
