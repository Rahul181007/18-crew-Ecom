<%- include("../layouts/header.ejs") %>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
/* General Styling */
body {
    font-family: 'Inter', sans-serif;
    background-color: #f5f7fa;
    color: #1e293b;
}

.navbar-brand {
    font-weight: 600;
    font-size: 1.75rem;
    color: #1e293b;
    letter-spacing: -0.025em;
    transition: color 0.2s ease;
}

.navbar-brand:hover {
    color: #3b82f6;
}

.brand-dot {
    width: 12px;
    height: 12px;
    background: linear-gradient(135deg, #3b82f6, #60a5fa);
    border-radius: 50%;
    display: inline-block;
    margin-left: 6px;
}

.navbar-nav {
    gap: 2rem;
}

.navbar-nav .nav-link {
    font-weight: 500;
    font-size: 1rem;
    color: #475569;
    transition: color 0.2s ease;
}

.navbar-nav .nav-link:hover,
.navbar-nav .nav-link.active {
    color: #3b82f6;
}

/* Card Styling */
.card {
    border: none;
    border-radius: 16px;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
    background: #ffffff;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
}

.card-header {
    border-bottom: 1px solid #e5e7eb;
    background: #fafafa;
    padding: 1.5rem;
}

.card-body {
    padding: 2rem;
}

.card-footer {
    border-top: 1px solid #e5e7eb;
    background: #fafafa;
    padding: 1.5rem;
}

/* Modernized Tracking Timeline */
.tracking-timeline {
    position: relative;
    padding-left: 48px;
    margin: 0;
}

.tracking-timeline::before {
    content: '';
    position: absolute;
    left: 20px;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(to bottom, #3b82f6, #22c55e);
    border-radius: 2px;
}

.timeline-item {
    position: relative;
    margin-bottom: 2rem;
    transition: opacity 0.3s ease;
}

.timeline-item:hover {
    opacity: 0.9;
}

.timeline-dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    position: absolute;
    left: -30px;
    top: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 12px;
    box-shadow: 0 0 0 5px rgba(59, 130, 246, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.timeline-dot:hover {
    transform: scale(1.15);
    box-shadow: 0 0 0 6px rgba(59, 130, 246, 0.15);
}

.bg-primary {
    background: linear-gradient(135deg, #3b82f6, #60a5fa);
}

.bg-success {
    background: linear-gradient(135deg, #22c55e, "Shipped"4ade80);
}

.bg-danger {
    background: linear-gradient(135deg, #ef4444, #f87171);
}

.timeline-item .status-icon {
    position: absolute;
    left: -54px;
    top: 4px;
    font-size: 1.5rem;
    color: #3b82f6;
    transition: color 0.3s ease;
}

.timeline-item .status-icon.success {
    color: #22c55e;
}

.timeline-content {
    background: #ffffff;
    border-radius: 10px;
    padding: 1rem 1.5rem;
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
}

.timeline-content:hover {
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
}

.timeline-content .fw-bold {
    font-size: 1.1rem;
    color: #1e293b;
    letter-spacing: -0.025em;
}

.timeline-content .text-muted {
    font-size: 0.85rem;
    color: #64748b;
}

/* Status Badges */
.status-pending {
    background-color: #fef3c7;
    color: #92400e;
    padding: 6px 12px;
    border-radius: 20px;
    font-weight: 500;
}

.status-processing, .status-shipped, .status-delivered, .status-cancelled, 
.status-returned, .status-return-request, .status-partially-returned, .status-rejected {
    padding: 6px 12px;
    border-radius: 20px;
    font-weight: 500;
}

.status-processing { background-color: #dbeafe; color: #1e40af; }
.status-shipped { background-color: #d1fae5; color: #065f46; }
.status-delivered { background-color: #22c55e; color: #fff; }
.status-cancelled, .status-returned, .status-return-request, .status-partially-returned, .status-rejected { 
    background-color: #fee2e2; 
    color: #991b1b; 
}

/* Table Styling */
.table {
    border-collapse: separate;
    border-spacing: 0 8px;
}

.table th {
    font-weight: 600;
    color: #1e293b;
    border: none;
    padding: 1rem;
}

.table td {
    vertical-align: middle;
    border: none;
    padding: 1rem;
    background: #ffffff;
    border-radius: 8px;
}

.table img {
    border-radius: 6px;
    transition: transform 0.3s ease;
}

.table img:hover {
    transform: scale(1.05);
}

/* Buttons */
.btn-outline-secondary, .btn-outline-primary, .btn-outline-danger, .btn-outline-warning {
    border-radius: 10px;
    padding: 10px 20px;
    font-weight: 500;
    font-size: 0.9rem;
    transition: all 0.3s ease;
}

.btn-outline-secondary {
    border-color: #e5e7eb;
    color: #475569;
}

.btn-outline-secondary:hover {
    background-color: #f8fafc;
    color: #1e293b;
}

.btn-outline-primary {
    border-color: #3b82f6;
    color: #3b82f6;
}

.btn-outline-primary:hover {
    background-color: #eff6ff;
    color: #1e40af;
}

.btn-outline-danger {
    border-color: #ef4444;
    color: #ef4444;
}

.btn-outline-danger:hover {
    background-color: #fef2f2;
    color: #991b1b;
}

.btn-outline-warning {
    border-color: #f59e0b;
    color: #f59e0b;
}

.btn-outline-warning:hover {
    background-color: #fef3c7;
    color: #92400e;
}

/* Modal Styling */
.modal-content {
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    border: none;
}

.modal-header {
    border-bottom: 1px solid #e5e7eb;
    padding: 1.5rem;
}

.modal-body {
    padding: 1.5rem;
}

.form-select, .form-control {
    border-radius: 8px;
    border: 1px solid #e5e7eb;
    padding: 10px;
    font-size: 0.9rem;
}

.form-select:focus, .form-control:focus {
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

/* Responsive Adjustments */
@media (max-width: 768px) {
    .tracking-timeline {
        padding-left: 40px;
    }

    .timeline-item .status-icon {
        left: -48px;
        font-size: 1.25rem;
    }

    .timeline-dot {
        left: -26px;
        width: 16px;
        height: 16px;
    }

    .tracking-timeline::before {
        left: 16px;
    }

    .timeline-content {
        padding: 0.75rem 1rem;
    }

    .card-body {
        padding: 1.5rem;
    }
}
</style>

<div class="container my-5">
  <h2 class="section-title mb-4 fw-bold" style="font-size: 1.875rem; color: #1e293b;">Order Details</h2>
  
  <% if (order) { %>
    <div class="card shadow-sm">
      <div class="card-header bg-light">
        <div class="d-flex justify-content-between align-items-center">
          <h5 class="mb-0 fw-semibold">Order ID: <%= order.orderId || 'N/A' %></h5>
          <span class="badge status-<%= order.status?.toLowerCase().replace(' ', '-') || 'pending' %>">
            <%= order.status || 'Pending' %>
          </span>
        </div>
        <div class="text-muted small mt-2">
          Placed on: <%= new Date(order.createdOn).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: 'numeric', minute: 'numeric' }) %>
        </div>
      </div>
      <div class="card-body">
        <!-- Tracking Information Section -->
        <h5 class="mb-3 fw-semibold">Tracking Information</h5>
        <% 
          const trackingUpdates = [];
          trackingUpdates.push({ status: "Ordered", date: order.createdOn });
          if (order.status === "Processing" || order.status === "Shipped" || order.status === "Delivered" || order.status === "Return Request" || order.status === "Returned" || order.status === "Partially Returned" || order.status === "Cancelled" || order.status === "Partially Cancelled") {
            trackingUpdates.push({ status: "Processing", date: order.updatedAt || order.createdOn });
          }
          if (order.status === "Shipped" || order.status === "Delivered" || order.status === "Return Request" || order.status === "Returned" || order.status === "Partially Returned") {
            trackingUpdates.push({ status: "Shipped", date: order.updatedAt || order.createdOn });
          }
          if (order.status === "Delivered" || order.status === "Return Request" || order.status === "Returned" || order.status === "Partially Returned") {
            trackingUpdates.push({ status: "Delivered", date: order.updatedAt || order.createdOn });
          }
          if (order.status === "Return Request" || order.status === "Partially Returned") {
            trackingUpdates.push({ status: "Return Requested", date: order.orderedItems.find(item => item.returnRequestedAt)?.returnRequestedAt || order.updatedAt });
          }
          if (order.status === "Returned" || order.status === "Partially Returned") {
            trackingUpdates.push({ status: order.status, date: order.updatedAt });
          }
          if (order.status === "Cancelled" || order.status === "Partially Cancelled") {
            trackingUpdates.push({ status: order.status, date: order.updatedAt || order.createdOn });
          }
          const rejectedItem = order.orderedItems.find(item => item.returnStatus === "Rejected");
          if (rejectedItem) {
            trackingUpdates.push({ status: "Rejected Return Request", date: rejectedItem.returnRequestedAt || order.updatedAt });
          }
        %>
        <% if (trackingUpdates.length > 0) { %>
          <div class="tracking-timeline mb-4">
            <% trackingUpdates.forEach(update => { %>
              <div class="timeline-item">
                <i class="bi bi-<%= 
                  update.status.toLowerCase() === 'ordered' ? 'cart-check' : 
                  update.status.toLowerCase() === 'processing' ? 'gear' : 
                  update.status.toLowerCase() === 'shipped' ? 'truck' : 
                  update.status.toLowerCase() === 'delivered' ? 'check-circle-fill' : 
                  update.status.toLowerCase() === 'return requested' ? 'arrow-return-left' : 
                  update.status.toLowerCase() === 'returned' ? 'x-circle' : 
                  update.status.toLowerCase() === 'partially returned' ? 'x-circle' : 
                  update.status.toLowerCase() === 'cancelled' ? 'x-circle' : 
                  update.status.toLowerCase() === 'partially cancelled' ? 'x-circle' : 
                  update.status.toLowerCase() === 'rejected return request' ? 'x-circle' : 'x-circle' 
                %> status-icon <%= 
                  update.status.toLowerCase() === 'delivered' ? 'success' : 
                  update.status.toLowerCase() === 'returned' || 
                  update.status.toLowerCase() === 'partially returned' || 
                  update.status.toLowerCase() === 'cancelled' || 
                  update.status.toLowerCase() === 'partially cancelled' || 
                  update.status.toLowerCase() === 'rejected return request' ? '' : '' 
                %>"></i>
                <div class="timeline-dot bg-<%= 
                  update.status.toLowerCase() === 'delivered' ? 'success' : 
                  update.status.toLowerCase() === 'returned' || 
                  update.status.toLowerCase() === 'return requested' || 
                  update.status.toLowerCase() === 'partially returned' || 
                  update.status.toLowerCase() === 'cancelled' || 
                  update.status.toLowerCase() === 'partially cancelled' || 
                  update.status.toLowerCase() === 'rejected return request' ? 'danger' : 'primary' 
                %> me-3">
                  <i class="bi bi-check"></i>
                </div>
                <div class="timeline-content">
                  <div class="fw-bold"><%= update.status %></div>
                  <div class="text-muted small">
                    <%= new Date(update.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: 'numeric', minute: 'numeric' }) %>
                  </div>
                </div>
              </div>
            <% }) %>
            <% if (order.trackingNumber) { %>
              <div class="text-muted small mt-3">
                Tracking Number: <%= order.trackingNumber %>
              </div>
            <% } %>
            <% if (order.trackingUrl) { %>
              <div class="text-muted small">
                <a href="<%= order.trackingUrl %>" target="_blank" class="text-primary">Track Package</a>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <p class="text-muted">Tracking information not available yet.</p>
        <% } %>
        
        <% if (order.orderedItems.some(item => item.returnStatus === 'Rejected')) { %>
          <div class="card mb-4">
            <div class="card-header bg text-dark">
              <h5 class="mb-0 fw-semibold">Rejected Returns</h5>
            </div>
            <div class="card-body">
              <% order.orderedItems.forEach(item => { %>
                <% if (item.returnStatus === 'Rejected') { %>
                  <div class="alert alert-light mb-2">
                    <div class="d-flex justify-content-between align-items-start">
                      <div>
                        <strong><%= item.product.productName %></strong> (Size: <%= item.size %>, Qty: <%= item.quantity %>)
                        <div class="mt-2">
                          <strong>Reason for rejection:</strong> <%= item.returnRejectionReason %>
                        </div>
                        <% if (item.returnRejectionDetails) { %>
                          <div class="mt-1">
                            <strong>Details:</strong> <%= item.returnRejectionDetails %>
                          </div>
                        <% } %>
                      </div>
                      <small class="text-muted">
                        <% if (item.returnProcessedAt) { %>
                          Rejected on: <%= new Date(item.returnProcessedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                        <% } else { %>
                          Rejected on: N/A
                        <% } %>
                      </small>
                    </div>
                  </div>
                <% } %>
              <% }) %>
            </div>
          </div>
        <% } %>
        
        <!-- Ordered Items Section -->
        <h5 class="mb-3 fw-semibold">Ordered Items</h5>
        <% if (order.orderedItems && order.orderedItems.length > 0) { %>
          <div class="table-responsive">
            <table class="table table-bordered">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Size</th>
                  <th>Quantity</th>
                  <th>Unit Price</th>
                  <th>Total</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% order.orderedItems.forEach(item => { %>
                  <tr>
                    <td>
                      <div class="d-flex align-items-center">
                        <% if (item.product && item.product.productImage && item.product.productImage.length > 0) { %>
                          <img src="/Uploads/re-image/<%= item.product.productImage[0] %>" alt="<%= item.product.productName || 'Product' %>" class="me-2" style="width: 50px; height: 50px; object-fit: cover;">
                        <% } %>
                        <span><%= item.product?.productName || 'N/A' %></span>
                      </div>
                    </td>
                    <td><%= item.size || 'N/A' %></td>
                    <td><%= item.quantity || 1 %></td>
                    <td>₹<%= item.price ? item.price.toFixed(2) : '0.00' %></td>
                    <td>₹<%= item.quantity && item.price ? (item.quantity * item.price).toFixed(2) : '0.00' %></td>
                    <td>
                      <% 
                        const deliveredStatuses = ["Delivered", "Return Request", "Returned", "Partially Returned"];
                        const isDeliveredForReturn = deliveredStatuses.includes(order.status);
                        const deliveredDate = trackingUpdates.find(update => update.status === "Delivered")?.date || order.updatedAt;
                        const daysSinceDelivery = deliveredDate ? Math.floor((new Date() - new Date(deliveredDate)) / (1000 * 60 * 60 * 24)) : Infinity;
                        const withinReturnWindow = daysSinceDelivery <= 7;
                        const cancelledStatuses = ["Cancelled", "Partially Cancelled"];
                        const isCancelled = cancelledStatuses.includes(order.status);
                      %>
                      <% if (item.returnStatus) { %>
                        <span class="badge status-<%= item.returnStatus.toLowerCase() %>">
                          <%= item.returnStatus %>
                        </span>
                      <% } else if (item.status === 'Cancelled') { %>
                        <span class="badge status-cancelled">Cancelled</span>
                      <% } else if (isDeliveredForReturn && !isCancelled) { %>
                        <div class="d-flex align-items-center gap-2">
                          <span class="badge status-delivered">Delivered</span>
                          <% if (withinReturnWindow) { %>
                            <button class="btn btn-outline-warning btn-sm btn-request-return" data-order-id="<%= order.orderId %>" data-item-id="<%= item._id %>">
                              <i class="bi bi-arrow-return-left"></i> Return Product
                            </button>
                          <% } %>
                        </div>
                      <% } else if (!isCancelled) { %>
                        <span class="badge status-<%= (item.status || order.status).toLowerCase().replace(' ', '-') %>">
                          <%= item.status || order.status %>
                        </span>
                      <% } else { %>
                        <span class="badge status-<%= item.status.toLowerCase() %>">
                          <%= item.status %>
                        </span>
                      <% } %>
                    </td>
                    <td>
                      <% if ((order.status === 'Pending' || order.status === 'Processing') && item.status !== 'Cancelled') { %>
                        <button class="btn btn-outline-danger btn-sm btn-cancel-item" data-order-id="<%= order.orderId %>" data-item-id="<%= item._id %>">
                          <i class="bi bi-x-circle"></i> Cancel Item
                        </button>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <div class="d-flex justify-content-end mt-3">
            <div class="fw-bold">Total Amount: ₹<%= order.finalAmount ? order.finalAmount.toFixed(2) : '0.00' %></div>
          </div>
        <% } else { %>
          <p class="text-muted">No items found for this order.</p>
        <% } %>
      </div>
      <div class="card-footer bg-light">
        <div class="row">
          <div class="col-md-6">
            <h6 class="fw-semibold">Shipping Address</h6>
            <% if (order.selectedAddress) { %>
              <p class="text-muted">
                <%= order.selectedAddress.name || 'N/A' %><br>
                <%= order.selectedAddress.landMark ? order.selectedAddress.landMark + ',' : '' %> <%= order.selectedAddress.city || '' %><br>
                <%= order.selectedAddress.state || '' %> <%= order.selectedAddress.pincode || '' %><br>
                Mobile: <%= order.selectedAddress.mobile || 'N/A' %><br>
                Alternate Mobile: <%= order.selectedAddress.altMobile || 'N/A' %>
              </p>
            <% } else { %>
              <p class="text-muted">Address not available.</p>
            <% } %>
          </div>
          <div class="col-md-6">
            <h6 class="fw-semibold">Order Status</h6>
            <p class="text-muted">
              Current Status: <%= order.status || 'Pending' %><br>
              Last Updated:
              <%= new Date(order.updatedAt || order.createdOn).toLocaleDateString('en-US', {
                year: 'numeric', month: 'short', day: 'numeric'
              }) %>
            </p>

            <h6 class="fw-semibold">Payment Details</h6>
            <p class="text-muted">
              Payment Method: <%= order.paymentMethod || 'N/A' %><br>
              Status: <%= order.isPaid ? 'Paid' : 'Not Paid' %><br>
              <% if (order.isPaid && order.paidAt) { %>
                Paid At:
                <%= new Date(order.paidAt).toLocaleDateString('en-US', {
                  year: 'numeric', month: 'short', day: 'numeric',
                  hour: 'numeric', minute: 'numeric'
                }) %><br>
              <% } %>
              <% if (order.isFullyRefunded) { %>
                <strong class="text-success">Refunded: ₹<%= order.refundedAmount.toFixed(2) %></strong><br>
                Refund Status: <span class="badge bg-success">Fully Refunded</span><br>
              <% } else if (order.refundedAmount > 0) { %>
                <strong class="text-warning">Partially Refunded: ₹<%= order.refundedAmount.toFixed(2) %></strong><br>
                Refund Status: <span class="badge bg-warning text-dark">Partial Refund</span><br>
              <% } %>
            </p>
          </div>
        </div>
        <div class="mt-3 text-end">
          <% if (order.status === 'Pending' || order.status === 'Processing') { %>
            <button class="btn btn-outline-danger btn-cancel-order" data-order-id="<%= order.orderId %>">
              <i class="bi bi-x-circle"></i> Cancel Order
            </button>
          <% } %>
          <a href="/userProfile#orders" class="btn btn-outline-secondary">Back to Orders</a>
          <a href="/orders/invoice/<%= order.orderId %>" class="btn btn-outline-primary btn-download-invoice" data-order-id="<%= order.orderId %>">
            <i class="bi bi-download"></i> Download Invoice
          </a>
        </div>
      </div>
    </div>

    <!-- Return Request Modal -->
    <div class="modal fade" id="returnModal" tabindex="-1" aria-labelledby="returnModalLabel" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title fw-semibold" id="returnModalLabel">Request Return</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <form id="return-form">
              <input type="hidden" id="return-order-id">
              <input type="hidden" id="return-item-id">
              <div class="mb-3">
                <label for="return-reason-type" class="form-label fw-medium">Reason for Return</label>
                <select class="form-select" id="return-reason-type" required>
                  <option value="" selected disabled>Select a reason</option>
                  <option value="Wrong item received">Wrong item received</option>
                  <option value="Item damaged or defective">Item damaged or defective</option>
                  <option value="Not as described">Not as described</option>
                  <option value="Changed my mind">Changed my mind</option>
                  <option value="Wrong size ordered">Wrong size ordered</option>
                  <option value="Other">Other (please specify)</option>
                </select>
              </div>
              <div class="mb-3">
                <label for="return-reason-details" class="form-label fw-medium">Additional Details</label>
                <textarea class="form-control" id="return-reason-details" rows="3" placeholder="Please provide additional details about your return"></textarea>
              </div>
              <button type="submit" class="btn btn-primary">Submit Return Request</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  <% } else { %>
    <div class="text-center py-4">
      <p class="text-muted">No order found.</p>
      <a href="/userProfile#orders" class="btn btn-outline-primary">Back to Orders</a>
    </div>
  <% } %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
// Configure SweetAlert2 Toast
const Toast = Swal.mixin({
  toast: true,
  position: 'top-end',
  showConfirmButton: false,
  timer: 3000,
  timerProgressBar: true,
  didOpen: (toast) => {
    toast.addEventListener('mouseenter', Swal.stopTimer);
    toast.addEventListener('mouseleave', Swal.resumeTimer);
  }
});

// Cancel order via AJAX
document.querySelectorAll('.btn-cancel-order').forEach(button => {
  button.addEventListener('click', async function () {
    const orderId = this.getAttribute('data-order-id');
    
    const { value: cancelReason } = await Swal.fire({
      title: 'Cancel Order',
      html: `
        <div class="text-start mb-3">
          <p>Are you sure you want to cancel this order?</p>
          <div class="mb-3">
            <select id="cancel-reason" class="form-select">
              <option value="" selected disabled>Select cancellation reason</option>
              <option value="Changed my mind">Changed my mind</option>
              <option value="Found better price elsewhere">Found better price elsewhere</option>
              <option value="Ordered by mistake">Ordered by mistake</option>
              <option value="Shipping takes too long">Shipping takes too long</option>
              <option value="Other">Other reason</option>
            </select>
          </div>
          <div id="cancel-details-container" style="display: none;">
            <textarea id="cancel-details" class="form-control mt-2" rows="2" placeholder="Please specify your reason"></textarea>
          </div>
        </div>
      `,
      focusConfirm: false,
      showCancelButton: true,
      confirmButtonColor: '#ef4444',
      cancelButtonColor: '#3b82f6',
      confirmButtonText: 'Yes, cancel',
      cancelButtonText: 'No',
      preConfirm: () => {
        const reason = document.getElementById('cancel-reason').value;
        if (!reason) {
          Swal.showValidationMessage('Please select a cancellation reason');
          return false;
        }
        const details = document.getElementById('cancel-details').value;
        return { reason, details };
      },
      didOpen: () => {
        document.getElementById('cancel-reason').addEventListener('change', function() {
          const detailsContainer = document.getElementById('cancel-details-container');
          detailsContainer.style.display = this.value === 'Other' ? 'block' : 'none';
        });
      }
    });

    if (!cancelReason) return;

    try {
      this.disabled = true;
      const response = await fetch(`/orders/cancel/${orderId}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ 
          reason: cancelReason.reason,
          details: cancelReason.details 
        }),
      });

      const result = await response.json();
      if (result.success) {
        Toast.fire({
          icon: 'success',
          title: 'Order cancelled successfully!'
        });

        const statusBadge = document.querySelector('.badge');
        statusBadge.className = 'badge status-cancelled';
        statusBadge.textContent = 'Cancelled';

        const statusText = document.querySelector('.col-md-6 p.text-muted');
        statusText.innerHTML = `Current Status: Cancelled<br>Last Updated: ${new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}`;

        this.remove();

        const trackingTimeline = document.querySelector('.tracking-timeline');
        const newTimelineItem = document.createElement('div');
        newTimelineItem.className = 'timeline-item';
        newTimelineItem.innerHTML = `
          <i class="bi bi-x-circle status-icon"></i>
          <div class="timeline-dot bg-danger me-3">
            <i class="bi bi-check"></i>
          </div>
          <div class="timeline-content">
            <div class="fw-bold">Cancelled</div>
            <div class="text-muted small">
              ${new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: 'numeric', minute: 'numeric' })}
            </div>
          </div>
        `;
        trackingTimeline.appendChild(newTimelineItem);
      } else {
        Toast.fire({
          icon: 'error',
          title: result.message || 'Failed to cancel order.'
        });
        this.disabled = false;
      }
    } catch (error) {
      console.error('Error cancelling order:', error);
      Toast.fire({
        icon: 'error',
        title: 'An error occurred while cancelling the order.'
      });
      this.disabled = false;
    }
  });
});

