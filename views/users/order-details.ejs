        const reason = document.getElementById('cancel-reason').value;
        if (!reason) {
          Swal.showValidationMessage('Please select a cancellation reason');
          return false;
        }
        const details = document.getElementById('cancel-details').value;
        return { reason, details };
      },
      didOpen: () => {
        document.getElementById('cancel-reason').addEventListener('change', function() {
          const detailsContainer = document.getElementById('cancel-details-container');
          detailsContainer.style.display = this.value === 'Other' ? 'block' : 'none';
        });
      }
    });

    if (!cancelReason) return;

    try {
      this.disabled = true;
      const response = await fetch(`/orders/cancel-item/${orderId}/${itemId}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ 
          reason: cancelReason.reason,
          details: cancelReason.details 
        }),
      });

      const result = await response.json();
      if (result.success) {
        Toast.fire({
          icon: 'success',
          title: 'Item cancelled successfully!'
        });

        // Update item status in the table
        const itemRow = this.closest('tr');
        const statusCell = itemRow.querySelector('td:nth-child(6)');
        statusCell.innerHTML = `<span class="badge status-cancelled">Cancelled</span>`;

        // Remove the cancel item button
        this.remove();

        // Update order status badge
        const statusBadge = document.querySelector('.badge');
        statusBadge.className = `badge status-${result.orderStatus.toLowerCase().replace(' ', '-')}`;
        statusBadge.textContent = result.orderStatus;

        // Update order status text
        const statusText = document.querySelector('.col-md-6 p.text-muted');
        statusText.innerHTML = `Current Status: ${result.orderStatus}<br>Last Updated: ${new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}`;

        // Add to tracking timeline
        const trackingTimeline = document.querySelector('.tracking-timeline');
        const newTimelineItem = document.createElement('div');
        newTimelineItem.className = 'timeline-item';
