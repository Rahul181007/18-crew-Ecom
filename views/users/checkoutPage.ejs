          <a
            class="nav-link dropdown-toggle text-uppercase fw-bold"
            href="#"
            role="button"
            data-bs-toggle="dropdown"
            aria-expanded="false"
          >
            <i class="bi bi-person-circle me-2"></i><%= user.name %>
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/userProfile">Profile</a></li>
            <li><hr class="dropdown-divider" /></li>
            <li>
              <a class="dropdown-item text-danger" href="/logout">Logout</a>
            </li>
          </ul>
        </li>
        <% } else { %>
        <li class="nav-item d-lg-none">
          <a class="nav-link" href="/signin"
            ><i class="bi bi-person me-2"></i>Sign In</a
          >
        </li>
        <% } %>
      </ul>

      <!-- Desktop View Icons -->
      <div class="d-none d-lg-flex align-items-center gap-3">
        <% if (locals?.user || user) { %>
        <div class="dropdown">
          <a
            class="nav-link dropdown-toggle text-uppercase fw-bold d-flex align-items-center"
            href="#"
            role="button"
            data-bs-toggle="dropdown"
            aria-expanded="false"
          >
            <i class="bi bi-person-circle me-2"></i>
            <%= user.name %>
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="/userProfile">Profile</a></li>
            <li><hr class="dropdown-divider" /></li>
            <li>
              <a class="dropdown-item text-danger" href="/logout">Logout</a>
            </li>
          </ul>
        </div>
        <% } else { %>
        <a
          href="/signin"
          class="text-dark fs-5"
          title="Account"
          aria-label="Account"
        >
          <i class="bi bi-person"></i>
        </a>
        <% } %>
        <a
          href="/wishlist"
          class="text-dark position-relative fs-5"
          title="Wishlist"
          aria-label="Wishlist<%= wishlistCount > 0 ? ` with ${wishlistCount} items` : '' %>"
        >
          <i class="bi bi-heart"></i>
          <% if (wishlistCount > 0) { %>
          <span class="badge-dot"></span>
          <% } %>
        </a>
        <a
          href="/getCartPage"
          class="text-dark position-relative fs-5"
          title="Cart"
          aria-label="Cart<%= cartCount > 0 ? ` with ${cartCount} items` : '' %>"
        >
          <i class="bi bi-bag"></i>
          <% if (cartCount > 0) { %>
          <span class="badge-dot"></span>
          <% } %>
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- Main Content -->
<section class="py-4">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <!-- Products Section -->
                <div class="section-card">
                    <h4><%= isCart ? 'Your Cart' : 'Your Item' %></h4>
                    <div class="table-responsive">
                        <table class="order_table">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Size</th>
                                    <th>Quantity</th>
                                    <th>Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (product && product.length > 0) { %>
                                    <% product.forEach((item, i) => { %>
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-3">
                                                    <img src="/uploads/re-image/<%= item.productDetails?.productImage[0] %>" 
                                                         alt="<%= item.productDetails.productName %>">
                                                    <div>
                                                        <h5 class="mb-1">
                                                            <a href="/productDetails?id=<%= item.productDetails._id %>" class="text-dark text-decoration none">
                                                                <%= item.productDetails.productName %>
                                                            </a>
                                                        </h5>
                                                        <p class="text-muted mb-0">₹<%= item.productDetails.salePrice %></p>
                                                    </div>
                                                </div>
                                            </td>
                                            <td><%= item.size || 'N/A' %></td>
                                            <td><%= item.quantity %></td>
                                            <td>₹<%= (item.quantity * item.productDetails.salePrice).toFixed(2) %></td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="4" class="text-center py-4">No products found</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Delivery Address Section -->
                <div class="section-card">
                    <h4>Delivery Address</h4>
                    <div class="row">
                        <% if (locals.userAddress && userAddress.address && userAddress.address.length > 0) { %>
                            <% userAddress.address.forEach((address, index) => { %>
                                <div class="col-md-6 mb-3">
                                    <div class="address-card <%= index === 0 ? 'selected' : '' %>">
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" 
                                                   id="addressRadio<%= index %>" 
                                                   name="selectedAddress" 
                                                   value='<%= JSON.stringify({ addressId: userAddress._id, addressIndex: index }) %>'
                                                   <%= index === 0 ? 'checked' : '' %>>
                                        </div>
                                        <h5><%= address.addressType %></h5>
                                        <address>
                                            <%= address.name %><br>
                                            <%= address.city %>, <%= address.state %><br>
                                            <%= address.landMark %><br>
                                            <%= address.pincode %>
                                        </address>
                                        <p>Phone: <%= address.mobile %></p>
                                        <% if (address.altMobile) { %>
                                            <p>Alt. Phone: <%= address.altMobile %></p>
                                        <% } %>
                                        <div class="mt-2">
                                            <a href="/editAddress?id=<%= userAddress._id %>&index=<%= index %>&source=checkout" 
                                               class="btn btn-sm btn-outline-primary">Edit</a>
                                            <a href="/deleteAddress/<%= address._id %>/<%= index %>" 
                                               class="btn btn-sm btn-outline-danger ms-2" 
                                               onclick="return confirm('Are you sure you want to delete this address?')">
                                                Delete
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="col-12">
                                <div class="alert alert-warning">
                                    No saved addresses found. Please add an address to continue.
                                </div>
                            </div>
                        <% } %>
                        <div class="col-12 mt-2">
                           <a href="/addAddress?source=checkout" class="btn btn-primary w-100">
                             <i class="bi bi-plus-circle"></i> Add New Address
                           </a>

                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <!-- Order Summary Section -->
                <div class="section-card order-summary">
                    <h4>Order Summary</h4>
                    <table class="summary-table">
                        <tbody>
                            <tr>
                                <th>Subtotal</th>
                                <td>₹<%= subtotal.toFixed(2) %></td>
                            </tr>
                            <tr>
                                <th>Savings</th>
                                <td id="generalDiscount">-₹<%= discount.toFixed(2) %></td>
                            </tr>
                            <tr>
                                <th>Coupon Discount</th>
                                <td id="couponDiscount">-₹<%= couponDiscount.toFixed(2) %></td>
                            </tr>
                            <tr>
                                <th>Shipping</th>
                                <td><em>Free Shipping</em></td>
                            </tr>
                            <tr class="total-row">
                                <th>Total</th>
                                <td>
                                    <span class="font-xl" id="totalValue">₹<%= grandTotal.toFixed(2) %></span>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- Coupon Section -->
<!-- Coupon Section -->
<div class="coupon-section">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0">Apply Coupon</h5>
        <% if (Coupon && Coupon.length > 0) { %>
            <button class="btn btn-sm btn-outline-primary" id="toggleCouponsBtn">
                Show Coupons <i class="bi bi-chevron-down"></i>
            </button>
        <% } %>
    </div>
    <div class="input-group mb-2">
        <input type="text" id="couponCode" class="form-control" placeholder="Enter coupon code">
        <button class="btn btn-primary" type="button" id="applyCoupon">Apply</button>
    </div>
    <div id="couponMessage" class="small mb-2"></div>
    <% if (Coupon && Coupon.length > 0) { %>
        <div class="coupon-list" id="couponList" style="display: none;">
            <% Coupon.forEach(coupon => { %>
                <div class="coupon-item">
                    <span class="coupon-name"><%= coupon.name %></span>
                    <span class="coupon-details">
                        <% if (coupon.offerPercentage) { %>
                            <%= coupon.offerPercentage %>% off, Min. ₹<%= coupon.minimumPrice %>
                        <% } else { %>
                            ₹<%= coupon.offerPrice %> off, Min. ₹<%= coupon.minimumPrice %>
                        <% } %>
                    </span>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

                    <!-- Payment Options -->
                    <div class="payment_method mt-4">
                        <h5>Payment Options</h5>
                        <div class="custome-radio mb-2">
                            <input class="form-check-input payment" type="radio" 
                                   value="cod" name="payment_option" id="CashOnDelivery"
                                   <%= grandTotal <= 1000 ? 'checked' : '' %>
                                   <%= grandTotal > 1000 ? 'disabled' : '' %>>
                            <label class="form-check-label" for="CashOnDelivery">
                                Cash on Delivery
                                <% if (grandTotal > 1000) { %>
                                    <span class="text-danger small">(Not available for orders above ₹1000)</span>
                                <% } %>
                            </label>
                        </div>
                        <div class="custome-radio mb-2">
                            <input class="form-check-input payment" type="radio" 
                                   value="razorpay" name="payment_option" id="Razorpay"
                                   <%= grandTotal > 5000 ? 'checked' : '' %>>
                            <label class="form-check-label" for="Razorpay">Razorpay</label>
                        </div>
                        <div class="custome-radio">
                            <input class="form-check-input payment" type="radio" 
                                   value="wallet" name="payment_option" id="wallet">
                            <label class="form-check-label" for="wallet">
                                Wallet (Balance: ₹<%= user.wallet || 0 %>)
                            </label>
                        </div>
                    </div>

                    <!-- Place Order Button -->
                    <button type="button" class="btn btn-primary w-100 mt-4 py-3" id="placeOrderBtn" 
                            onclick="placeOrder('<%= user._id %>')">
                        <%= isCart ? 'Place Order' : 'Buy Now' %>
                    </button>

                    <% if (!isCart && buyNowData) { %>
                        <input type="hidden" id="buyNow" value="true">
                        <input type="hidden" id="buyNowProductId" value="<%= buyNowData.productId %>">
                        <input type="hidden" id="buyNowSize" value="<%= buyNowData.size %>">
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- JavaScript -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
// Initialize variables
let couponState = {
    applied: '<%= locals.couponCode || "" %>' || null,
    discount: <%= couponDiscount || 0 %>,
    message: '<%= locals.couponCode ? "Coupon applied successfully!" : "" %>',
    isValid: <%= couponDiscount > 0 %>
};

// Calculate cart total
let cartTotal = <%= grandTotal + discount + couponDiscount %>;
let generalDiscount = <%= discount || 0 %>;

document.addEventListener('DOMContentLoaded', function() {
    console.log('Checkout page initialized');
    
    // Auto-select first payment method if none selected and COD is available
    const paymentMethods = document.querySelectorAll('input[name="payment_option"]');
    const hasSelectedPayment = Array.from(paymentMethods).some(radio => radio.checked);
    
    if (!hasSelectedPayment) {
        const codRadio = document.getElementById('CashOnDelivery');
        const firstEnabledRadio = Array.from(paymentMethods).find(radio => !radio.disabled);
        
        if (firstEnabledRadio) {
            firstEnabledRadio.checked = true;
            console.log('Auto-selected payment:', firstEnabledRadio.value);
            updatePlaceOrderButtonState();
        }
    }

    // Set up event listeners for address and payment selection
    document.querySelectorAll('input[name="selectedAddress"], input[name="payment_option"]')
        .forEach(el => {
            el.addEventListener('change', function() {
                console.log(`${this.name} changed:`, this.value);
                updatePlaceOrderButtonState();
                
                if (this.name === 'selectedAddress') {
                    document.querySelectorAll('.address-card').forEach(card => {
                        card.classList.remove('selected');
                    });
                    this.closest('.address-card').classList.add('selected');
                }
            });
        });

    // Initialize coupon input
    const couponInput = document.getElementById('couponCode');
    const applyCouponBtn = document.getElementById('applyCoupon');
    
    couponInput.value = couponState.applied || '';
    applyCouponBtn.disabled = !couponInput.value.trim() || couponState.applied !== null;
    if (couponState.message) {
        showCouponMessage(couponState.message, couponState.isValid ? 'success' : 'error');
    }

    couponInput.addEventListener('input', function() {
        applyCouponBtn.disabled = !this.value.trim() || couponState.applied !== null;
    });

    // Apply coupon handler
    applyCouponBtn.addEventListener('click', applyCouponHandler);

    // Initial button state check
    updatePlaceOrderButtonState();
});

async function applyCouponHandler() {
    const couponCode = document.getElementById('couponCode').value.trim();
    const couponMessage = document.getElementById('couponMessage');
    
    if (!couponCode) {
        showCouponMessage('Please enter a coupon code', 'error');
        return;
    }

    if (couponState.applied) {
        showCouponMessage('A coupon is already applied. Remove it to apply a new one.', 'error');
        return;
    }

    try {
        const response = await fetch('/applyCoupon', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
                couponCode, 
                cartTotal: cartTotal - generalDiscount,
                userId: '<%= user._id %>'
            })
        });

        const data = await response.json();
        
        if (!response.ok || !data.status) {
            throw new Error(data.message || 'Invalid coupon code');
        }

        couponState = {
            applied: couponCode,
            discount: data.discount,
            message: 'Coupon applied successfully!',
            isValid: true
        };

        updateOrderSummary();
        showCouponMessage(couponState.message, 'success');
        
        const removeBtn = document.createElement('button');
        removeBtn.className = 'btn btn-sm btn-outline-danger ms-2';
        removeBtn.textContent = 'Remove';
        removeBtn.onclick = removeCoupon;
        couponMessage.appendChild(removeBtn);

    } catch (error) {
        showCouponMessage(error.message, 'error');
        console.error('Coupon error:', error);
    }
}

async function removeCoupon() {
    try {
        const response = await fetch('/removeCoupon', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });

        if (!response.ok) throw new Error('Failed to remove coupon');

        couponState = {
            applied: null,
            discount: 0,
            message: 'Coupon removed successfully!',
            isValid: false
        };

        document.getElementById('couponCode').value = '';
        updateOrderSummary();
        showCouponMessage(couponState.message, 'success');

    } catch (error) {
        showCouponMessage(error.message, 'error');
    }
}

function updateOrderSummary() {
    const subtotal = cartTotal;
    const totalDiscount = generalDiscount + couponState.discount;
    const finalAmount = subtotal - totalDiscount;

    document.getElementById('couponDiscount').textContent = `-₹${couponState.discount.toFixed(2)}`;
    document.getElementById('totalValue').textContent = `₹${finalAmount.toFixed(2)}`;
}

function showCouponMessage(message, type) {
    const couponMessage = document.getElementById('couponMessage');
    couponMessage.innerHTML = `<span class="text-${type}">${message}</span>`;
}

function updatePlaceOrderButtonState() {
    const addressSelected = document.querySelector("input[name='selectedAddress']:checked");
    const paymentSelected = document.querySelector("input[name='payment_option']:checked");
    const placeOrderBtn = document.getElementById('placeOrderBtn');
    
    console.log('Button state check:', {
        address: !!addressSelected,
        payment: !!paymentSelected
    });
    
    placeOrderBtn.disabled = !(addressSelected && paymentSelected);
}

async function placeOrder(userId) {
    // Get all required elements
    const selectedAddress = document.querySelector("input[name='selectedAddress']:checked");
    const paymentMethod = document.querySelector("input[name='payment_option']:checked");
    const addressCards = document.querySelectorAll('.address-card');
    const placeOrderBtn = document.getElementById('placeOrderBtn');

    // Validate address selection
    if (!selectedAddress) {
        // Highlight all address cards to show they need selection
        addressCards.forEach(card => {
            card.style.borderColor = 'var(--error)';
            card.style.boxShadow = '0 0 0 2px rgba(239, 68, 68, 0.2)';
        });

        Swal.fire({
            icon: 'error',
            title: 'Address Required',
            text: 'Please select a delivery address to continue',
            didClose: () => {
                // Scroll to address section
                document.querySelector('.section-card h4').scrollIntoView({
                    behavior: 'smooth',
                    block: 'center'
                });
            }
        });
        return;
    }

    // Validate payment method
    if (!paymentMethod) {
        Swal.fire({
            icon: 'error',
            title: 'Payment Method Required',
            text: 'Please select a payment method to continue',
            didClose: () => {
                // Scroll to payment section
                document.querySelector('.payment_method').scrollIntoView({
                    behavior: 'smooth',
                    block: 'center'
                });
            }
        });
        return;
    }

    // Parse address data
    let addressData;
    try {
        addressData = JSON.parse(selectedAddress.value);
        if (!addressData.addressId || typeof addressData.addressIndex === 'undefined') {
            throw new Error('Invalid address data');
        }
    } catch (error) {
        Swal.fire({
            icon: 'error',
            title: 'Invalid Address',
            text: 'The selected address appears to be invalid. Please select another address or add a new one.',
            didClose: () => {
                document.querySelector('.section-card h4').scrollIntoView({
                    behavior: 'smooth',
                    block: 'center'
                });
            }
        });
        return;
    }

    // Validate wallet balance if wallet payment selected
    if (paymentMethod.value === 'wallet') {
        const walletBalance = parseFloat('<%= user.wallet || 0 %>');
        const totalAmount = parseFloat(document.getElementById('totalValue').textContent.replace(/[^\d.]/g, ''));
        
        if (walletBalance < totalAmount) {
            Swal.fire({
                icon: 'error',
                title: 'Insufficient Wallet Balance',
                html: `Your wallet balance (₹${walletBalance.toFixed(2)}) is less than the order total (₹${totalAmount.toFixed(2)}).<br>Please choose another payment method.`,
                didClose: () => {
                    document.querySelector('.payment_method').scrollIntoView({
                        behavior: 'smooth',
                        block: 'center'
                    });
                }
            });
            return;
        }
    }

    // Validate COD availability for orders > 1000
    if (paymentMethod.value === 'cod') {
        const totalAmount = parseFloat(document.getElementById('totalValue').textContent.replace(/[^\d.]/g, ''));
        if (totalAmount > 1000) {
            Swal.fire({
                icon: 'error',
                title: 'COD Not Available',
                text: 'Cash on Delivery is not available for orders above ₹1000. Please choose another payment method.',
                didClose: () => {
                    document.querySelector('.payment_method').scrollIntoView({
                        behavior: 'smooth',
                        block: 'center'
                    });
                }
            });
            return;
        }
    }

    // If all validations pass, proceed with order placement
    const swal = Swal.fire({
        title: 'Processing Order',
        html: 'Please wait while we process your order...',
        allowOutsideClick: false,
        didOpen: () => Swal.showLoading(),
    });

    try {
        const orderData = {
            userId,
            addressId: addressData.addressId,
            addressIndex: addressData.addressIndex,
            payment: paymentMethod.value,
            couponCode: couponState.applied,
            generalDiscount,
            couponDiscount: couponState.discount,
            finalAmount: parseFloat(document.getElementById('totalValue').textContent.replace(/[^\d.]/g, '')),
            buyNow: document.getElementById('buyNow')?.value === 'true',
            totalPrice: cartTotal,
        };

        if (orderData.buyNow) {
            const productId = document.getElementById('buyNowProductId')?.value;
            const size = document.getElementById('buyNowSize')?.value;
            
            if (!productId || !size) {
                throw new Error('Product information missing for Buy Now order');
            }
            
            orderData.productId = productId;
            orderData.size = size;
        }

        const response = await fetch('/orderPlaced', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(orderData),
        });

        const data = await response.json();

        if (!response.ok || !data.status) {
            throw new Error(data.message || 'Order placement failed');
        }

        if (data.razorpayOrder) {
            handleRazorpayPayment(data.razorpayOrder, data.order._id);
        } else {
            Swal.close();
            window.location.href = `/successPage?id=${data.order._id}`;
        }
    } catch (error) {
        Swal.fire({
            icon: 'error',
            title: 'Order Failed',
            text: error.message,
        });
    }
}

function handleRazorpayPayment(razorpayOrder, orderId) {
  if (!razorpayOrder || !razorpayOrder.id) {
    Swal.fire({
      icon: 'error',
      title: 'Payment Error',
      text: 'Invalid Razorpay order details',
    }).then(() => {
      window.location.href = `/failedPage?message=${encodeURIComponent('Invalid Razorpay order details')}`;
    });
    return;
  }

  const options = {
    key: "<%= process.env.RAZORPAY_KEY_ID %>",
    amount: razorpayOrder.amount,
    currency: razorpayOrder.currency,
    name: "18-CREW",
    description: "Order Payment",
    order_id: razorpayOrder.id,
    handler: async function (response) {
      try {
        const verifyResponse = await fetch('/verify-payment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            razorpay_payment_id: response.razorpay_payment_id,
            razorpay_order_id: response.razorpay_order_id,
            razorpay_signature: response.razorpay_signature,
          }),
        });

        const verifyData = await verifyResponse.json();

        if (verifyData.status) {
          Swal.close();
          window.location.href = `/successPage?id=${verifyData.orderId}`;
        } else {
          Swal.fire({
            icon: 'error',
            title: 'Payment Failed',
            text: verifyData.message || 'Payment verification failed',
          }).then(() => {
            window.location.href = `/failedPage?message=${encodeURIComponent(verifyData.message || 'Payment verification failed')}`;
          });
        }
      } catch (error) {
        Swal.fire({
          icon: 'error',
          title: 'Payment Error',
          text: 'An error occurred during payment verification',
        }).then(() => {
          window.location.href = `/failedPage?message=${encodeURIComponent('An error occurred during payment verification')}`;
        });
      }
    },
    prefill: {
      name: "<%= user.name %>",
      email: "<%= user.email %>",
    },
    theme: {
      color: "#C586A5",
    },
    modal: {
      ondismiss: function () {
        // Runs when user closes Razorpay modal without completing payment
        Swal.fire({
          icon: 'info',
          title: 'Payment Cancelled',
          text: 'You closed the payment window before completing the transaction.',
        }).then(() => {
          window.location.href = `/failedPage?message=${encodeURIComponent('You cancelled the payment.')}`;
        });
      }
    }
  };

  const rzp = new Razorpay(options);

  rzp.on('payment.failed', function (response) {
    Swal.fire({
      icon: 'error',
      title: 'Payment Failed',
      text: response.error.description || 'Payment failed. Please try again.',
    }).then(() => {
      window.location.href = `/failedPage?message=${encodeURIComponent(response.error.description || 'Payment failed. Please try again.')}`;
    });
  });

  rzp.open();
}

// Coupon list toggle functionality
document.addEventListener('DOMContentLoaded', function() {
    const toggleBtn = document.getElementById('toggleCouponsBtn');
    const couponList = document.getElementById('couponList');
    
    if (toggleBtn && couponList) {
        // Initialize state
        let isExpanded = false;
        
        toggleBtn.addEventListener('click', function() {
            isExpanded = !isExpanded;
            
            // Toggle visibility
            if (isExpanded) {
                couponList.style.display = 'block';
                setTimeout(() => {
                    couponList.classList.add('show');
                }, 10);
                this.innerHTML = 'Hide Coupons <i class="bi bi-chevron-down"></i>';
                this.classList.add('collapsed');
            } else {
                couponList.classList.remove('show');
                setTimeout(() => {
                    couponList.style.display = 'none';
                }, 300); // Match this with your CSS transition time
                this.innerHTML = 'Show Coupons <i class="bi bi-chevron-down"></i>';
                this.classList.remove('collapsed');
            }
        });
        
    }
});
</script>

