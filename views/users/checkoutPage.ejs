<%- include("../layouts/header.ejs") %>

<!-- External Styles -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

<style>
/* Updated Professional Styles */
:root {
    --primary: #C586A5;
    --primary-dark: #A76C86;
    --primary-light: #f0e1e8;
    --text-dark: #1A202C;
    --text-muted: #6B7280;
    --background: #F7FAFC;
    --white: #FFFFFF;
    --border: #E2E8F0;
    --border-light: #f1f5f9;
    --shadow: 0 1px 3px rgba(0, 0, 0, 0.05);
    --shadow-hover: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    --error: #EF4444;
    --success: #10B981;
    --transition-speed: 0.3s
}

/* Modern Typography */
body {
    font-family: 'Poppins', sans-serif;
    background-color: var(--background);
    color: var(--text-dark);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
}
/* Navigation */
  .navbar {
    box-shadow: 0 2px 15px rgba(0,0,0,0.05);
    transition: all var(--transition-speed) ease;
  }
  
  .navbar.scrolled {
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  
  .navbar-brand {
    font-weight: 700;
    font-size: 1.6rem;
    color: #1a1517;
    letter-spacing: 0.5px;
    position: relative;
  }
  
  .brand-dot {
    width: 10px;
    height: 10px;
    background: #C586A5;
    border-radius: 50%;
    display: inline-block;
    margin-left: 4px;
  }
  
  .navbar-nav {
    gap: 1.5rem;
  }
  
  .navbar-nav .nav-link {
    font-weight: 500;
    color:#212529;
    transition: color var(--transition-speed);
    position: relative;
    padding: 0.5rem 0;
  }
  
  .navbar-nav .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: #C586A5;
    transition: width var(--transition-speed);
  }
  
  .navbar-nav .nav-link:hover::after,
  .navbar-nav .nav-link.active::after {
    width: 100%;
  }
  
  .navbar-nav .nav-link:hover,
  .navbar-nav .nav-link.active {
    color: #C586A5;
  }
  
  /* Badge */
  .badge-dot {
    position: absolute;
    top: -5px;
    right: -5px;
    width: 10px;
    height: 10px;
    background-color:#e60039;
    border-radius: 50%;
    border: 1px solid white;
  }
  

/* Enhanced Section Cards */
.section-card {
    background: var(--white);
    border: 1px solid var(--border-light);
    border-radius: 16px;
    padding: 28px;
    margin-bottom: 28px;
    box-shadow: var(--shadow);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.section-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
}

.section-card h4 {
    font-weight: 600;
    color: var(--text-dark);
    margin-bottom: 24px;
    font-size: 1.25rem;
    padding-bottom: 16px;
    position: relative;
}

.section-card h4:after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 48px;
    height: 3px;
    background: var(--primary);
    border-radius: 3px;
}

/* Modern Table */
.order_table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
}

.order_table th {
    background: var(--white);
    font-weight: 600;
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid var(--border-light);
    position: sticky;
    top: 0;
}

.order_table td {
    padding: 16px;
    vertical-align: middle;
    border-bottom: 1px solid var(--border-light);
    background: var(--white);
}

.order_table tr:last-child td {
    border-bottom: none;
}

.order_table img {
    width: 64px;
    height: 64px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid var(--border-light);
    box-shadow: 0 1px 2px rgba(0,0,0,0.05);
}

/* Enhanced Address Cards */
.address-card {
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
    background: var(--white);
    position: relative;
    transition: all 0.3s ease;
    cursor: pointer;
    overflow: hidden;
}

.address-card:hover {
    border-color: var(--primary);
    box-shadow: var(--shadow-hover);
}

.address-card.selected {
    border: 2px solid var(--primary);
    background-color: rgba(197, 134, 165, 0.03);
}

.address-card.selected:before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--primary);
}

.address-card .form-check {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 2;
}

/* Modern Payment Methods */
.payment_method .form-check {
    padding: 16px;
    border: 1px solid var(--border-light);
    border-radius: 12px;
    margin-bottom: 12px;
    transition: all 0.2s ease;
    background: var(--white);
    display: flex;
    align-items: center;
    gap: 12px;
}

.payment_method .form-check:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
}

.payment_method .form-check-input {
    width: 18px;
    height: 18px;
    margin: 0;
}

.payment_method .form-check-label {
    font-weight: 500;
    flex: 1;
}

/* Enhanced Order Summary */
.order-summary {
    position: sticky;
    top: 24px;
}

.summary-table {
    width: 100%;
    font-size: 0.875rem;
}

.summary-table th, .summary-table td {
    padding: 12px 0;
    border-bottom: 1px solid var(--border-light);
}

.summary-table th {
    font-weight: 500;
    color: var(--text-muted);
}

.summary-table .total-row th,
.summary-table .total-row td {
    border-top: 2px solid var(--border);
    border-bottom: none;
    padding-top: 16px;
}

.summary-table .font-xl {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--primary);
}

/* Modern Buttons */
.btn-primary {
    background: var(--primary);
    border: none;
    padding: 14px 24px;
    border-radius: 12px;
    color: var(--white);
    font-weight: 600;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    font-size: 0.8125rem;
}

.btn-primary:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
}

.btn-outline-primary {
    border-color: var(--primary);
    color: var(--primary);
}

.btn-outline-primary:hover {
    background: var(--primary-light);
}

/* Professional Coupon Section */
.coupon-section {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--border-light);
}

.coupon-list {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    margin-top: 0;
    border-radius: 12px;
    background-color: var(--white);
    border: 1px solid transparent;
}

.coupon-list.show {
    max-height: 400px;
    margin-top: 12px;
    border-color: var(--border-light);
    padding: 12px;
}

#toggleCouponsBtn {
    border: none;
    background: transparent;
    color: var(--primary);
    font-weight: 500;
    font-size: 0.8125rem;
    padding: 4px 8px;
    border-radius: 6px;
    transition: all 0.2s ease;
}

#toggleCouponsBtn:hover {
    background: var(--primary-light);
}

#toggleCouponsBtn .bi-chevron-down {
    transition: transform 0.3s ease;
    font-size: 0.875rem;
}

#toggleCouponsBtn.collapsed .bi-chevron-down {
    transform: rotate(180deg);
}

.coupon-item {
    padding: 10px 12px;
    border-radius: 8px;
    margin-bottom: 6px;
    font-size: 0.8125rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--background);
    transition: all 0.2s ease;
}

.coupon-item:last-child {
    margin-bottom: 0;
}

.coupon-item:hover {
    background-color: var(--primary-light);
    transform: translateX(2px);
}

.coupon-name {
    font-weight: 600;
    color: var(--primary);
}

.coupon-details {
    color: var(--text-muted);
    font-size: 0.75rem;
}

/* Input Group Enhancements */
.input-group {
    border-radius: 12px;
    overflow: hidden;
}

.form-control {
    border: 1px solid var(--border-light);
    padding: 12px 16px;
    font-size: 0.875rem;
    transition: all 0.2s ease;
}

.form-control:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(197, 134, 165, 0.1);
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .section-card {
        padding: 20px;
        border-radius: 12px;
    }
    
    .order_table th, 
    .order_table td {
        padding: 12px;
    }
    
    .address-card {
        padding: 16px;
    }
}

/* Micro-interactions */
.form-check-input:checked {
    background-color: var(--primary);
    border-color: var(--primary);
}

.form-check-input:focus {
    box-shadow: 0 0 0 3px rgba(197, 134, 165, 0.25);
}

/* Loading state for buttons */
.btn-loading {
    position: relative;
    pointer-events: none;
}

.btn-loading:after {
    content: "";
    position: absolute;
    width: 16px;
    height: 16px;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    margin: auto;
    border: 2px solid transparent;
    border-top-color: var(--white);
    border-radius: 50%;
    animation: button-loading-spinner 1s ease infinite;
}

@keyframes button-loading-spinner {
    from { transform: rotate(0turn); }
    to { transform: rotate(1turn); }
}
</style>

<nav class="navbar navbar-expand-lg navbar-light bg-white py-3 sticky-top">
  <div class="container">
    <a href="/" class="navbar-brand d-flex align-items-center">
      18-CREW<span class="brand-dot"></span>
    </a>

    <!-- Cart & Wishlist Icons - Always Visible on Mobile -->
    <div class="d-flex d-lg-none align-items-center gap-3 ms-auto me-3">
      <a
        href="/wishlist"
        class="text-dark position-relative fs-5"
        title="Wishlist"
        aria-label="Wishlist<%= wishlistCount > 0 ? ` with ${wishlistCount} items` : '' %>"
      >
        <i class="bi bi-heart"></i>
        <% if (wishlistCount > 0) { %>
        <span class="badge-dot"></span>
        <% } %>
      </a>
      <a
        href="/getCartPage"
        class="text-dark position-relative fs-5"
        title="Cart"
        aria-label="Cart<%= cartCount > 0 ? ` with ${cartCount} items` : '' %>"
      >
        <i class="bi bi-bag"></i>
        <% if (cartCount > 0) { %>
        <span class="badge-dot"></span>
        <% } %>
      </a>
    </div>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarContent"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarContent">
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a
            class="nav-link <%= typeof page !== 'undefined' && page === 'home' ? 'active' : '' %>"
            href="/"
            >HOME</a
          >
        </li>
        <li class="nav-item">
          <a
            class="nav-link <%= typeof page !== 'undefined' && page === 'shop' ? 'active' : '' %>"
            href="/shop"
            >COLLECTION</a
          >
        </li>
        <li class="nav-item">
          <a
            class="nav-link <%= typeof page !== 'undefined' && page === 'about' ? 'active' : '' %>"
            href="/about"
            >ABOUT</a
          >
        </li>
        <li class="nav-item">
          <a
            class="nav-link <%= typeof page !== 'undefined' && page === 'contact' ? 'active' : '' %>"
            href="/contact"
            >CONTACT</a
          >
