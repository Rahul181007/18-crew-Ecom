<section>
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <!-- Products Section -->
                <div class="section-card">
                    <h4><%= isCart ? 'Your Cart' : 'Your Item' %></h4>
                    <div class="table-responsive order_table">
                        <table>
                            <thead>
                                <tr>
                                    <th>Image</th>
                                    <th>Product</th>
                                    <th>Size</th>
                                    <th>Quantity</th>
                                    <th>Total</th>
                                    <% if (isCart) { %>
                                        <th>Delete</th>
                                    <% } %>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (product && product.length > 0) { %>
                                    <% product.forEach((item, i) => { %>
                                        <tr>
                                            <td class="image product-thumbnail">
                                                <img src="/Uploads/re-image/<%= item.productDetails?.productImage[0] %>" alt="#">
                                            </td>
                                            <td>
                                                <h5>
                                                    <a href="/productDetails?id=<%= item.productDetails._id %>">
                                                        <%= item.productDetails.productName %>
                                                    </a>
                                                </h5>
                                            </td>
                                            <td><%= item.size || 'N/A' %></td>
                                            <td>
                                                <% if (isCart) { %>
                                                    <div class="input-group" style="max-width: 120px;">
                                                        <button class="btn btn-outline-secondary minus-btn" type="button" 
                                                                data-product-id="<%= item.productDetails._id %>">-</button>
                                                        <input type="text" class="form-control text-center quantity-input" 
                                                               value="<%= item.quantity %>" 
                                                               data-product-id="<%= item.productDetails._id %>">
                                                        <button class="btn btn-outline-secondary plus-btn" type="button" 
                                                                data-product-id="<%= item.productDetails._id %>">+</button>
                                                    </div>
                                                <% } else { %>
                                                    <%= item.quantity %>
                                                <% } %>
                                            </td>
                                            <td>₹<%= item.quantity * item.productDetails.salePrice %></td>
                                            <% if (isCart) { %>
                                                <td class="action" data-title="Remove">
                                                    <a class="btn btn-sm btn-small" href="/deleteItem?id=<%= item.productDetails._id %>">
                                                        <i class="bi bi-trash"></i>
                                                    </a>
                                                </td>
                                            <% } %>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="<%= isCart ? '6' : '5' %>">No products found</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Delivery Address Section -->
                <div class="section-card">
                    <h4>Delivery Address</h4>
                    <div class="row">
                        <% if (locals.userAddress && userAddress.address && userAddress.address.length > 0) { %>
                            <% userAddress.address.forEach((address, index) => { %>
                                <div class="col-md-6 mb-3">
                                    <div class="address-card">
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" 
                                                   id="addressRadio<%= index %>" 
                                                   name="selectedAddress" 
                                                   value='<%= JSON.stringify({ addressId: userAddress._id, addressIndex: index }) %>'
                                                   <%= index === 0 ? 'checked' : '' %>>
                                            <label class="form-check-label" for="addressRadio<%= index %>">Select</label>
                                        </div>
                                        <h5><%= address.addressType %></h5>
                                        <address>
                                            <%= address.name %><br>
                                            <%= address.city %>, <%= address.state %><br>
                                            <%= address.landMark %><br>
                                            <%= address.pincode %>
                                        </address>
                                        <p>Phone: <%= address.mobile %></p>
                                        <% if (address.altMobile) { %>
                                            <p>Alt. Phone: <%= address.altMobile %></p>
                                        <% } %>
                                        <div class="mt-2">
                                            <a href="/editAddress?id=<%= userAddress._id %>&index=<%= index %>&source=checkout" class="btn-small">Edit</a>
                                            <a href="/deleteAddress?id=<%= userAddress._id %>&index=<%= index %>" class="btn-small ms-2" 
                                               onclick="return confirm('Are you sure you want to delete this address?')">
                                                Delete
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="col-md-6">
                                <div class="address-card">
                                    <p class="text-muted">No saved addresses found</p>
                                </div>
                            </div>
                        <% } %>
                        <div class="col-md-6">
                            <a href="/addAddress" class="btn btn-primary w-100">
                                <i class="bi bi-plus-circle"></i> Add New Address
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 order-summary">
                <!-- Order Summary Section -->
                <div class="section-card">
                    <h4>Order Summary</h4>
                    <table class="summary-table">
                        <tbody>
                            <tr>
                                <th>Subtotal</th>
                                <td>₹<%= grandTotal + (discount || 0) %></td>
                            </tr>
                            <tr>
                                <th>Shipping</th>
                                <td><em>Free Shipping</em></td>
                            </tr>
                            <tr>
                                <th>Discount</th>
                                <td id="discount">-₹<%= discount || 0 %></td>
                            </tr>
                            <tr>
                                <th>Total</th>
                                <td>
                                    <span class="font-xl" id="totalValue">₹<%= grandTotal %></span>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- Coupon Section -->
                    <% if (Coupon && Coupon.length > 0) { %>
                        <div class="mt-4">
                            <h5>Apply Coupon</h5>
                            <div class="input-group mb-3">
                                <input type="text" class="form-control" id="couponCode" placeholder="Enter coupon code">
                                <button class="btn btn-primary" type="button" id="applyCoupon">Apply</button>
                            </div>
                            <div id="couponMessage" class="small"></div>
                        </div>
                    <% } %>

                    <!-- Payment Options -->
                    <div class="mt-4">
                        <h5>Payment Options</h5>
                        <div class="payment_method">
                            <div class="custome-radio mb-2">
                                <input class="form-check-input payment" type="radio" 
                                       value="cod" name="payment_option" id="CashOnDelivery" 
                                       <%= grandTotal <= 5000 ? 'checked' : '' %>
                                       <%= grandTotal > 5000 ? 'disabled' : '' %>>
                                <label class="form-check-label" for="CashOnDelivery">
                                    Cash on Delivery
                                    <% if (grandTotal > 5000) { %>
                                        <span class="text-danger small">(Not available for orders above ₹5000)</span>
                                    <% } %>
                                </label>
                            </div>
                            <div class="custome-radio mb-2">
                                <input class="form-check-input payment" type="radio" 
                                       value="razorpay" name="payment_option" id="Razorpay">
                                <label class="form-check-label" for="Razorpay">Razorpay</label>
                            </div>
                            <div class="custome-radio">
                                <input class="form-check-input payment" type="radio" 
                                       value="wallet" name="payment_option" id="wallet">
                                <label class="form-check-label" for="wallet">
                                    Wallet (Balance: ₹<%= user.walletBalance || 0 %>)
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Place Order Button -->
                    <button type="button" class="btn btn-primary w-100 mt-3" 
                            onclick="placeOrder('<%= user._id %>')">
                        <%= isCart ? 'Place Order' : 'Buy Now' %>
                    </button>

                    <!-- Hidden fields for buy-now data -->
                    <% if (!isCart && buyNowData) { %>
                        <input type="hidden" id="buyNow" value="true">
                        <input type="hidden" id="buyNowProductId" value="<%= buyNowData.productId %>">
                        <input type="hidden" id="buyNowSize" value="<%= buyNowData.size %>">
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
// Place Order Function
async function placeOrder(userId) {
    const selectedAddress = $("input[name='selectedAddress']:checked").val();
    const payment = $("input[name='payment_option']:checked").val();
    const totalValue = parseFloat($("#totalValue").text().replace(/[^\d.]/g, '')) || 0;
    const discount = parseFloat($("#discount").text().replace(/[^\d.]/g, '')) || 0;
    const buyNow = $("#buyNow").val() === "true";
    const productId = $("#buyNowProductId").val();
    const size = $("#buyNowSize").val();
    const couponCode = $("#couponCode").val();

    // Validate inputs
    if (!payment) {
        showError("Payment Method Required", "Please select a payment method");
        return;
    }

    if (!selectedAddress) {
        showError("Address Required", "Please select a delivery address");
        return;
    }

    // Parse the selected address (contains addressId and addressIndex)
    const { addressId, addressIndex } = JSON.parse(selectedAddress);

    if (payment === "cod" && totalValue > 5000) {
        showError("COD Not Available", "Cash on Delivery not available for orders above ₹5000");
        return;
    }

    if (payment === "wallet") {
        const walletBalance = parseFloat("<%= user.walletBalance || 0 %>");
        if (walletBalance < totalValue) {
            showError("Insufficient Balance", "Your wallet balance is insufficient for this order");
            return;
        }
    }

    // Prepare order data
    const orderData = {
        totalPrice: totalValue,
        addressId: addressId,
        addressIndex: addressIndex,
        payment: payment,
        discount: discount,
        couponCode: couponCode || null,
        buyNow: buyNow
    };

    // Add buy-now specific data if applicable
    if (buyNow) {
        orderData.productId = productId;
        orderData.size = size;
    } else {
        // Collect quantities for cart items
        orderData.quantities = {};
        $('.quantity-input').each(function() {
            orderData.quantities[$(this).data('product-id')] = parseInt($(this).val());
        });
    }

    try {
        // Show loading
        Swal.fire({
            title: 'Processing Order',
            html: 'Please wait while we process your order...',
            allowOutsideClick: false,
            didOpen: () => Swal.showLoading()
        });

        const response = await fetch("/orderPlaced", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify(orderData)
        });

        const data = await response.json();

        if (!response.ok || !data.status) {
            throw new Error(data.message || "Failed to place order");
        }

        // Handle payment methods
        if (payment === "razorpay" && data.razorpayOrder) {
            Swal.close();
            handleRazorpayPayment(data.razorpayOrder, data.order._id);
        } else {
            // For COD/Wallet, redirect to order confirmation
            window.location.href = `/successPage?id=${data.order._id}`;
        }
    } catch (error) {
        Swal.fire({
            icon: 'error',
            title: 'Order Failed',
            text: error.message || "An error occurred while placing your order"
        });
        console.error("Order error:", error);
    }
}

