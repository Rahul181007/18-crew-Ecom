<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  // Change main image when thumbnail is clicked
  function changeMainImage(thumbnail, imageSrc) {
    const mainImage = document.querySelector('.main-product-image');
    mainImage.src = `/uploads/re-image/${imageSrc}`;
    
    // Remove active class from all thumbnails
    document.querySelectorAll('.thumbnail-img').forEach(img => {
      img.classList.remove('active');
    });
    
    // Add active class to clicked thumbnail
    thumbnail.classList.add('active');
    
    // Reset zoom
    mainImage.style.transform = 'scale(1)';
  }

  // Add to cart function with stock validation
async function addToCart(productId) {
    const sizeInput = document.querySelector('input[name="size"]:checked');
    
    if (!sizeInput) {
      document.getElementById('size-error').textContent = 'Please select a size';
      return;
    }
    
    const size = sizeInput.value;
    
    try {
      const response = await fetch("/addToCart", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({ productId, size })
      });
      
      if (response.status === 401 || response.headers.get("content-type")?.includes("text/html")) {
        let data;
        try {
          data = await response.json();
        } catch {
          data = { message: "User not authenticated" };
        }
        Toastify({
          text: `<div class="toast-premium-content">
                  <div class="toast-icon">✕</div>
                  <span>${data.message || 'User not authenticated'}</span>
                </div>`,
          duration: 3000,
          gravity: "top",
          position: "right",
          className: "toast-premium-error",
          stopOnFocus: true,
          escapeMarkup: false
        }).showToast();
        window.location.href = '/signin';
        return;
      }
      
      const data = await response.json();
      
      if (response.ok && data.status) { 
        // Premium success toast with tick animation
        const toast = Toastify({
          text: `<div class="toast-premium-content">
                  <div class="toast-tick-animation">
                    <svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52">
                      <circle class="checkmark__circle" cx="26" cy="26" r="25" fill="none"/>
                      <path class="checkmark__check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
                    </svg>
                  </div>
                  <span>Added to cart</span>
                </div>`,
          duration: 2000,
          gravity: "top",
          position: "right",
          stopOnFocus: true,
          className: "toast-premium-success",
          escapeMarkup: false
        }).showToast();
        
        // Update cart badge
        const cartLink = document.querySelector('a[href="/getCartPage"]');
        if (cartLink) {
          let cartBadge = cartLink.querySelector('.badge-dot');
          if (!cartBadge && data.cartCount > 0) {
            cartBadge = document.createElement('span');
            cartBadge.className = 'badge-dot';
            cartLink.appendChild(cartBadge);
          }
          if (cartBadge) {
            cartBadge.style.display = data.cartCount > 0 ? 'block' : 'none';
          }
        }
      } else {
        // Premium error toast
        Toastify({
          text: `<div class="toast-premium-content">
                  <div class="toast-icon">✕</div>
                  <span>${data.message || 'Could not add to cart'}</span>
                </div>`,
          duration: 3000,
          gravity: "top",
          position: "right",
          className: "toast-premium-error",
          stopOnFocus: true,
          escapeMarkup: false
        }).showToast();
      }
    } catch (error) {
      console.error("Fetch error:", error); // Debug log
      // Premium network error toast
      Toastify({
        text: `<div class="toast-premium-content">
                <div class="toast-icon">⚠</div>
                <span>Network error occurred</span>
              </div>`,
        duration: 3000,
        gravity: "top",
        position: "right",
        className: "toast-premium-error",
        stopOnFocus: true,
        escapeMarkup: false
      }).showToast();
    }
}
  async function buyNow(productId) {
    const sizeInput = document.querySelector('input[name="size"]:checked');
    
    if (!sizeInput) {
      document.getElementById('size-error').textContent = 'Please select a size';
      return;
    }
    
    const size = sizeInput.value;
    
    // First check stock availability
    try {
       const stockCheck = await fetch(`/checkStock?productId=${productId}&size=${size}`);
       
      const stockData = await stockCheck.json();
      
      if (!stockData) {
        Swal.fire({
          icon: 'error',
          title: 'Out of Stock',
          text: 'This size is no longer available'
        });
        return;
      }
      
      // Proceed to checkout
      window.location.href = `/checkout?buyNow=true&productId=${productId}&size=${size}`;
      
    } catch (error) {
      Swal.fire({
        icon: 'error',
        title: 'Error',
        text: 'Could not verify stock availability or login & try'
      });
    }
  }

  // Toggle wishlist function
async function toggleWishlist(productId) {
    const wishlistHeart = document.getElementById('wishlist-heart');
    const isInWishlist = wishlistHeart.classList.contains('active');
    const endpoint = isInWishlist ? '/removeFromWishlist' : '/addToWishlist';
    
    try {
        // Show processing state
        wishlistHeart.classList.add('processing');
        const originalClasses = wishlistHeart.className;
        wishlistHeart.className = 'bi bi-arrow-repeat wishlist-heart processing';
        
        const response = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId })
        });
        
        const data = await response.json();
        
        if (response.ok && data.status) {
            // Toggle heart state
            wishlistHeart.classList.remove('bi-heart', 'bi-heart-fill', 'processing');
            wishlistHeart.classList.add(isInWishlist ? 'bi-heart' : 'bi-heart-fill');
            wishlistHeart.classList.toggle('active');
            wishlistHeart.setAttribute('aria-label', isInWishlist ? 'Add to wishlist' : 'Remove from wishlist');
            
            // Bounce animation
            wishlistHeart.classList.add('animate-bounce');
            setTimeout(() => wishlistHeart.classList.remove('animate-bounce'), 1000);
            
            // Success toast
            Toastify({
                text: `<div class="toast-premium-content">
                        <div class="toast-tick-animation">
                            <svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52">
                                <circle class="checkmark__circle" cx="26" cy="26" r="25" fill="none"/>
                                <path class="checkmark__check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
                            </svg>
                        </div>
                        <span>${isInWishlist ? 'Removed from Wishlist' : 'Added to Wishlist'}</span>
                    </div>`,
                duration: 2000,
                gravity: "top",
                position: "right",
                className: "toast-premium-success",
                escapeMarkup: false
            }).showToast();
            
            // Update wishlist badge count
            const wishlistLink = document.querySelector('a[href="/wishlist"]');
            if (wishlistLink) {
                let wishlistBadge = wishlistLink.querySelector('.badge-dot');
                if (data.wishlistCount > 0) {
                    if (!wishlistBadge) {
                        wishlistBadge = document.createElement('span');
                        wishlistBadge.className = 'badge-dot';
                        wishlistLink.appendChild(wishlistBadge);
                    }
                } else if (wishlistBadge) {
                    wishlistBadge.remove();
                }
            }
            
        } else if (response.status === 401) {
            // Auth required toast
            Toastify({
                text: `<div class="toast-premium-content">
                        <div class="toast-icon">🔒</div>
                        <span>Please sign in to manage wishlist</span>
                    </div>`,
                duration: 3000,
                gravity: "top",
                position: "right",
                className: "toast-premium-warning",
                escapeMarkup: false,
                onClick: () => window.location.href = '/signin'
            }).showToast();
            
            // Reset heart to original state
            wishlistHeart.className = originalClasses;
        } else {
            // Error toast
            Toastify({
                text: `<div class="toast-premium-content">
                        <div class="toast-icon">✕</div>
                        <span>${data.message || 'Operation failed'}</span>
                    </div>`,
                duration: 3000,
                gravity: "top",
                position: "right",
                className: "toast-premium-error",
                escapeMarkup: false
            }).showToast();
            
            // Reset heart to original state
            wishlistHeart.className = originalClasses;
        }
    } catch (error) {
        // Network error toast
        Toastify({
            text: `<div class="toast-premium-content">
                    <div class="toast-icon">⚠</div>
                    <span>Network error occurred</span>
                </div>`,
            duration: 3000,
            gravity: "top",
            position: "right",
            className: "toast-premium-error",
            escapeMarkup: false
        }).showToast();
        
        // Reset heart to original state
        wishlistHeart.className = originalClasses;
    } finally {
        wishlistHeart.classList.remove('processing');
    }
}
  // Image zoom effect
  const zoomContainer = document.querySelector('.zoom-container');
  const zoomImage = document.querySelector('.zoom-image');
  
  if (zoomContainer && zoomImage) {
    zoomContainer.addEventListener('mousemove', e => {
      const { left, top, width, height } = zoomContainer.getBoundingClientRect();
      const x = (e.clientX - left) / width * 100;
      const y = (e.clientY - top) / height * 100;
      zoomImage.style.transformOrigin = `${x}% ${y}%`;
      zoomImage.style.transform = 'scale(2)';
    });
    
    zoomContainer.addEventListener('mouseleave', () => {
      zoomImage.style.transform = 'scale(1)';
    });
  }

  // Size selection effect
  document.querySelectorAll('.size-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.size-btn').forEach(b => {
        b.classList.remove('selected');
      });
      if (!this.classList.contains('out-of-stock')) {
        this.classList.add('selected');
        document.getElementById('size-error').textContent = '';
      }
    });
  });

  // Clear size error on selection
  document.querySelectorAll('input[name="radio"]').forEach(input => {
    input.addEventListener('change', () => {
      document.getElementById('size-error').textContent = '';
    });
  });
</script>
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>



