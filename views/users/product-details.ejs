      <div class="row gy-4 text-center text-md-start align-items-start">
        
        <div class="col-md-6 col-lg-5">
          <h4 class="fw-bold">18-CREW<span class="text-danger">.</span></h4>
          <p class="text-muted small mb-0">
            Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s.
          </p>
        </div>
        
        <div class="col-md-3 col-lg-3">
          <h6 class="fw-semibold mb-3">COMPANY</h6>
          <ul class="list-unstyled text-muted small">
            <li><a href="/home" class="text-decoration-none text-muted">Home</a></li>
            <li><a href="/about" class="text-decoration-none text-muted">About us</a></li>
            <li><a href="/delivery" class="text-decoration-none text-muted">Delivery</a></li>
            <li><a href="/privacy" class="text-decoration-none text-muted">Privacy policy</a></li>
          </ul>
        </div>
  
        <div class="col-md-3 col-lg-4">
          <h6 class="fw-semibold mb-3">GET IN TOUCH</h6>
          <p class="mb-1 text-muted small">+1-212-456-7890</p>
          <p class="mb-0 text-muted small">18CREW@gmail.com</p>
        </div>
  
      </div>
  
      <hr class="my-5" />
      <div class="text-center text-muted small">
        Copyright © 2024 @ 18-CREW.dev – All Right Reserved.
      </div>
    </div>
  </footer>
<script>
  // Thumbnail click to change main image
  const thumbnails = document.querySelectorAll('.thumbnail-img');
  const mainImage = document.querySelector('.main-product-image');

  thumbnails.forEach(thumbnail => {
    thumbnail.addEventListener('click', () => {
      mainImage.src = thumbnail.src;
    });
  });

  // Zoom image on hover move
  const imageWrapper = document.querySelector('.product-image-wrapper');

  imageWrapper.addEventListener('mousemove', function(e) {
    const { left, top, width, height } = this.getBoundingClientRect();
    const x = ((e.pageX - left) / width) * 100;
    const y = ((e.pageY - top) / height) * 100;

    mainImage.style.transformOrigin = `${x}% ${y}%`;
    mainImage.style.transform = 'scale(2)';
  });

  imageWrapper.addEventListener('mouseleave', function() {
    mainImage.style.transform = 'scale(1)';
    mainImage.style.transformOrigin = 'center center';
  });


  const sizeRadios = document.querySelectorAll('input[name="size"]');
  const selectedSizeInput = document.getElementById('selected-size');

  sizeRadios.forEach(radio => {
    radio.addEventListener('change', () => {
      selectedSizeInput.value = radio.value;
    });
  });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js"></script>
<% include("../layouts/footer.ejs") %>


