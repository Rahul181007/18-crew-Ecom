<% include("../layouts/header.ejs") %>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

<style>
      body {
    font-family: 'Poppins', sans-serif;
  }
  .navbar-brand {
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: 1px;
  }
  .brand-dot {
    width: 10px;
    height: 10px;
    background: #C586A5;
    border-radius: 50%;
    display: inline-block;
  }
  .navbar-nav {
    gap: 2rem;
  }
  .thumbnail-img {
    width: 60px;
    cursor: pointer;
    margin-bottom: 10px;
  }

  .btn-check:checked + .btn {
    background-color: #000;
    color: #fff;
    border-color: #000;
  }

  .related-products img {
    width: 100%;
  }

  /* Zoom styles */
  .product-image-wrapper {
    position: relative;
    overflow: hidden;
    cursor: zoom-in;
  }

  .product-image-wrapper img {
    width: 100%;
    transition: transform 0.2s ease;
    transform-origin: center center;
  }
</style>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top py-3">
    <div class="container d-flex align-items-center justify-content-between">
      <a href="#" class="navbar-brand d-flex align-items-center gap-2">18-CREW <span class="brand-dot"></span></a>
      <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse flex-grow-1 justify-content-center" id="navbarContent">
        <ul class="navbar-nav mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link active" href="/">HOME</a></li>
          <li class="nav-item"><a class="nav-link" href="/shop">COLLECTION</a></li>
          <li class="nav-item"><a class="nav-link" href="#">ABOUT</a></li>
          <li class="nav-item"><a class="nav-link" href="#">CONTACT</a></li>
        </ul>
      </div>
      <div class="d-flex align-items-center gap-3">
        <a href="#" class="text-dark" style="font-size: 1.5rem;"><i class="bi bi-search"></i></a>
        <a href="#" class="text-dark" style="font-size: 1.5rem;"><i class="bi bi-bag"></i></a>
        <% if (locals?.user) { %>
          <div class="dropdown">
            <a class="nav-link dropdown-toggle text-uppercase fw-bold" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <%= locals.user.name %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/userProfile">Profile</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>
            </ul>
          </div>
        <% } else { %>
          <a href="/signin" class="text-dark" style="font-size: 1.5rem;">
            <i class="bi bi-person"></i>
          </a>
        <% } %>
      </div>
    </div>
  </nav>

<!-- Product Detail -->
<div class="container my-5">
  <div class="row">
    <!-- Thumbnails -->
    <div class="col-md-1">
      <% for (let i = 0; i < product.productImage.length; i++) { %>
        <img src="/uploads/re-image/<%= product.productImage[i] %>" class="thumbnail-img" alt="Thumb <%= i %>">
      <% } %>
    </div>

    <!-- Main Product Image -->
    <div class="col-md-5">
      <div class="product-image-wrapper">
        <img src="/uploads/re-image/<%= product.productImage[0] %>" class="img-fluid main-product-image" alt="Main Product">
      </div>
    </div>

    <!-- Product Info -->
    <div class="col-md-6">
      <h3><%= product.productName %></h3>
      <p class="text-muted"><%= product.brand %></p>
      <p class="mb-1">
        <span class="text-warning">&#9733;&#9733;&#9733;&#9733;&#9734;</span> (1222)
      </p>

      <h4>
        <span class="text-success fw-bold">₹<%= product.salePrice.toLocaleString('en-IN') %></span>
        <span class="text-muted ms-2"><strike>₹<%= product.regularPrice.toLocaleString('en-IN') %></strike></span>
        <span class="text-muted ms-2">
            <%= totalOffer ? totalOffer + "%" : "No offer" %>
          </span>
          
      </h4>
      <p><%= category.description %></p>

      <!-- Offers -->
      <div class="bg-light p-3 rounded my-3">
        <h6 class="fw-bold mb-2">Available Offers:</h6>
        <ul class="list-unstyled small mb-0">
          <li><i class="bi bi-tag-fill text-success me-2"></i>Get extra 10% off on orders above ₹999</li>
          <li><i class="bi bi-credit-card-fill text-primary me-2"></i>5% Cashback on HDFC Bank Credit Cards</li>
          <li><i class="bi bi-truck text-warning me-2"></i>Free delivery on first order</li>
        </ul>
      </div>

<!-- Size Selection -->
<div class="mb-4">
    <label class="form-label">Select Size:</label>
    <div class="btn-group w-100" role="group">
        <% product.sizes.forEach(size => { %>
            <input type="radio" class="btn-check" name="size" id="size-<%= size %>" value="<%= size %>" autocomplete="off" <%= size === product.sizes[0] ? 'checked' : '' %>>
            <label class="btn btn-outline-dark" for="size-<%= size %>"><%= size %></label>
        <% }) %>
    </div>
    <div id="size-error" class="text-danger mt-1"></div>
</div>

<!-- Add to Cart Form -->
<form action="/addToCart" method="POST">
    <input type="hidden" name="productId" value="<%= product._id %>">
    <input type="hidden" name="productImage" value="<%= product.productImage[0] %>">
    <input type="hidden" name="productName" value="<%= product.productName %>">
    <input type="hidden" name="productSalePrice" value="<%= product.salePrice %>">
    <input type="hidden" name="productSize" id="selected-size" value="<%= product.sizes[0] %>">
    <button type="submit" class="btn btn-dark mb-3">Add to Cart</button>
</form>
      <p class="text-muted small">100% Original product. Easy return within 7 days.</p>
    </div>
  </div>

  <!-- Tabs for Description & Reviews -->
  <div class="row mt-5">
    <div class="col-12">
      <ul class="nav nav-tabs" id="productTabs" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#description">Description</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#reviews">Reviews (1222)</button></li>
      </ul>
      <div class="tab-content p-3 border">
        <div class="tab-pane fade show active" id="description"><p><%= product.description %></p></div>
        <div class="tab-pane fade" id="reviews"><p>Customer reviews will be displayed here.</p></div>
      </div>
    </div>
  </div>

  <!-- Related Products -->
  <div class="mt-5">
    <h5 class="fw-bold text-uppercase mb-3">Related Products</h5>
    <div class="row related-products">
      <% relatedProducts.forEach(item => { %>
        <div class="col-6 col-md-2">
          <a href="/productDetails?id=<%= item._id %>" class="text-black text-decoration-none">
            <img src="/uploads/re-image/<%= item.productImage[0] %>" alt="<%= item.productName %>" class="img-fluid">
            <p><%= item.productName %><br><strong>₹<%= item.salePrice.toLocaleString('en-IN') %></strong></p>
          </a>
        </div>
      <% }) %>
    </div>
  </div>
</div>
<!-- FOOTER -->
