<%- include("../layouts/header.ejs") %>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">

<style>
  :root {
    --primary-color: #C586A5;
    --secondary-color: #1a1517;
    --accent-color: #e60039;
    --light-bg: #f8f9fa;
    --dark-text: #212529;
    --muted-text: #6c757d;
    --transition-speed: 0.3s;
  }
  
  body {
    font-family: 'Poppins', sans-serif;
    overflow-x: hidden;
  }
  
  /* Navigation */
  .navbar {
    box-shadow: 0 2px 15px rgba(0,0,0,0.05);
    transition: all var(--transition-speed) ease;
  }
  
  .navbar.scrolled {
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  
  .navbar-brand {
    font-weight: 700;
    font-size: 1.6rem;
    color: var(--secondary-color);
    letter-spacing: 0.5px;
    position: relative;
  }
  
  .brand-dot {
    width: 10px;
    height: 10px;
    background: var(--primary-color);
    border-radius: 50%;
    display: inline-block;
    margin-left: 4px;
  }
  
  .navbar-nav {
    gap: 1.5rem;
  }
  
  .navbar-nav .nav-link {
    font-weight: 500;
    color: var(--dark-text);
    transition: color var(--transition-speed);
    position: relative;
    padding: 0.5rem 0;
  }
  
  .navbar-nav .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--primary-color);
    transition: width var(--transition-speed);
  }
  
  .navbar-nav .nav-link:hover::after,
  .navbar-nav .nav-link.active::after {
    width: 100%;
  }
  
  .navbar-nav .nav-link:hover,
  .navbar-nav .nav-link.active {
    color: var(--primary-color);
  }
  
  /* Badge */
  .badge-dot {
    position: absolute;
    top: -5px;
    right: -5px;
    width: 10px;
    height: 10px;
    background-color: var(--accent-color);
    border-radius: 50%;
    border: 1px solid white;
  }

  /* Product Gallery Styles */
  .product-gallery {
    position: relative;
  }
  
  .main-product-image {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 10px;
    transition: transform 0.5s ease;
    cursor: zoom-in;
  }
  
  .thumbnail-container {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  
  .thumbnail-img {
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 6px;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.3s ease;
  }
  
  .thumbnail-img:hover, 
  .thumbnail-img.active {
    border-color: var(--primary-color);
    transform: scale(1.05);
  }
  
  /* Wishlist Heart Icon */
  .wishlist-heart {
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 1.5rem;
    color: var(--muted-text);
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 10;
  }

  .wishlist-heart.active {
    color: var(--primary-color);
  }

  .wishlist-heart:hover {
    transform: scale(1.2);
  }


  /* Product Info Styles */
  .product-info {
    padding-left: 1.5rem;
  }
  
  
  @media (max-width: 768px) {
    .product-info {
      padding-left: 0;
      margin-top: 1.5rem;
    }
    
    .thumbnail-container {
      flex-direction: row;
      order: 2;
      margin-top: 0.8rem;
      justify-content: center;
    }

    .wishlist-heart {
      top: 8px;
      right: 8px;
      font-size: 1.3rem;
    }
  }
  
  .price-display {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin: 1rem 0;
  }
  
  .current-price {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--primary-color);
  }
  
  .original-price {
    font-size: 1rem;
    color: var(--muted-text);
    text-decoration: line-through;
  }
  
  .discount-badge {
    background-color: var(--accent-color);
    color: white;
    padding: 0.2rem 0.6rem;
    border-radius: 16px;
    font-size: 0.8rem;
    font-weight: 600;
  }
  
  /* Size Selector */
  .size-selector {
    margin: 1.5rem 0;
  }
  
  .size-selector h5 {
    font-size: 0.95rem;
    margin-bottom: 0.8rem;
  }
  
  .size-option {
    position: relative;
  }
  
  .size-btn {
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #ddd;
    border-radius: 6px;
    background: white;
    font-weight: 600;
    font-size: 0.85rem;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  
  .size-btn:hover {
    border-color: var(--dark-text);
  }
  
  .size-btn.selected {
    border-color: var(--primary-color);
    background-color: rgba(197, 134, 165, 0.1);
  }
  
  .size-btn.out-of-stock {
    opacity: 0.5;
    position: relative;
    cursor: not-allowed;
  }
  
  .size-btn.out-of-stock:after {
    content: "";
    position: absolute;
    width: 100%;
    height: 1px;
    background-color: var(--accent-color);
    transform: rotate(-15deg);
    top: 50%;
    left: 0;
  }
  
  /* Action Buttons */
  .action-btns {
    display: flex;
    gap: 0.8rem;
    margin: 1.5rem 0;
    align-items: center;
  }
  
  .btn-add-to-cart {
    flex: 1;
    background-color: var(--secondary-color);
    color: white;
    padding: 0.75rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.3s ease;
    border: none;
  }
  
  .btn-add-to-cart:hover {
    background-color: #333;
    transform: translateY(-2px);
  }
  
  .btn-buy-now {
    flex: 1;
    background-color: var(--primary-color);
    color: white;
    padding: 0.75rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.3s ease;
    border: none;
  }
  
  .btn-buy-now:hover {
    background-color: #b36d8f;
    transform: translateY(-2px);
  }
  
  /* Product Details Accordion */
  .product-accordion .accordion-item {
    border: none;
    border-bottom: 1px solid #eee;
  }
  
  .product-accordion .accordion-button {
    background: none;
    padding: 0.8rem 0;
    font-weight: 600;
    font-size: 0.95rem;
  }
  
  .product-accordion .accordion-button:not(.collapsed) {
    color: var(--primary-color);
    background: none;
    box-shadow: none;
  }
  
  .product-accordion .accordion-button:focus {
    box-shadow: none;
  }
  
  .product-accordion .accordion-body {
    padding: 0 0 0.8rem 0;
    font-size: 0.9rem;
  }
  
  /* Description List */
  .feature-list {
    list-style: none;
    padding: 0;
  }
  
  .feature-list li {
    padding: 0.3rem 0;
    position: relative;
    padding-left: 1.2rem;
    font-size: 0.9rem;
  }
  
  .feature-list li:before {
    content: "•";
    color: var(--primary-color);
    font-size: 1.2rem;
    position: absolute;
    left: 0;
    top: -3px;
  }
  
  /* Related Products */
  .related-products {
    margin-top: 3rem;
  }
  
  .related-products h4 {
    font-size: 1.2rem;
    margin-bottom: 1rem;
  }
  
  .related-product-card {
    border: none;
    transition: all 0.3s ease;
    overflow: hidden;
    border-radius: 10px;
  }
  
  .related-product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 16px rgba(0,0,0,0.1);
  }
  
  .related-product-card img {
    transition: transform 0.5s ease;
  }
  
  .related-product-card:hover img {
    transform: scale(1.05);
  }
  
  .related-product-title {
    font-weight: 600;
    font-size: 0.9rem;
    margin: 0.4rem 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  /* Stock Badge */
  .stock-badge {
    padding: 0.4rem 0.8rem;
    border-radius: 16px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  
  .in-stock {
    background-color: rgba(40, 167, 69, 0.1);
    color: #28a745;
  }
  
  .low-stock {
    background-color: rgba(255, 193, 7, 0.1);
    color: #ffc107;
  }
  
  .out-of-stock-badge {
    background-color: rgba(220, 53, 69, 0.1);
    color: #dc3545;
  }
  
  /* Rating Styles */
  .rating-stars {
    color: #FFD700;
    font-size: 0.85rem;
  }
  
  .review-count {
    color: var(--muted-text);
    font-size: 0.8rem;
  }
  
 /* Footer */
  .footer {
    background: var(--secondary-color);
    color: white;
  }
  
  .footer-logo {
    font-weight: 700;
    font-size: 1.8rem;
    margin-bottom: 1rem;
    display: inline-block;
  }
  
  .footer-logo-dot {
    color: var(--primary-color);
  }
  
  .footer-about {
    color: rgba(255,255,255,0.7);
  }
  
  .footer-title {
    font-weight: 600;
    margin-bottom: 1.5rem;
    position: relative;
    display: inline-block;
  }
  
  .footer-title::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 40px;
    height: 2px;
    background: var(--primary-color);
  }
  
  .footer-links li {
    margin-bottom: 0.75rem;
  }
  
  .footer-link {
    color: rgba(255,255,255,0.7);
    transition: all var(--transition-speed);
    text-decoration: none;
  }
  
  .footer-link:hover {
    color: white;
    padding-left: 5px;
  }
  
  .footer-contact-item {
    margin-bottom: 1rem;
    display: flex;
    align-items: flex-start;
  }
  
  .footer-contact-icon {
    margin-right: 1rem;
    color: var(--primary-color);
  }
  
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 1.5rem;
  }
  
  /* Image Zoom Effect */
  .zoom-container {
    overflow: hidden;
    border-radius: 10px;
    position: relative;
  }
  
  .zoom-image {
    transition: transform 0.5s ease;
  }
  
  /* Product Title */
  .product-info h1 {
    font-size: 1.7rem;
    margin-bottom: 0.5rem;
  }
  
  .product-info .text-muted {
    font-size: 0.85rem;
  }
/* Premium Toast Styles */
.toast-premium-success {
  background: linear-gradient(135deg, #38a169 0%, #48bb78 100%) !important;
  padding: 16px 24px !important;
  border-radius: 12px !important;
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
  font-family: 'Inter', -apple-system, sans-serif !important;
  color: white !important;
  margin: 12px !important;
}

.toast-premium-error {
  background: linear-gradient(135deg, #e53e3e 0%, #f56565 100%) !important;
  padding: 16px 24px !important;
  border-radius: 12px !important;
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
  font-family: 'Inter', -apple-system, sans-serif !important;
  color: white !important;
  margin: 12px !important;
}

.toast-premium-content {
  display: flex;
  align-items: center;
  gap: 12px;
}

.toast-tick-animation {
  width: 24px;
  height: 24px;
}

.toast-icon {
  font-size: 20px;
  font-weight: bold;
}

/* Checkmark animation */
.checkmark {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: block;
  stroke-width: 4;
  stroke: #fff;
  stroke-miterlimit: 10;
  animation: fill .4s ease-in-out .4s forwards, scale .3s ease-in-out .9s both;
}

.checkmark__circle {
  stroke-dasharray: 166;
  stroke-dashoffset: 166;
  stroke-width: 4;
  stroke-miterlimit: 10;
  stroke: #fff;
  fill: none;
  animation: stroke .6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
}

.checkmark__check {
  transform-origin: 50% 50%;
  stroke-dasharray: 48;
  stroke-dashoffset: 48;
  animation: stroke .3s cubic-bezier(0.65, 0, 0.45, 1) .8s forwards;
}

@keyframes stroke {
  100% { stroke-dashoffset: 0; }
}

@keyframes scale {
  0%, 100% { transform: none; }
  50% { transform: scale3d(1.1, 1.1, 1); }
}

@keyframes fill {
  100% { box-shadow: inset 0 0 0 100vh transparent; }
}
  
  /* Responsive adjustments */
  @media (max-width: 576px) {
    .action-btns {
      flex-direction: column;
    }
    
    .price-display {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
    }
    
    .thumbnail-container {
      justify-content: flex-start;
    }
    
    .product-info h1 {
      font-size: 1.5rem;
    }
    
    .current-price {
      font-size: 1.3rem;
    }
  }
</style>

