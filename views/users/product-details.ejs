<div class="container my-4">
  <div class="row g-3">
    <!-- Thumbnails Column -->
    <div class="col-md-1 order-md-1 d-flex flex-md-column thumbnail-container">
      <% product.productImage.forEach((image, index) => { %>
        <img src="/uploads/re-image/<%= image %>" 
             class="thumbnail-img <%= index === 0 ? 'active' : '' %>" 
             alt="Thumbnail <%= index + 1 %>"
             onclick="changeMainImage(this, '<%= image %>')">
      <% }); %>
    </div>

    <!-- Main Image Column -->
    <div class="col-md-5 order-md-2">
      <div class="zoom-container rounded-3 overflow-hidden">
        <img src="/uploads/re-image/<%= product.productImage[0] %>" 
             class="img-fluid main-product-image zoom-image" 
             alt="<%= product.productName %>"
             id="mainProductImage">
        <% if (locals?.user || user) { %>
          <i id="wishlist-heart" 
             class="bi <%= isInWishlist ? 'bi-heart-fill active' : 'bi-heart' %> wishlist-heart"
             onclick="toggleWishlist('<%= product._id %>')"
             aria-label="<%= isInWishlist ? 'Remove from wishlist' : 'Add to wishlist' %>"></i>
        <% } %>
      </div>
    </div>

    <!-- Product Info Column -->
    <div class="col-md-6 order-md-3 product-info">
      <h1 class="fw-bold mb-1"><%= product.productName %></h1>
      <p class="text-muted mb-2"><%= product.brand?.brandName || product.brand || 'Unknown Brand' %></p>
      
      <div class="d-flex align-items-center mb-2">
        <div class="rating-stars me-2">
          <i class="bi bi-star-fill"></i>
          <i class="bi bi-star-fill"></i>
          <i class="bi bi-star-fill"></i>
          <i class="bi bi-star-fill"></i>
          <i class="bi bi-star-half"></i>
        </div>
        <span class="review-count">(1,222 reviews)</span>
      </div>

     
     <!-- Price and Stock Display -->
<div class="price-display">
  <div class="current-price">₹<%= product.salePrice.toLocaleString('en-IN') %></div>
  <% if (product.regularPrice > product.salePrice) { %>
    <div class="original-price">₹<%= product.regularPrice.toLocaleString('en-IN') %></div>
    <% if (product.productOffer > 0 && product.productOffer >= product.category.categoryOffer) { %>
      <div class="discount-badge"><%= product.productOffer %>% OFF</div>
    <% } else if (product.category.categoryOffer > 0) { %>
      <div class="discount-badge"><%= product.category.categoryOffer %>% OFF</div>
    <% }else{ %>
      <div class="discount-badge"><%= (product.regularPrice-product.salePrice )/100%>% OFF</div>
  <% } %>
    <% } %>
</div>
      
      <!-- Stock Status Badge -->
      <% const totalStock = product.sizes.reduce((sum, size) => sum + size.stock, 0); %>
      <div class="mb-3">
        <% if (totalStock > 0) { %>
          <% if (totalStock <= 5) { %>
            <span class="stock-badge low-stock">
              <i class="bi bi-exclamation-triangle-fill me-1"></i> Only <%= totalStock %> left!
            </span>
          <% } else { %>
            <span class="stock-badge in-stock">
              <i class="bi bi-check-circle-fill me-1"></i> In Stock
            </span>
          <% } %>
        <% } else { %>
          <span class="stock-badge out-of-stock-badge">
            <i class="bi bi-x-circle-fill me-1"></i> Out of Stock
          </span>
        <% } %>
      </div>

      <!-- Size Selection -->
      <div class="size-selector">
        <h5 class="fw-bold mb-2">SELECT SIZE</h5>
        <div class="d-flex flex-wrap gap-2">
          <% product.sizes.forEach(sizeObj => { %>
            <div class="size-option">
              <input type="radio" 
                     class="btn-check" 
                     name="size" 
                     id="size-<%= sizeObj.size %>" 
                     value="<%= sizeObj.size %>"
                     <%= sizeObj.stock <= 0 ? 'disabled' : '' %>
                     autocomplete="off">
              <label class="size-btn <%= sizeObj.stock <= 0 ? 'out-of-stock' : '' %>" 
                     for="size-<%= sizeObj.size %>">
                <%= sizeObj.size %>
              </label>
            </div>
          <% }); %>
        </div>
        <div id="size-error" class="text-danger small mt-1"></div>
      </div>

      <!-- Action Buttons -->
      <div class="action-btns">
        <% if (totalStock > 0) { %>
          <button class="btn-add-to-cart" onclick="addToCart('<%= product._id %>')">
            <i class="bi bi-cart-plus me-2"></i> ADD TO CART
          </button>
          <button class="btn-buy-now" onclick="buyNow('<%= product._id %>')">
            BUY NOW
          </button>
        <% } else { %>
          <button class="btn btn-secondary w-100 py-2" disabled>
            <i class="bi bi-bell-fill me-2"></i> NOTIFY WHEN AVAILABLE
          </button>
        <% } %>
      </div>

      <!-- Product Details Accordion -->
      <div class="product-accordion accordion" id="productAccordion">
        <div class="accordion-item">
          <h2 class="accordion-header">
            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDetails">
              PRODUCT DETAILS
            </button>
          </h2>
          <div id="collapseDetails" class="accordion-collapse collapse show" data-bs-parent="#productAccordion">
            <div class="accordion-body">
              <ul class="feature-list">
                <li><strong>Material:</strong> <%= product.material || 'Premium quality fabric' %></li>
                <li><strong>Fit:</strong> <%= product.fit || 'Regular fit' %></li>
                <li><strong>Color:</strong> <%= product.color || 'Not specified' %></li>
                <li><strong>Care Instructions:</strong> Machine wash cold, gentle cycle</li>
              </ul>
              <p class="mt-2"><%= product.description || 'No description available.' %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Related Products -->
  <div class="related-products">
    <div class="row">
      <div class="col-12">
        <h4 class="fw-bold mb-3">YOU MAY ALSO LIKE</h4>
      </div>
      
      <% if (relatedProducts && relatedProducts.length > 0) { %>
        <% for(let i=0; i < Math.min(4, relatedProducts.length); i++) { %>
          <div class="col-6 col-md-3 mb-3">
            <a href="/productDetails?id=<%= relatedProducts[i]._id %>" class="text-decoration-none text-dark">
              <div class="card related-product-card h-100">
                <img src="/uploads/re-image/<%= relatedProducts[i].productImage[0] || 'default.jpg' %>" 
                     class="card-img-top" 
                     alt="<%= relatedProducts[i].productName %>">
                <div class="card-body">
                  <h6 class="related-product-title"><%= relatedProducts[i].productName || 'Unnamed Product' %></h6>
                  <div class="d-flex align-items-center">
                    <span class="fw-bold text-success">₹<%= relatedProducts[i].salePrice.toLocaleString('en-IN') %></span>
                    <% if (relatedProducts[i].regularPrice > relatedProducts[i].salePrice) { %>
                      <span class="text-muted small ms-2"><del>₹<%= relatedProducts[i].regularPrice.toLocaleString('en-IN') %></del></span>
                    <% } %>
                  </div>
                </div>
              </div>
            </a>
          </div>
        <% } %>
      <% } else { %>
        <div class="col-12">
          <p class="text-muted">No related products found</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

