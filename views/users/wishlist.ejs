<%- include("../layouts/header.ejs") %>

<link
  href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
  rel="stylesheet"
/>
<link
  href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
  rel="stylesheet"
/>
<link
  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css"
  rel="stylesheet"
  crossorigin="anonymous"
/>
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css"
/>

<style>
  :root {
    --primary-color: #c586a5;
    --secondary-color: #1a1517;
    --accent-color: #e60039;
    --light-bg: #f8f9fa;
    --dark-text: #212529;
    --muted-text: #6c757d;
    --transition-speed: 0.3s;
  }

  body {
    font-family: "Poppins", sans-serif;
    overflow-x: hidden;
  }

  /* Navigation */
  .navbar {
    box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
    transition: all var(--transition-speed) ease;
  }

  .navbar.scrolled {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .navbar-brand {
    font-weight: 700;
    font-size: 1.6rem;
    color: var(--secondary-color);
    letter-spacing: 0.5px;
    position: relative;
  }

  .brand-dot {
    width: 10px;
    height: 10px;
    background: var(--primary-color);
    border-radius: 50%;
    display: inline-block;
    margin-left: 4px;
  }

  .navbar-nav {
    gap: 1.5rem;
  }

  .navbar-nav .nav-link {
    font-weight: 500;
    color: var(--dark-text);
    transition: color var(--transition-speed);
    position: relative;
    padding: 0.5rem 0;
  }

  .navbar-nav .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--primary-color);
    transition: width var(--transition-speed);
  }

  .navbar-nav .nav-link:hover::after,
  .navbar-nav .nav-link.active::after {
    width: 100%;
  }

  .navbar-nav .nav-link:hover,
  .navbar-nav .nav-link.active {
    color: var(--primary-color);
  }

  /* Badge */
  .badge-dot {
    position: absolute;
    top: -5px;
    right: -5px;
    width: 10px;
    height: 10px;
    background-color: var(--accent-color);
    border-radius: 50%;
    border: 1px solid white;
  }

  @keyframes pulse {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.5);
    }
    100% {
      transform: scale(1);
    }
  }

  .page-header {
    background: linear-gradient(180deg, #f8f9fa, #ffffff);
    padding: 2rem 0;
    border-bottom: 1px solid #e9ecef;
  }

  .breadcrumb a {
    color: #c586a5;
    text-decoration: none;
    font-weight: 500;
  }

  .breadcrumb span {
    color: #6c757d;
    margin: 0 0.5rem;
  }

  .wishlist-section {
    padding: 3rem 0;
  }

  .wishlist-card {
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    transition: transform 0.2s;
  }

  .wishlist-card:hover {
    transform: translateY(-5px);
  }

  .wishlist-card img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 8px;
  }

  .wishlist-card .product-info {
    flex: 1;
  }

  .wishlist-card .product-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: #333;
    margin-bottom: 0.5rem;
  }

  .wishlist-card .product-description {
    font-size: 0.9rem;
    color: #6c757d;
  }

  .wishlist-card .price {
    font-size: 1.1rem;
    font-weight: 600;
    color: #c586a5;
  }

  .wishlist-card .btn {
    font-size: 0.9rem;
    padding: 0.5rem 1.2rem;
    border-radius: 8px;
  }

  .btn-primary {
    background: linear-gradient(45deg, #1a1517, #1f1b1d);
    border: none;
    transition: all 0.3s;
  }

  .btn-primary:hover {
    background: linear-gradient(45deg, #2c2527, #332e30);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
  }

  .btn-danger {
    background: #dc3545;
    border: none;
  }

  .btn-danger:hover {
    background: #c82333;
  }

  .empty-wishlist {
    text-align: center;
    padding: 3rem;
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .empty-wishlist p {
    font-size: 1.2rem;
    color: #6c757d;
    margin-bottom: 1rem;
  }

  .empty-wishlist a {
    font-size: 1rem;
    color: #c586a5;
    text-decoration: none;
    font-weight: 500;
  }
  /* Premium Toast Styles */
  .toast-premium-success {
    background: linear-gradient(135deg, #38a169 0%, #48bb78 100%) !important;
    padding: 16px 24px !important;
    border-radius: 12px !important;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1),
      0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
    font-family: "Inter", -apple-system, sans-serif !important;
    color: white !important;
    margin: 12px !important;
  }

  .toast-premium-error {
    background: linear-gradient(135deg, #e53e3e 0%, #f56565 100%) !important;
    padding: 16px 24px !important;
    border-radius: 12px !important;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1),
      0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
    font-family: "Inter", -apple-system, sans-serif !important;
    color: white !important;
    margin: 12px !important;
  }

  .toast-premium-content {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .toast-tick-animation {
    width: 24px;
    height: 24px;
  }

  .toast-icon {
    font-size: 20px;
    font-weight: bold;
  }

  /* Checkmark animation */
  .checkmark {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: block;
    stroke-width: 4;
    stroke: #fff;
    stroke-miterlimit: 10;
    animation: fill 0.4s ease-in-out 0.4s forwards,
      scale 0.3s ease-in-out 0.9s both;
  }

  .checkmark__circle {
    stroke-dasharray: 166;
    stroke-dashoffset: 166;
    stroke-width: 4;
    stroke-miterlimit: 10;
    stroke: #fff;
    fill: none;
    animation: stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
  }

  .checkmark__check {
    transform-origin: 50% 50%;
    stroke-dasharray: 48;
    stroke-dashoffset: 48;
    animation: stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.8s forwards;
  }

  @keyframes stroke {
    100% {
      stroke-dashoffset: 0;
    }
  }

  @keyframes scale {
    0%,
    100% {
      transform: none;
    }
    50% {
      transform: scale3d(1.1, 1.1, 1);
    }
  }

  @keyframes fill {
    100% {
      box-shadow: inset 0 0 0 100vh transparent;
    }
  }
  @media (max-width: 768px) {
    .wishlist-card {
      flex-direction: column;
      text-align: center;
    }

    .wishlist-card img {
      width: 100px;
      height: 100px;
    }

    .wishlist-card .btn {
      width: 100%;
      margin-top: 0.5rem;
    }
  }
</style>

<nav class="navbar navbar-expand-lg navbar-light bg-white py-3">
  <div class="container">
    <a href="/" class="navbar-brand d-flex align-items-center">
      18-CREW<span class="brand-dot"></span>
    </a>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarContent"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarContent">
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a
            class="nav-link <%= typeof page !== 'undefined' && page === 'home' ? 'active' : '' %>"
            href="/"
            >HOME</a
          >
        </li>
        <li class="nav-item">
          <a
            class="nav-link <%= typeof page !== 'undefined' && page === 'shop' ? 'active' : '' %>"
            href="/shop"
            >COLLECTION</a
          >
        </li>
        <li class="nav-item">
          <a
            class="nav-link <%= typeof page !== 'undefined' && page === 'about' ? 'active' : '' %>"
            href="/about"
            >ABOUT</a
          >
        </li>
        <li class="nav-item">
          <a
            class="nav-link <%= typeof page !== 'undefined' && page === 'contact' ? 'active' : '' %>"
            href="/contact"
            >CONTACT</a
          >
        </li>

        <% if (locals?.user || user) { %>
        <li class="nav-item dropdown d-lg-none">
          <a
            class="nav-link dropdown-toggle text-uppercase fw-bold"
            href="#"
            role="button"
            data-bs-toggle="dropdown"
          >
            <%= user.name %>
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/userProfile">Profile</a></li>
            <li><hr class="dropdown-divider" /></li>
            <li>
              <a class="dropdown-item text-danger" href="/logout">Logout</a>
            </li>
          </ul>
        </li>
        <% } else { %>
        <li class="nav-item d-lg-none">
          <a class="nav-link" href="/signin"
            ><i class="bi bi-person me-2"></i>Sign In</a
          >
        </li>
        <% } %>
      </ul>

      <div class="d-none d-lg-flex align-items-center gap-4">
        <% if (locals?.user || user) { %>
        <div class="dropdown">
          <a
            class="nav-link dropdown-toggle text-uppercase fw-bold d-flex align-items-center"
            href="#"
            role="button"
            data-bs-toggle="dropdown"
          >
            <i class="bi bi-person-circle me-2"></i>
            <%= user.name %>
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="/userProfile">Profile</a></li>
            <li><hr class="dropdown-divider" /></li>
            <li>
              <a class="dropdown-item text-danger" href="/logout">Logout</a>
            </li>
          </ul>
        </div>
        <% } else { %>
        <a href="/signin" class="text-dark fs-5" title="Account">
          <i class="bi bi-person"></i>
        </a>
        <% } %>
        <a
          href="/wishlist"
          class="text-dark position-relative fs-5"
          title="Wishlist"
          aria-label="Wishlist<%= wishlistCount > 0 ? ` with ${wishlistCount} items` : '' %>"
        >
          <i class="bi bi-heart"></i>
          <% if (wishlistCount > 0) { %>
          <span class="badge-dot"></span>
          <% } %>
        </a>
        <a
          href="/getCartPage"
          class="text-dark position-relative fs-5"
          title="Cart"
          aria-label="Cart<%= cartCount > 0 ? ` with ${cartCount} items` : '' %>"
        >
          <i class="bi bi-bag"></i>
          <% if (cartCount > 0) { %>
          <span class="badge-dot"></span>
          <% } %>
        </a>
      </div>
    </div>
  </div>
</nav>

<main class="main">
  <div class="page-header breadcrumb-wrap">
    <div class="container">
      <div class="breadcrumb">
        <a href="/" rel="nofollow">Home</a>
        <span>></span> Collection <span>></span> My Wishlist
      </div>
    </div>
  </div>

  <section class="wishlist-section">
    <div class="container">
      <div class="row">
        <div class="col-12">
          <% if (wishlistCount > 0 && wishlist && wishlist.length > 0) { %> <%
          wishlist.forEach(product => { %>
          <div
            class="wishlist-card"
            data-product-id="<%= product.product._id %>"
          >
            <img
              src="/Uploads/re-image/<%= product.product.productImage && product.product.productImage[0] ? product.product.productImage[0] : 'default.jpg' %>"
              alt="<%= product.product.productName || 'Product Image' %>"
            />
            <div class="product-info">
              <h5 class="product-name">
                <a
                  href="/productDetails?id=<%= product.product._id %>"
                  class="text-black text-decoration-none"
                >
                  <%= product.product.productName || 'Unnamed Product' %>
                </a>
              </h5>
              <p class="product-description">
                <%= product.product.category && product.product.category.name ?
                product.product.category.name : 'Unknown Category' %><br />
                <%= product.product.brand && product.product.brand.brandName ?
                product.product.brand.brandName : product.product.brand ||
                'Unknown Brand' %>
              </p>
            </div>
            <div class="price">
              ₹<%= product.product.salePrice ?
              product.product.salePrice.toLocaleString('en-IN') : '0' %>
            </div>
            <a
              href="#"
              onclick="promptForSize('<%= product.product._id %>', <%= JSON.stringify(product.product.sizes || []) %>)"
              class="btn btn-primary"
              aria-label="Add <%= product.product.productName || 'product' %> to cart"
              >Add to Cart</a
            >
            <a
              href="#"
              onclick="removeFromWishlist('<%= product.product._id %>', this)"
              class="btn btn-danger"
              aria-label="Remove <%= product.product.productName || 'product' %> from wishlist"
            >
              <i class="bi bi-trash"></i>
            </a>
          </div>
          <% }) %> <% } else { %>
          <div class="empty-wishlist">
            <p class="lead mb-4">No items found in Wishlist</p>
            <a href="/shop">Explore Collection</a>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </section>
</main>

<script
  src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js"
  crossorigin="anonymous"
></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@10"></script>
<script>
  async function promptForSize(productId, sizes) {
    if (!sizes || sizes.length === 0) {
      Swal.fire({
        icon: "error",
        title: "No Sizes Available",
        text: "This product has no size options.",
        timer: 1500,
        showConfirmButton: false,
      });
      return;
    }

    const availableSizes = sizes.filter((size) => size.stock > 0);
    if (availableSizes.length === 0) {
      Swal.fire({
        icon: "error",
        title: "Out of Stock",
        text: "No sizes are currently in stock.",
        timer: 1500,
        showConfirmButton: false,
      });
      return;
    }

    const { value: size } = await Swal.fire({
      title: "Select Size",
      input: "select",
      inputOptions: availableSizes.reduce((options, size) => {
        options[size.size] = size.size;
        return options;
      }, {}),
      inputPlaceholder: "Choose a size",
      showCancelButton: true,
      confirmButtonText: "Add to Cart",
      cancelButtonText: "Cancel",
      confirmButtonColor: "#1a1517",
      cancelButtonColor: "#6c757d",
      inputValidator: (value) => {
        if (!value) {
          return "Please select a size!";
        }
      },
    });

    if (size) {
      await addToCart(productId, size, true);
    }
  }

  async function addToCart(productId, size, fromWishlist = false) {
    try {
      const response = await fetch("/addToCart", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ productId, size, fromWishlist }),
      });
      const data = await response.json();

      if (response.ok && data.status) {
        // Premium success toast with tick animation
        Toastify({
          text: `<div class="toast-premium-content">
                <div class="toast-tick-animation">
                  <svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52">
                    <circle class="checkmark__circle" cx="26" cy="26" r="25" fill="none"/>
                    <path class="checkmark__check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
                  </svg>
                </div>
                <span>${
                  fromWishlist
                    ? "Added to Cart & Removed from Wishlist"
                    : "Added to Cart"
                }</span>
              </div>`,
          duration: 2000,
          gravity: "top",
          position: "right",
          className: "toast-premium-success",
          escapeMarkup: false,
        }).showToast();

        // Update cart badge
        const cartLink = document.querySelector('a[href="/getCartPage"]');
        if (cartLink) {
          let cartBadge = cartLink.querySelector(".badge-dot");
          if (!cartBadge && data.cartCount > 0) {
            cartBadge = document.createElement("span");
            cartBadge.className = "badge-dot";
            cartLink.appendChild(cartBadge);
          }
          if (cartBadge) {
            cartBadge.style.display = data.cartCount > 0 ? "block" : "none";
          }
        }

        // If from wishlist, remove the card and update wishlist count
        if (fromWishlist && data.productId) {
          const card = document.querySelector(
            `.wishlist-card[data-product-id="${data.productId}"]`
          );
          if (card) {
            card.remove();
          }
          const wishlistLink = document.querySelector('a[href="/wishlist"]');
          if (wishlistLink) {
            let wishlistBadge = wishlistLink.querySelector(".badge-dot");
            if (data.wishlistCount === 0 && wishlistBadge) {
              wishlistBadge.remove();
            }
            if (data.wishlistCount > 0 && !wishlistBadge) {
              wishlistBadge = document.createElement("span");
              wishlistBadge.className = "badge-dot";
              wishlistLink.appendChild(wishlistBadge);
            }
          }
          // Show empty wishlist message if no items remain
          const wishlistSection = document.querySelector(
            ".wishlist-section .row .col-12"
          );
          if (data.wishlistCount === 0) {
            wishlistSection.innerHTML = `
            <div class="empty-wishlist">
              <p class="lead mb-4">No items found in Wishlist</p>
              <a href="/shop">Explore Collection</a>
            </div>
          `;
          }
        }
      } else {
        // Premium error toast
        Toastify({
          text: `<div class="toast-premium-content">
                <div class="toast-icon">✕</div>
                <span>${data.message || "Failed to add to cart."}</span>
              </div>`,
          duration: 3000,
          gravity: "top",
          position: "right",
          className: "toast-premium-error",
          escapeMarkup: false,
        }).showToast();
      }
    } catch (error) {
      // Premium network error toast
      Toastify({
        text: `<div class="toast-premium-content">
              <div class="toast-icon">⚠</div>
              <span>Unable to contact the server.</span>
            </div>`,
        duration: 3000,
        gravity: "top",
        position: "right",
        className: "toast-premium-error",
        escapeMarkup: false,
      }).showToast();
    }
  }

  async function removeFromWishlist(productId, element) {
    try {
      const response = await fetch("/deleteitemwish", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ productId }),
      });
      const data = await response.json();

      if (response.ok && data.status) {
        // Premium success toast with checkmark
        Toastify({
          text: `<div class="toast-premium-content">
                <div class="toast-tick-animation">
                  <svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52">
                    <circle class="checkmark__circle" cx="26" cy="26" r="25" fill="none"/>
                    <path class="checkmark__check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
                  </svg>
                </div>
                <span>Removed from Wishlist</span>
              </div>`,
          duration: 2000,
          gravity: "top",
          position: "right",
          className: "toast-premium-success",
          escapeMarkup: false,
        }).showToast();

        const card = element.closest(".wishlist-card");
        if (card) {
          card.remove();
        }
        const wishlistLink = document.querySelector('a[href="/wishlist"]');
        if (wishlistLink) {
          let wishlistBadge = wishlistLink.querySelector(".badge-dot");
          if (data.wishlistCount === 0 && wishlistBadge) {
            wishlistBadge.remove();
          }
        }
        const wishlistSection = document.querySelector(
          ".wishlist-section .row .col-12"
        );
        if (data.wishlistCount === 0) {
          wishlistSection.innerHTML = `
          <div class="empty-wishlist">
            <p class="lead mb-4">No items found in Wishlist</p>
            <a href="/shop">Explore Collection</a>
          </div>
        `;
        }
      } else {
        // Premium error toast
        Toastify({
          text: `<div class="toast-premium-content">
                <div class="toast-icon">✕</div>
                <span>${
                  data.message || "Failed to remove from wishlist."
                }</span>
              </div>`,
          duration: 3000,
          gravity: "top",
          position: "right",
          className: "toast-premium-error",
          escapeMarkup: false,
        }).showToast();
      }
    } catch (error) {
      // Premium network error toast
      Toastify({
        text: `<div class="toast-premium-content">
              <div class="toast-icon">⚠</div>
              <span>Unable to contact the server.</span>
            </div>`,
        duration: 3000,
        gravity: "top",
        position: "right",
        className: "toast-premium-error",
        escapeMarkup: false,
      }).showToast();
    }
  }
</script>
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

<%- include("../layouts/footer.ejs") %>
