<%- include("../layouts/admin/header.ejs") %>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<div class="main-content">
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold">Customers</h2>
</div>

<div class="text-center mb-4">
  <form action="/admin/users/" method="get" class="d-inline">
    <div class="input-group input-group-sm mx-auto" style="max-width: 400px;">
      <input type="text" class="form-control border-dark" placeholder="Search customers..." name="search" value="<%= search %>">
      <button class="btn btn-dark" type="submit">Search</button>
    </div>
  </form>
</div>

<div class="table-responsive">
  <table class="table table-bordered text-center align-middle" style="background-color: #fff;">
    <thead style="background-color: #ff4fc3; color: #fff;">
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Mobile No</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% if(data.length > 0) { %>
        <% for(let i=0; i<data.length; i++) { %>
          <tr>
            <td><%= data[i].name %></td>
            <td><%= data[i].email %></td>
            <td><%= data[i].mobile %></td>
            <td>
  <% if(!data[i].isBlocked) { %>
    <a href="javascript:void(0)" 
       class="btn btn-danger btn-sm"
       onclick="confirmAction('<%= data[i]._id %>', 'block')">Block</a>
  <% } else { %>
    <a href="javascript:void(0)" 
       class="btn btn-success btn-sm"
       onclick="confirmAction('<%= data[i]._id %>', 'unblock')">Unblock</a>
  <% } %>

            </td>
          </tr>
        <% } %>
      <% } else { %>
        <tr>
          <td colspan="4">No customers found.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <nav aria-label="Page navigation">
    <ul class="pagination justify-content-center">
      <% for(let i=1; i<=totalPages; i++) { %>
        <li class="page-item <%= (i===currentPage) ? 'active' : '' %>">
          <a class="page-link" href="?page=<%=i%>&search=<%=search%>" style =="<%= (i===currentPage) ? 'background-color:#ff4fc3; border-color:#ff4fc3; color:#fff;' : '' %>">
            <%= i %>
          </a> 
        </li>
      <% } %>
    </ul>
  </nav>
</div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
function confirmAction(id, actionType) {
  const actionText = actionType === 'block' ? 'block' : 'unblock';
  const buttonColor = actionType === 'block' ? '#d33' : '#28a745';
  const confirmUrl = actionType === 'block' 
                      ? `/admin/blockCustomer?id=${id}`
                      : `/admin/unblockCustomer?id=${id}`;

  Swal.fire({
    title: `Are you sure?`,
    text: `You are about to ${actionText} this customer.`,
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: buttonColor,
    cancelButtonColor: '#6c757d',
    confirmButtonText: `Yes, ${actionText} them!`
  }).then((result) => {
    if (result.isConfirmed) {
      window.location.href = confirmUrl;
    }
  });
}
</script>


<%- include("../layouts/admin/footer.ejs") %>
