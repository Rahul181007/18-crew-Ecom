<%- include("../layouts/admin/header.ejs") %>
<link
  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
  rel="stylesheet"
/>
<div class="main-content">
  <section class="content-main">
    <div class="content-header">
      <h2 class="content-title card-title">Brands</h2>
    </div>

    <div class="card p-4">
      <div class="row g-4 flex-wrap">
        <!-- Add Brand Form -->
        <div class="col-12 col-md-4">
          <% if (typeof error !== 'undefined') { %>
          <div class="alert alert-danger"><%= error %></div>
          <% } %> <% if (typeof success !== 'undefined') { %>
          <div class="alert alert-success"><%= success %></div>
          <% } %>
          <form
            method="post"
            action="/admin/addBrands"
            enctype="multipart/form-data"
          >
            <div class="mb-3">
              <label class="form-label">Brand Name</label>
              <input
                type="text"
                name="name"
                placeholder="Type here"
                class="form-control rounded-3 border-dark"
              />
            </div>
            <div class="mb-3">
              <label class="form-label">Brand Image</label>
              <input
                type="file"
                name="image"
                class="form-control rounded-3 border-dark"
              />
            </div>
            <button type="submit" class="btn btn-dark w-100 rounded-pill">
              Add Brand
            </button>
          </form>
        </div>

        <!-- Brands Table -->
        <div class="col-12 col-md-8">
          <div class="table-responsive">
            <table class="table align-middle text-center table-hover border">
              <thead class="table-light">
                <tr>
                  <th>Brand</th>
                  <th>Logo</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% brands.forEach(brand => { %>
                <tr>
                  <td class="text-start"><%= brand.brandName %></td>
                  <td>
                    <div
                      class="d-flex align-items-center justify-content-center"
                      style="
                        width: 50px;
                        height: 50px;
                        border-radius: 50%;
                        overflow: hidden;
                      "
                    >
                      <img
                        src="/uploads/re-image/<%= brand.brandImage[0] %>"
                        alt="<%=brand.brandName  %>"
                        class="img-fluid rounded-circle"
                      />
                    </div>
                  </td>
                  <td>
                    <% if (brand.isBlocked===false) { %>
                    <span class="badge bg-success rounded-pill px-3"
                      >Active</span
                    >
                    <% } else { %>
                    <span class="badge bg-danger rounded-pill px-3"
                      >Blocked</span
                    >
                    <% } %>
                  </td>

                  <td>
                    <% if(brand.isBlocked===false) {%>
                    <button class="btn btn-outline-danger btn-sm">
                      <a
                        href="/admin/blockBrand?id=<%= brand._id %>"
                        class="text-dark text-decoration-none"
                        >Block</a
                      >
                    </button>
                    <% }else{ %>
                    <button class="btn btn-outline-success btn-sm">
                      <a
                        href="/admin/unblockBrand?id=<%= brand._id %>"
                        class="text-dark text-decoration-none"
                        >Unblock</a
                      >
                    </button>
                    <% } %>
                    <button
                      class="btn btn-outline-danger btn-sm"
                      onclick="return confirmDelete()"
                    >
                      <a
                        href="/admin/deleteBrand?id=<%= brand._id %>"
                        class="text-dark text-decoration-none"
                        >Delete</a
                      >
                    </button>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
<script>
  function confirmDelete() {
    return confirm("Are you sure you want to delete");
  }
</script>

<%- include("../layouts/admin/footer.ejs") %>
