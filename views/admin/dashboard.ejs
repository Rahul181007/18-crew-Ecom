<!-- views/admin/sales-report.ejs -->
<%- include("../layouts/admin/header.ejs") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<style>
  .summary-card {
    border-radius: 10px;
    border: none;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    transition: transform 0.2s;
  }
  .summary-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 10px rgba(0, 0, 0, 0.1);
  }
  .card-title {
    font-weight: 600;
  }
  #salesReportTable th {
    font-weight: 600;
    background-color: #f8f9fa;
  }
  .badge {
    padding: 5px 10px;
    font-weight: 500;
  }
  .chart-container {
    position: relative;
    height: 300px;
    margin-bottom: 20px;
  }
</style>
<div class="main-content">
<div class="main-content container my-4">
   <div id="alertBox" class="alert alert-warning d-none" role="alert"></div>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="content-title">Sales Reports</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#reportModal">
      <i class="bi bi-download me-2"></i>Generate Report
    </button>
  </div>

  <!-- Report Filters -->
  <div class="card mb-4">
    <div class="card-body">
      <form id="salesReportForm">
        <div class="row">
          <div class="col-md-3">
            <label for="reportPeriod" class="form-label">Report Period</label>
            <select class="form-select" id="reportPeriod">
              <option value="daily">Daily</option>
              <option value="weekly">Weekly</option>
              <option value="monthly">Monthly</option>
              <option value="yearly">Yearly</option>
              <option value="custom">Custom Date Range</option>
            </select>
          </div>
          <div class="col-md-3" id="specificDateContainer">
            <label for="specificDate" class="form-label">Select Date</label>
            <input type="date" class="form-control" id="specificDate" max="<%= new Date().toISOString().split('T')[0] %>">
          </div>
          <div class="col-md-6" id="dateRangeContainer" style="display: none;">
            <div class="row">
              <div class="col-md-6">
                <label for="startDate" class="form-label">Start Date</label>
                <input type="date" class="form-control" id="startDate" max="<%= new Date().toISOString().split('T')[0] %>">
              </div>
              <div class="col-md-6">
                <label for="endDate" class="form-label">End Date</label>
                <input type="date" class="form-control" id="endDate" max="<%= new Date().toISOString().split('T')[0] %>">
              </div>
            </div>
          </div>
        </div>
        <div class="row mt-3">
          <div class="col-md-12">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-filter me-2"></i>Apply Filters
            </button>
            <button type="button" id="resetFilters" class="btn btn-outline-secondary ms-2">
              <i class="bi bi-arrow-counterclockwise me-2"></i>Reset
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="row mb-4">
    <div class="col-md-3">
      <div class="card summary-card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="card-subtitle mb-2 text-muted">Total Sales</h6>
              <h3 class="card-title mb-0">₹<span id="totalSales">0.00</span></h3>
            </div>
            <div class="bg-primary bg-opacity-10 p-3 rounded">
              <i class="bi bi-currency-inr text-primary fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card summary-card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="card-subtitle mb-2 text-muted">Total Orders</h6>
              <h3 class="card-title mb-0"><span id="totalOrders">0</span></h3>
            </div>
            <div class="bg-success bg-opacity-10 p-3 rounded">
              <i class="bi bi-cart-check text-success fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card summary-card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="card-subtitle mb-2 text-muted">Total Discounts</h6>
              <h3 class="card-title mb-0">₹<span id="totalDiscounts">0.00</span></h3>
            </div>
            <div class="bg-warning bg-opacity-10 p-3 rounded">
              <i class="bi bi-tag text-warning fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card summary-card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="card-subtitle mb-2 text-muted">Avg. Order Value</h6>
              <h3 class="card-title mb-0">₹<span id="avgOrderValue">0.00</span></h3>
            </div>
            <div class="bg-info bg-opacity-10 p-3 rounded">
              <i class="bi bi-graph-up text-info fs-4"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Sales Charts -->
  <div class="row mb-4">
    <div class="col-md-6">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title">Sales Distribution</h5>
          <div class="chart-container">
            <canvas id="salesPieChart"></canvas>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title">Sales Trend</h5>
          <div class="chart-container">
            <canvas id="salesLineChart"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>
<!-- Add this after the Sales Trend chart section -->
<div class="row mb-4">
  <div class="col-md-4">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title">Top Selling Products</h5>
        <div class="chart-container" style="height: 300px;">
          <canvas id="topProductsChart"></canvas>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title">Top Selling Categories</h5>
        <div class="chart-container" style="height: 300px;">
          <canvas id="topCategoriesChart"></canvas>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title">Top Selling Brands</h5>
        <div class="chart-container" style="height: 300px;">
          <canvas id="topBrandsChart"></canvas>
        </div>
      </div>
    </div>
  </div>
</div>
  <!-- Sales Report Table -->
  <div class="card">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-hover table-bordered" id="salesReportTable">
          <thead class="table-light">
            <tr>
              <th scope="col">Date</th>
              <th scope="col">Order ID</th>
              <th scope="col">Customer</th>
              <th scope="col">Amount</th>
              <th scope="col">Discount</th>
              <th scope="col">Coupon Used</th>
              <th scope="col">Net Amount</th>
              <th scope="col">Status</th>
            </tr>
          </thead>
          <tbody>
            <!-- Data will be loaded via JavaScript -->
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Report Generation Modal -->
  <div class="modal fade" id="reportModal" tabindex="-1" aria-labelledby="reportModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="reportModalLabel">Download Sales Report</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form id="downloadReportForm">
            <div class="mb-3">
              <label for="downloadFormat" class="form-label">Format</label>
              <select class="form-select" id="downloadFormat">
                <option value="pdf">PDF</option>
                <option value="excel">Excel</option>
                <option value="csv">CSV</option>
              </select>
            </div>
            <div class="mb-3">
              <label for="includeDetails" class="form-label">Include</label>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="includeDetails" checked>
                <label class="form-check-label" for="includeDetails">Detailed order information</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="includeSummary" checked>
                <label class="form-check-label" for="includeSummary">Summary statistics</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="includeCharts" checked>
                <label class="form-check-label" for="includeCharts">Charts and graphs</label>
              </div>
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary" id="downloadReportBtn">Download</button>
        </div>
      </div>
    </div>
  </div>
</div>
</div>
<!-- JavaScript -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js"></script>
<script>
  let salesPieChart, salesLineChart;

  function initCharts() {
    const pieCtx = document.getElementById('salesPieChart').getContext('2d');
    const lineCtx = document.getElementById('salesLineChart').getContext('2d');

    salesPieChart = new Chart(pieCtx, {
      type: 'pie',
      data: {
        labels: ['Gross Sales', 'Discounts', 'Net Sales'],
        datasets: [{
          data: [0, 0, 0],
          backgroundColor: ['#36A2EB', '#FFCE56', '#4BC0C0'],
          borderColor: ['#2A87C3', '#D9A441', '#3B9B9B'],
          borderWidth: 1,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { position: 'bottom' },
          tooltip: {
            callbacks: {
              label: function (context) {
                return `${context.label}: ₹${context.raw.toFixed(2)}`;
              },
            },
          },
        },
      },
    });

    salesLineChart = new Chart(lineCtx, {
      type: 'line',
      data: {
        labels: [],
        datasets: [{
          label: 'Daily Sales',
          data: [],
          backgroundColor: 'rgba(75, 192, 192, 0.2)',
          borderColor: '#4BC0C0',
          borderWidth: 2,
          tension: 0.3,
          fill: true,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { position: 'top' },
          tooltip: {
            callbacks: {
              label: function (context) {
                return `₹${context.raw.toFixed(2)}`;
              },
            },
          },
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              callback: function (value) {
                return `₹${value.toFixed(2)}`;
              },
            },
          },
          x: {
            ticks: {
              maxRotation: 45,
              minRotation: 45,
            },
          },
        },
      },
    });
  }

  function loadSalesData() {
  const period = document.getElementById('reportPeriod').value;
  const specificDate = document.getElementById('specificDate').value;
  const startDate = document.getElementById('startDate').value;
  const endDate = document.getElementById('endDate').value;

  // Validate inputs
  if (period === 'custom' && (!startDate || !endDate)) {
    showAlert('Please select both start and end dates for custom range.');
    return;
  }
  if (period === 'custom' && new Date(endDate) < new Date(startDate)) {
    showAlert('End date cannot be before start date.');
    return;
  }
  if (period !== 'custom' && !specificDate) {
    showAlert('Please select a date for the selected period.');
    return;
  }

  const tableBody = document.querySelector('#salesReportTable tbody');
  tableBody.innerHTML = '<tr><td colspan="8" class="text-center py-4"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></td></tr>';

  fetch('/admin/dashboard/reports/data', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ period, specificDate, startDate, endDate }),
  })
    .then((response) => {
      if (!response.ok) {
        throw new Error('Network response was not ok');
      }
      return response.json();
    })
    .then((data) => {
      if (!data.success) {
        throw new Error(data.message || 'Failed to load data');
      }

      // Update summary cards
      document.getElementById('totalSales').textContent = data.summary.totalSales.toFixed(2);
      document.getElementById('totalOrders').textContent = data.summary.totalOrders;
      document.getElementById('totalDiscounts').textContent = data.summary.totalDiscounts.toFixed(2);
      document.getElementById('avgOrderValue').textContent = data.summary.avgOrderValue.toFixed(2);

      // Update pie chart
      salesPieChart.data.datasets[0].data = [
        data.summary.totalSales + data.summary.totalDiscounts,
        data.summary.totalDiscounts,
        data.summary.totalSales,
      ];
      salesPieChart.update();

      // Update line chart
      if (data.dailyData && data.dailyData.length > 0) {
        salesLineChart.data.labels = data.dailyData.map((item) =>
          period === 'yearly'
            ? new Date(item.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
            : new Date(item.date).toLocaleDateString()
        );
        salesLineChart.data.datasets[0].data = data.dailyData.map((item) => item.amount);

        // Adjust x-axis for daily period
        if (period === 'daily') {
          salesLineChart.options.scales.x.title = {
            display: true,
            text: 'Date',
          };
          salesLineChart.options.scales.x.ticks.maxRotation = 0;
          salesLineChart.options.scales.x.ticks.minRotation = 0;
        } else {
          salesLineChart.options.scales.x.title = {
            display: true,
            text: period === 'yearly' ? 'Month' : 'Date',
          };
          salesLineChart.options.scales.x.ticks.maxRotation = 45;
          salesLineChart.options.scales.x.ticks.minRotation = 45;
        }
      } else {
        salesLineChart.data.labels = [new Date(specificDate).toLocaleDateString()];
        salesLineChart.data.datasets[0].data = [0];
        salesLineChart.options.scales.x.title = {
          display: true,
          text: 'Date',
        };
        salesLineChart.options.scales.x.ticks.maxRotation = 0;
        salesLineChart.options.scales.x.ticks.minRotation = 0;
      }
      salesLineChart.update();

      // Update table
      let tableHtml = '';
      if (data.data.length === 0) {
        tableHtml = '<tr><td colspan="8" class="text-center py-4">No orders found for the selected period.</td></tr>';
      } else {
        data.data.forEach((order) => {
          tableHtml += `
            <tr>
              <td>${new Date(order.date).toLocaleDateString()}</td>
              <td>#${order.orderId}</td>
              <td>${order.customer}</td>
              <td>₹${order.amount.toFixed(2)}</td>
              <td>₹${order.discount.toFixed(2)}</td>
              <td>${order.couponUsed || 'None'}</td>
              <td>₹${order.netAmount.toFixed(2)}</td>
              <td><span class="badge ${getStatusClass(order.status)}">${order.status}</span></td>
            </tr>
          `;
        });
      }
      tableBody.innerHTML = tableHtml;
    })
    .catch((error) => {
      tableBody.innerHTML = `<tr><td colspan="8" class="text-center py-4 text-danger">Error: ${error.message}. Please try again.</td></tr>`;
      console.error('Error loading sales data:', error);
    });
}

  function getStatusClass(status) {
    const statusClasses = {
      Initiated: 'bg-info',
      Pending: 'bg-warning',
      Processing: 'bg-primary',
      Shipped: 'bg-success',
      Delivered: 'bg-success',
      Cancelled: 'bg-danger',
      'Return Request': 'bg-warning',
      Returned: 'bg-secondary',
      'Partially Returned': 'bg-secondary',
    };
    return statusClasses[status] || 'bg-secondary';
  }

  document.addEventListener('DOMContentLoaded', function () {
    initCharts();
    initTopCharts();
    loadSalesData();
    loadTopSellingData();

    const today = new Date().toISOString().split('T')[0];
    document.getElementById('specificDate').value = today;

    document.getElementById('reportPeriod').addEventListener('change', function () {
      const period = this.value;
      document.getElementById('specificDateContainer').style.display = period !== 'custom' ? 'block' : 'none';
      document.getElementById('dateRangeContainer').style.display = period === 'custom' ? 'block' : 'none';

      if (period !== 'custom') {
        const today = new Date();
        let dateValue = today.toISOString().split('T')[0];

        if (period === 'weekly') {
          const day = today.getDay();
          const diff = today.getDate() - day + (day === 0 ? -6 : 1);
          const startOfWeek = new Date(today.setDate(diff));
          dateValue = startOfWeek.toISOString().split('T')[0];
        } else if (period === 'monthly') {
          dateValue = new Date(today.getFullYear(), today.getMonth(), 1).toISOString().split('T')[0];
        } else if (period === 'yearly') {
          dateValue = new Date(today.getFullYear(), 0, 1).toISOString().split('T')[0];
        }

        document.getElementById('specificDate').value = dateValue;
      }
    });

    document.getElementById('salesReportForm').addEventListener('submit', function (e) {
      e.preventDefault();
      loadSalesData();
    });

    document.getElementById('resetFilters').addEventListener('click', function () {
      document.getElementById('reportPeriod').value = 'daily';
      document.getElementById('specificDate').value = new Date().toISOString().split('T')[0];
      document.getElementById('startDate').value = '';
      document.getElementById('endDate').value = '';
      document.getElementById('dateRangeContainer').style.display = 'none';
      document.getElementById('specificDateContainer').style.display = 'block';
      loadSalesData();
    });

    document.getElementById('downloadReportBtn').addEventListener('click', function () {
      const format = document.getElementById('downloadFormat').value;
      const includeDetails = document.getElementById('includeDetails').checked;
      const includeSummary = document.getElementById('includeSummary').checked;
      const includeCharts = document.getElementById('includeCharts').checked;
      const period = document.getElementById('reportPeriod').value;
      const specificDate = document.getElementById('specificDate').value;
      const startDate = document.getElementById('startDate').value;
      const endDate = document.getElementById('endDate').value;

      // Validate inputs
      if (period === 'custom' && (!startDate || !endDate)) {
        alert('Please select both start and end dates for custom range.');
        return;
      }
      if (period === 'custom' && new Date(endDate) < new Date(startDate)) {
        alert('End date cannot be before start date.');
        return;
      }
      if (period !== 'custom' && !specificDate) {
        alert('Please select a date for the selected period.');
        return;
      }

      let url = `/admin/dashboard/reports/download?format=${format}`;
      url += `&includeDetails=${includeDetails}`;
      url += `&includeSummary=${includeSummary}`;
      url += `&includeCharts=${includeCharts}`;
      url += `&period=${period}`;
      url += period === 'custom' ? `&startDate=${startDate}&endDate=${endDate}` : `&specificDate=${specificDate}`;

      window.location.href = url;

      const modal = bootstrap.Modal.getInstance(document.getElementById('reportModal'));
      modal.hide();
    });
  });

  function showAlert(message, type = 'warning') {
  const alertBox = document.getElementById('alertBox');
  alertBox.className = `alert alert-${type}`;
  alertBox.textContent = message;
  alertBox.classList.remove('d-none');

  setTimeout(() => alertBox.classList.add('d-none'), 5000);
}



let topProductsChart, topCategoriesChart, topBrandsChart;

function initTopCharts() {
  const productCtx = document.getElementById('topProductsChart').getContext('2d');
  const categoryCtx = document.getElementById('topCategoriesChart').getContext('2d');
  const brandCtx = document.getElementById('topBrandsChart').getContext('2d');

  topProductsChart = new Chart(productCtx, {
    type: 'bar',
    data: { labels: [], datasets: [{ label: 'Quantity Sold', data: [] }] },
    options: getTopChartOptions('Products')
  });

  topCategoriesChart = new Chart(categoryCtx, {
    type: 'bar',
    data: { labels: [], datasets: [{ label: 'Revenue', data: [] }] },
    options: getTopChartOptions('Categories')
  });

  topBrandsChart = new Chart(brandCtx, {
    type: 'bar',
    data: { labels: [], datasets: [{ label: 'Revenue', data: [] }] },
    options: getTopChartOptions('Brands')
  });
}

function getTopChartOptions(title) {
  return {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      title: { display: true, text: `Top ${title} by Revenue` },
      legend: { display: false },
      tooltip: {
        callbacks: {
          label: function(context) {
            return `₹${context.raw.toFixed(2)}`;
          }
        }
      }
    },
    scales: {
      y: {
        beginAtZero: true,
        ticks: {
          callback: function(value) {
            return `₹${value.toFixed(2)}`;
          }
        }
      }
    }
  };
}

async function loadTopSellingData() {
  try {
    // Load top products
    const productsRes = await fetch('/admin/dashboard/reports/best-products');
    const productsData = await productsRes.json();
    if (productsData.success) {
      topProductsChart.data.labels = productsData.data.map(p => p.productName);
      topProductsChart.data.datasets[0].data = productsData.data.map(p => p.totalRevenue);
      topProductsChart.update();
    }

    // Load top categories
    const categoriesRes = await fetch('/admin/dashboard/reports/best-categories');
    const categoriesData = await categoriesRes.json();
    if (categoriesData.success) {
      topCategoriesChart.data.labels = categoriesData.data.map(c => c.category);
      topCategoriesChart.data.datasets[0].data = categoriesData.data.map(c => c.totalRevenue);
      topCategoriesChart.update();
    }

    // Load top brands
    const brandsRes = await fetch('/admin/dashboard/reports/best-brands');
    const brandsData = await brandsRes.json();
    if (brandsData.success) {
      topBrandsChart.data.labels = brandsData.data.map(b => b.brand);
      topBrandsChart.data.datasets[0].data = brandsData.data.map(b => b.totalRevenue);
      topBrandsChart.update();
    }
  } catch (error) {
    console.error('Error loading top selling data:', error);
  }
}
</script>

<%- include("../layouts/admin/footer.ejs") %>